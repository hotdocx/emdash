{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/scripts/infinity_codex.py\" hook",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "resume|compact",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/scripts/infinity_codex.py\" hook",
            "timeout": 30,
            "statusMessage": "Loading Infinity Codex recovery pointers"
          }
        ]
      }
    ]
  }
}
