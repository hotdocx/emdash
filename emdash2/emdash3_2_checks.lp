    I M
  : τ (Obj
      (@Prof_transf_cat
        I I J' J'
        (@Hom_prof_along I J' B M L)
        (@id_func I)
        (@Prof_imply_cov
          I J' J
          (@Hom_prof_along I J B M F)
          W)
        (@id_func J')));

assert [A B I K : Cat]
  (adj : τ (Adjunction A B))
  (M : τ (Functor I A))
  (F : τ (Functor K B)) ⊢
  @Adjunction_prof_transpose A B adj I K M F
  : τ (Obj
      (@Prof_transf_cat
        I I K K
        (@Hom_prof_along
          I K B
