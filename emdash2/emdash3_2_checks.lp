        C
        (@fapp0 A (Functor_cat A C) H a)
        (@fapp0 A (Functor_cat A C) H a')
        a
        a'
        (@fapp1_fapp0 A (Functor_cat A C) H a a' p)
        p;

// From emdash3_2.lp:4991.
assert [A C : Cat]
  (H K : τ (Functor A (Functor_cat A C)))
  (eta : τ (Transf H K))
  (a : τ (Obj A)) ⊢
  @tapp0_fapp0
      A
      C
      (@diag_func A C H)
      (@diag_func A C K)
      a
