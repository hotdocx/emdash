    ≡ @Transfd_cat K R D s t;

// From emdash3_2.lp:6959.
assert [K A : Cat] ⊢
  @Sigma_cat K (@Const_catd K A) ≡ Product_cat K A;

// From emdash3_2.lp:6962.
assert [K A : Cat]
  (x y : τ (Obj K))
  (u v : τ (Obj A)) ⊢
  @Hom_cat
