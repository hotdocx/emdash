            I A B
            (@left_adj_func A B adj)
            M)
          F)
        (@id_func I)
        (@Hom_prof_along
          I K A
          M
          (@comp_cat_fapp0
            K B A
            (@right_adj_func A B adj)
            F))
        (@id_func K)));

assert [A B I K : Cat]
  (adj : τ (Adjunction A B))
