assert [A B I K : Cat]
  (adj : τ (Adjunction A B))
  (M : τ (Functor I A))
  (F : τ (Functor K B)) ⊢
  @Prof_comp_transf
    I I I K K K
    (@Hom_prof_along
      I K B
      (@comp_cat_fapp0 I A B (@left_adj_func A B adj) M)
      F)
    (@Hom_prof_along
      I K A
      M
      (@comp_cat_fapp0 K B A (@right_adj_func A B adj) F))
    (@Hom_prof_along
      I K B
      (@comp_cat_fapp0 I A B (@left_adj_func A B adj) M)
      F)
    (@id_func I)
    (@id_func K)
    (@id_func I)
    (@id_func K)
    (@Adjunction_prof_untranspose A B adj I K M F)
    (@Adjunction_prof_transpose A B adj I K M F)
  ≡ @Prof_id_transf
      I K
      (@Hom_prof_along
        I K B
        (@comp_cat_fapp0 I A B (@left_adj_func A B adj) M)
        F);

assert [A B I K : Cat]
  (adj : τ (Adjunction A B))
  (M : τ (Functor I A))
  (F : τ (Functor K B)) ⊢
  @Prof_comp_transf
    I I I K K K
    (@Hom_prof_along
      I K A
      M
      (@comp_cat_fapp0 K B A (@right_adj_func A B adj) F))
    (@Hom_prof_along
      I K B
      (@comp_cat_fapp0 I A B (@left_adj_func A B adj) M)
      F)
    (@Hom_prof_along
      I K A
      M
