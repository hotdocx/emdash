  (q : τ (Hom K y z))
  (u : τ (Obj (Fibre_cat E x))) ⊢
  @fapp0
    (Fibre_cat E y)
    (Fibre_cat E z)
    (@catd_transport_func K E y z q)
    (@fapp0
      (Fibre_cat E x)
      (Fibre_cat E y)
      (@catd_transport_func K E x y p)
      u)
    ≡ @fapp0
        (Fibre_cat E x)
        (Fibre_cat E z)
        (@catd_transport_func K E x z (@comp_fapp0 K x y z q p))
        u;

// From emdash3_2.lp:7755.
assert [K : Cat] (E : τ (Catd K))
  (x y z : τ (Obj K))
  (u : τ (Obj (Fibre_cat E x)))
  (v : τ (Obj (Fibre_cat E y)))
  (w : τ (Obj (Fibre_cat E z)))
  (p : τ (Hom K x y))
  (q : τ (Hom K y z))
  (alpha : τ (Hom
      (Fibre_cat E y)
      (@fapp0
        (Fibre_cat E x)
        (Fibre_cat E y)
        (@catd_transport_func K E x y p)
        u)
      v))
  (beta : τ (Hom
      (Fibre_cat E z)
      (@fapp0
        (Fibre_cat E y)
        (Fibre_cat E z)
        (@catd_transport_func K E y z q)
        v)
      w)) ⊢
  @comp_fapp0
    (@Sigma_cat K E)
    (Struct_sigma x u)
    (Struct_sigma y v)
    (Struct_sigma z w)
    (@sigma_arrow K E y z v w q beta)
    (@sigma_arrow K E x y u v p alpha)
    ≡ @sigma_arrow
        K
        E
        x
        z
        u
        w
        (@comp_fapp0 K x y z q p)
        (@comp_fapp0
          (Fibre_cat E z)
          (@fapp0
            (Fibre_cat E x)
            (Fibre_cat E z)
            (@catd_transport_func K E x z (@comp_fapp0 K x y z q p))
            u)
          (@fapp0
            (Fibre_cat E y)
            (Fibre_cat E z)
            (@catd_transport_func K E y z q)
            v)
          w
          beta
          (@fapp1_fapp0
            (Fibre_cat E y)
            (Fibre_cat E z)
            (@catd_transport_func K E y z q)
            (@fapp0
              (Fibre_cat E x)
              (Fibre_cat E y)
              (@catd_transport_func K E x y p)
              u)
            v
            alpha));

