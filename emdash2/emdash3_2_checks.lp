    K
    (@Op_catd K E)
    (@Homd_target_catd K E)
    (@homd_int K E E (@id_funcd K E))
    (@comp_catd_fapp0
      K
      (@Op_catd K E)
      (@Op_catd K D)
      (@Homd_target_catd K E)
      (@homd_int K E D GG)
      (@Op_funcd K E D FF))
    (@tdapp1_int_fapp0_transfd K E D FF GG ϵ)
    x
    u
    ≡ @tdapp1_int_section_arrow K E D FF GG ϵ x u;

