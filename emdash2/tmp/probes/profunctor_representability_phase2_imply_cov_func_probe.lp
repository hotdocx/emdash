require open emdash.emdash3_2;

// Fixed-weight covariant implication as a functor in its first argument.
symbol Probe_Prof_imply_cov_func [A B X : Cat]
  (Q : Ď„ (Prof B X))
  : Ď„ (Functor
      (Prof_cat A X)
      (Prof_cat A B));

rule fapp0
      (@Probe_Prof_imply_cov_func $A $B $X $Q)
      $O
  â†Ş @Prof_imply_cov $A $B $X $O $Q;

// Full hom-action of the fixed-weight implication functor.
symbol Probe_Prof_imply_cov_func_fapp1_func
  [A B X : Cat]
  (Q : Ď„ (Prof B X))
  [O O' : Ď„ (Prof A X)]
  : Ď„ (Functor
      (@Functord_cat
        (Product_cat (Op_cat A) X)
        O O')
      (@Functord_cat
        (Product_cat (Op_cat A) B)
        (@Prof_imply_cov A B X O Q)
        (@Prof_imply_cov A B X O' Q)));

symbol Probe_Prof_imply_cov_func_transf
  [A B X : Cat]
  (Q : Ď„ (Prof B X))
  [O O' : Ď„ (Prof A X)]
  (o : Ď„ (Functord O O'))
  : Ď„ (Functord
      (@Prof_imply_cov A B X O Q)
      (@Prof_imply_cov A B X O' Q));

// Rewrite-capable mirror of the active mixed-variance constructor. This tests
// changing the active declaration from `constant symbol` to `symbol`.
symbol Probe_Prof_imply_cov_transf
  [A A' B B' X : Cat]
  [O : Ď„ (Prof A X)]
  [O' : Ď„ (Prof A' X)]
  [Q : Ď„ (Prof B X)]
  [Q' : Ď„ (Prof B' X)]
  [F : Ď„ (Functor A A')]
  [M : Ď„ (Functor B' B)]
  (o : Ď„ (Obj (@Prof_transf_cat A' A X X O F O' (@id_func X))))
  (q : Ď„ (Obj (@Prof_transf_cat B B' X X Q' M Q (@id_func X))))
  : Ď„ (Obj
      (@Prof_transf_cat
        A' A B' B'
        (@Prof_reindex
          A A B B'
          (@Prof_imply_cov A B X O Q)
          (@id_func A)
          M)
        F
        (@Prof_imply_cov A' B' X O' Q')
        (@id_func B')));

rule fapp1_func
      (@Probe_Prof_imply_cov_func $A $B $X $Q)
      [$O] [$O']
  â†Ş @Probe_Prof_imply_cov_func_fapp1_func
      $A $B $X $Q $O $O';

rule fapp0
      (@Probe_Prof_imply_cov_func_fapp1_func
        $A $B $X $Q $O $O')
      $o
  â†Ş @Probe_Prof_imply_cov_func_transf
      $A $B $X $Q $O $O' $o;

rule fapp1_fapp0
      (@Probe_Prof_imply_cov_func $A $B $X $Q)
      [$O] [$O'] $o
  â†Ş @Probe_Prof_imply_cov_func_transf
      $A $B $X $Q $O $O' $o;

// Unary functor laws.
rule @Probe_Prof_imply_cov_func_transf
      $A $B $X $Q
      $O $O
      (@id_funcd _ $O)
  â†Ş @id_funcd
      (Product_cat (Op_cat $A) $B)
      (@Prof_imply_cov $A $B $X $O $Q);

rule @Probe_Prof_imply_cov_func_transf
      $A $B $X $Q
      $O $O''
      (@comp_catd_fapp0
        _
        $O $O' $O''
        $o' $o)
  â†Ş @comp_catd_fapp0
      (Product_cat (Op_cat $A) $B)
      (@Prof_imply_cov $A $B $X $O $Q)
      (@Prof_imply_cov $A $B $X $O' $Q)
      (@Prof_imply_cov $A $B $X $O'' $Q)
      (@Probe_Prof_imply_cov_func_transf
        $A $B $X $Q $O' $O'' $o')
      (@Probe_Prof_imply_cov_func_transf
        $A $B $X $Q $O $O' $o);

// Reindexing a unary implication map reindexes both its varying input and its
// fixed weight, matching object-level implication reindexing.
rule @Prof_reindex_transf
      $A $A'
      $B $B'
      (@Prof_imply_cov $A $B $X $O $Q)
      (@Prof_imply_cov $A $B $X $O' $Q)
      (@Probe_Prof_imply_cov_func_transf
        $A $B $X $Q $O $O' $o)
      $F $M
  â†Ş @Probe_Prof_imply_cov_func_transf
      $A' $B' $X
      (@Prof_reindex
        $B $B' $X $X
        $Q $M (@id_func $X))
      (@Prof_reindex
        $A $A' $X $X
        $O $F (@id_func $X))
      (@Prof_reindex
        $A $A' $X $X
        $O' $F (@id_func $X))
      (@Prof_reindex_transf
        $A $A' $X $X
        $O $O' $o
        $F (@id_func $X));

// The identity-endpoint specialization of the mixed-variance action is the
// unary fixed-weight action.
rule @Probe_Prof_imply_cov_transf
      $A $A $B $B $X
      $O $O' $Q $Q
      (@id_func $A)
      (@id_func $B)
      $o
      (@Prof_id_transf $B $X $Q)
  â†Ş @Probe_Prof_imply_cov_func_transf
      $A $B $X $Q $O $O' $o;

assert [A B X : Cat]
  (Q : Ď„ (Prof B X))
  (O : Ď„ (Prof A X)) âŠ˘
  @fapp0
    (@Prof_cat A X)
    (@Prof_cat A B)
    (@Probe_Prof_imply_cov_func A B X Q)
    O
  â‰ˇ @Prof_imply_cov A B X O Q;

assert [A B X : Cat]
  (Q : Ď„ (Prof B X))
  [O O' : Ď„ (Prof A X)]
  (o : Ď„ (Functord O O')) âŠ˘
  @fapp1_fapp0
    (@Prof_cat A X)
    (@Prof_cat A B)
    (@Probe_Prof_imply_cov_func A B X Q)
    O O' o
  â‰ˇ @Probe_Prof_imply_cov_func_transf
      A B X Q O O' o;

assert [A B X : Cat]
  (Q : Ď„ (Prof B X))
  (O : Ď„ (Prof A X)) âŠ˘
  @Probe_Prof_imply_cov_func_transf
    A B X Q O O
    (@id_funcd (Product_cat (Op_cat A) X) O)
  â‰ˇ @id_funcd
      (Product_cat (Op_cat A) B)
      (@Prof_imply_cov A B X O Q);

assert [A B X : Cat]
  (Q : Ď„ (Prof B X))
  [O O' O'' : Ď„ (Prof A X)]
  (o : Ď„ (Functord O O'))
  (o' : Ď„ (Functord O' O'')) âŠ˘
  @Probe_Prof_imply_cov_func_transf
    A B X Q O O''
    (@comp_catd_fapp0
      (Product_cat (Op_cat A) X)
      O O' O'' o' o)
  â‰ˇ @comp_catd_fapp0
      (Product_cat (Op_cat A) B)
      (@Prof_imply_cov A B X O Q)
      (@Prof_imply_cov A B X O' Q)
      (@Prof_imply_cov A B X O'' Q)
      (@Probe_Prof_imply_cov_func_transf
        A B X Q O' O'' o')
      (@Probe_Prof_imply_cov_func_transf
        A B X Q O O' o);

assert [A A' B B' X : Cat]
  (Q : Ď„ (Prof B X))
  [O O' : Ď„ (Prof A X)]
  (o : Ď„ (Functord O O'))
  (F : Ď„ (Functor A' A))
  (M : Ď„ (Functor B' B)) âŠ˘
  @Prof_reindex_transf
    A A' B B'
    (@Prof_imply_cov A B X O Q)
    (@Prof_imply_cov A B X O' Q)
    (@Probe_Prof_imply_cov_func_transf
      A B X Q O O' o)
    F M
  â‰ˇ @Probe_Prof_imply_cov_func_transf
      A' B' X
      (@Prof_reindex
        B B' X X
        Q M (@id_func X))
      (@Prof_reindex
        A A' X X
        O F (@id_func X))
      (@Prof_reindex
        A A' X X
        O' F (@id_func X))
      (@Prof_reindex_transf
        A A' X X
        O O' o
        F (@id_func X));

assert [A B X : Cat]
  (Q : Ď„ (Prof B X))
  [O O' : Ď„ (Prof A X)]
  (o : Ď„ (Functord O O')) âŠ˘
  @Probe_Prof_imply_cov_transf
    A A B B X
    O O' Q Q
    (@id_func A)
    (@id_func B)
    o
    (@Prof_id_transf B X Q)
  â‰ˇ @Probe_Prof_imply_cov_func_transf
      A B X Q O O' o;
