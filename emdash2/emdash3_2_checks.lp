        (@right_adj_func A B adj)
        L));

assert [B J J' A : Cat]
  [W : τ (Prof J' J)]
  [F : τ (Functor J B)]
  [L : τ (Functor J' B)]
  (isl : τ (@IsWeightedLimit_cov_iso B J J' F W L))
  (adj : τ (Adjunction A B)) ⊢
  @iso_evidence_to
    (Prof_cat A J')
    _
    _
    (@right_adjoint_preserves_weighted_limit_cov_iso
      B J J' A W F L isl adj)
  ≡ @comp_catd_fapp0
      (Product_cat (Op_cat A) J')
      _ _ _
      (@Adjunction_prof_transpose
        A B adj A J' (@id_func A) L)
      (@comp_catd_fapp0
        (Product_cat (Op_cat A) J')
        _ _ _
        (@iso_evidence_to
          (Prof_cat A J')
          _ _
          (@right_adjoint_weighted_limit_iso_step2
            B J J' A W F L isl adj))
        (@fapp1_fapp0
          (Prof_cat A J)
          (Prof_cat A J')
          (@Prof_imply_cov_func A J' J W)
          (@Hom_prof
            J A
            (@comp_cat_fapp0
              J B A
              (@right_adj_func A B adj)
              F))
          (@Hom_prof_along
            A J B
            (@left_adj_func A B adj)
            F)
          (@Adjunction_prof_untranspose
            A B adj A J (@id_func A) F)));

assert [B J J' A : Cat]
  [W : τ (Prof J' J)]
  [F : τ (Functor J B)]
  [L : τ (Functor J' B)]
  (isl : τ (@WeightedLimit_cov B J J' F W L))
  (adj : τ (Adjunction A B)) ⊢
