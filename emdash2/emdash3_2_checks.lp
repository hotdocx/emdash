/*
  m- / emdash3.2 diagnostic/assertion checks.

  This file is generated by the first reorganization pass: the implementation
  lives in emdash3_2.lp, while Lambdapi diagnostic `assert` probes live here.
  The checks are kept in their original order and annotated with their source
  line in the pre-split emdash3_2.lp snapshot.
*/

flag "eta_equality" on;
flag "print_implicits" on;
flag "print_contexts" on;
flag "print_domains" on;
flag "print_meta_args" on;

require open emdash.emdash3_2;

// From emdash3_2.lp:350.
assert [A : Grpd] ⊢ Obj (Path_cat A) ≡ A;

// From emdash3_2.lp:351.
assert [A : Grpd] (x y : τ A) ⊢ Hom_cat (Path_cat A) x y ≡ Path_cat (x = y);

// From emdash3_2.lp:352.
assert [A : Grpd] (x : τ A) ⊢ @id (Path_cat A) x ≡ eq_refl x;

// From emdash3_2.lp:353.
assert [A : Grpd] (x y z : τ A) (p : τ (x = y)) (q : τ (y = z)) ⊢
  @comp_fapp0 (Path_cat A) x y z q p ≡ eq_trans p q;

// Ordinary categorical isomorphism evidence.
assert [C : Cat] (x : τ (Obj C)) ⊢
  @iso_evidence_to C x x (@iso_evidence_refl C x)
  ≡ @id C x;

assert [C : Cat] (x : τ (Obj C)) ⊢
  @iso_evidence_from C x x (@iso_evidence_refl C x)
  ≡ @id C x;

assert [C : Cat] (x : τ (Obj C)) ⊢
  @iso_evidence_left C x x (@iso_evidence_refl C x)
  ≡ eq_refl (@id C x);

assert [C : Cat] (x : τ (Obj C)) ⊢
  @iso_evidence_right C x x (@iso_evidence_refl C x)
  ≡ eq_refl (@id C x);

assert [C : Cat] [x y : τ (Obj C)]
  (i : τ (IsoEvidence C x y)) ⊢
  @iso_evidence_to C y x (@iso_evidence_sym C x y i)
  ≡ @iso_evidence_from C x y i;

assert [C : Cat] [x y : τ (Obj C)]
  (i : τ (IsoEvidence C x y)) ⊢
  @iso_evidence_from C y x (@iso_evidence_sym C x y i)
  ≡ @iso_evidence_to C x y i;

assert [C : Cat] [x y : τ (Obj C)]
  (i : τ (IsoEvidence C x y)) ⊢
  @iso_evidence_left C x y i
  : τ (
      @comp_fapp0 C x y x
        (@iso_evidence_from C x y i)
        (@iso_evidence_to C x y i)
      =
      @id C x);

assert [C : Cat] [x y : τ (Obj C)]
  (i : τ (IsoEvidence C x y)) ⊢
  @iso_evidence_right C x y i
  : τ (
      @comp_fapp0 C y x y
        (@iso_evidence_to C x y i)
        (@iso_evidence_from C x y i)
      =
      @id C y);

// Categorical univalence skeleton: 1-categorical staging and omega layer.
assert [C : Cat] (x : τ (Obj C)) ⊢
  @idtoiso_cat C x x (eq_refl x)
  ≡ @iso_evidence_refl C x;

assert [C : Cat] (x : τ (Obj C)) ⊢
  @iso_evidence_path C x x (@iso_evidence_refl C x)
  ≡ @eq_refl (Obj C) x;

assert [C : Cat] (x : τ (Obj C)) ⊢
  @iso_evidence_to C x x (@idtoiso_cat C x x (eq_refl x))
  ≡ @id C x;

assert [C : Cat]
  [x y : τ (Obj C)]
  (i : τ (IsoEvidence C x y)) ⊢
  @isotoid_cat C (cat_iso_univalence C) x y i
  : τ (x = y);

assert ⊢
  cat_iso_univalence Cat_cat
  : τ (CatIsoUnivalence Cat_cat);

assert ⊢
  cat_iso_univalence_by_decoder Cat_cat
  : τ (CatIsoUnivalenceByDecoder Cat_cat);

assert [C : Cat] (x : τ (Obj C)) ⊢
  omega_equiv_to (@omega_equiv_refl C x)
  ≡ @id C x;

assert [C : Cat] (x : τ (Obj C)) ⊢
  omega_equiv_left_inv (@omega_equiv_refl C x)
  ≡ @id C x;

assert [C : Cat] (x : τ (Obj C)) ⊢
  omega_equiv_right_inv (@omega_equiv_refl C x)
  ≡ @id C x;

assert [C : Cat] (x : τ (Obj C)) ⊢
  omega_equiv_left_cell (@omega_equiv_refl C x)
  ≡ @omega_equiv_refl (Hom_cat C x x) (@id C x);

assert [C : Cat] (x : τ (Obj C)) ⊢
  omega_equiv_right_cell (@omega_equiv_refl C x)
  ≡ @omega_equiv_refl (Hom_cat C x x) (@id C x);

assert [A : Grpd] (x : τ A) ⊢
  @path_cat_omega_path A x x
    (@omega_equiv_refl (Path_cat A) x)
  ≡ eq_refl x;

assert [A : Grpd] (x : τ A) ⊢
  @path_cat_iso_path A x x
    (@iso_evidence_refl (Path_cat A) x)
  ≡ eq_refl x;

assert [C : Cat]
  [x y : τ (Obj C)]
  (e : τ (OmegaEquiv C x y)) ⊢
  @omega_equiv_op C x y e
  : τ (OmegaEquiv (Op_cat C) y x);

assert [C : Cat]
  [x y : τ (Obj C)]
  (e : τ (OmegaEquiv C x y)) ⊢
  @id (Hom_cat (Op_cat C) y x)
    (@omega_equiv_to (Op_cat C) y x (@omega_equiv_op C x y e))
  ≡ @id (Hom_cat (Op_cat C) y x)
    (@omega_equiv_to C x y e);

assert [C : Cat]
  [x y : τ (Obj C)]
  (e : τ (OmegaEquiv C x y)) ⊢
  @id (Hom_cat (Op_cat C) x y)
    (@omega_equiv_left_inv (Op_cat C) y x (@omega_equiv_op C x y e))
  ≡ @id (Hom_cat (Op_cat C) x y)
    (@omega_equiv_right_inv C x y e);

assert [C : Cat]
  [x y : τ (Obj C)]
  (e : τ (OmegaEquiv C x y)) ⊢
  @id (Hom_cat (Op_cat C) x y)
    (@omega_equiv_right_inv (Op_cat C) y x (@omega_equiv_op C x y e))
  ≡ @id (Hom_cat (Op_cat C) x y)
    (@omega_equiv_left_inv C x y e);

assert [C : Cat]
  [x y : τ (Obj C)]
  (e : τ (OmegaEquiv C x y)) ⊢
  @id
    (Path_cat
      (OmegaEquiv
        (Hom_cat C y y)
        (@comp_fapp0 C y x y
          (@omega_equiv_to C x y e)
          (@omega_equiv_right_inv C x y e))
        (@id C y)))
    (@omega_equiv_left_cell (Op_cat C) y x (@omega_equiv_op C x y e))
  ≡ @id
    (Path_cat
      (OmegaEquiv
        (Hom_cat C y y)
        (@comp_fapp0 C y x y
          (@omega_equiv_to C x y e)
          (@omega_equiv_right_inv C x y e))
        (@id C y)))
    (@omega_equiv_right_cell C x y e);

assert [C : Cat]
  [x y : τ (Obj C)]
  (e : τ (OmegaEquiv C x y)) ⊢
  @id
    (Path_cat
      (OmegaEquiv
        (Hom_cat C x x)
        (@comp_fapp0 C x y x
          (@omega_equiv_left_inv C x y e)
          (@omega_equiv_to C x y e))
        (@id C x)))
    (@omega_equiv_right_cell (Op_cat C) y x (@omega_equiv_op C x y e))
  ≡ @id
    (Path_cat
      (OmegaEquiv
        (Hom_cat C x x)
        (@comp_fapp0 C x y x
          (@omega_equiv_left_inv C x y e)
          (@omega_equiv_to C x y e))
        (@id C x)))
    (@omega_equiv_left_cell C x y e);

assert [C : Cat] (x : τ (Obj C)) ⊢
  @omega_equiv_op C x x (@omega_equiv_refl C x)
  ≡ @omega_equiv_refl (Op_cat C) x;

assert [C : Cat] (x : τ (Obj C)) ⊢
  omega_equiv_to (@omega_equiv_op C x x (@omega_equiv_refl C x))
  ≡ @id (Op_cat C) x;

assert [A B : Cat]
  [x0 x1 : τ (Obj A)]
  [y0 y1 : τ (Obj B)]
  (iA : τ (IsoEvidence A x0 x1))
  (iB : τ (IsoEvidence B y0 y1)) ⊢
  @iso_evidence_product A B x0 x1 y0 y1 iA iB
  : τ (IsoEvidence
      (Product_cat A B)
      (Struct_sigma x0 y0)
      (Struct_sigma x1 y1));

assert [A B : Cat]
  [x0 x1 : τ (Obj A)]
  [y0 y1 : τ (Obj B)]
  (iA : τ (IsoEvidence A x0 x1))
  (iB : τ (IsoEvidence B y0 y1)) ⊢
  @iso_evidence_to
    (Product_cat A B)
    (Struct_sigma x0 y0)
    (Struct_sigma x1 y1)
    (@iso_evidence_product A B x0 x1 y0 y1 iA iB)
  ≡ @Struct_sigma
      (Obj (Hom_cat A x0 x1))
      (λ _ : τ (Obj (Hom_cat A x0 x1)), Obj (Hom_cat B y0 y1))
      (@iso_evidence_to A x0 x1 iA)
      (@iso_evidence_to B y0 y1 iB);

assert [A B : Cat]
  [x0 x1 : τ (Obj A)]
  [y0 y1 : τ (Obj B)]
  (iA : τ (IsoEvidence A x0 x1))
  (iB : τ (IsoEvidence B y0 y1)) ⊢
  @iso_evidence_from
    (Product_cat A B)
    (Struct_sigma x0 y0)
    (Struct_sigma x1 y1)
    (@iso_evidence_product A B x0 x1 y0 y1 iA iB)
  ≡ @Struct_sigma
      (Obj (Hom_cat A x1 x0))
      (λ _ : τ (Obj (Hom_cat A x1 x0)), Obj (Hom_cat B y1 y0))
      (@iso_evidence_from A x0 x1 iA)
      (@iso_evidence_from B y0 y1 iB);

assert [A B : Cat]
  [x0 x1 : τ (Obj A)]
  [y0 y1 : τ (Obj B)]
  (iA : τ (IsoEvidence A x0 x1))
  (iB : τ (IsoEvidence B y0 y1)) ⊢
  sigma_Fst
    (@iso_evidence_path
      (Product_cat A B)
      (Struct_sigma x0 y0)
      (Struct_sigma x1 y1)
      (@iso_evidence_product A B x0 x1 y0 y1 iA iB))
  ≡ @iso_evidence_path A x0 x1 iA;

assert [A B : Cat]
  [x0 x1 : τ (Obj A)]
  [y0 y1 : τ (Obj B)]
  (iA : τ (IsoEvidence A x0 x1))
  (iB : τ (IsoEvidence B y0 y1)) ⊢
  sigma_Snd
    (@iso_evidence_path
      (Product_cat A B)
      (Struct_sigma x0 y0)
      (Struct_sigma x1 y1)
      (@iso_evidence_product A B x0 x1 y0 y1 iA iB))
  ≡ @const_pathover
      (Obj A)
      (Obj B)
      x0
      x1
      y0
      y1
      (@iso_evidence_path A x0 x1 iA)
      (@iso_evidence_path B y0 y1 iB);

assert [A B : Cat]
  [x0 x1 : τ (Obj A)]
  [y0 y1 : τ (Obj B)]
  (pA : τ (x0 = x1))
  (pB : τ (@PathOver (Obj A) (λ _ : τ (Obj A), Obj B) x0 x1 pA y0 y1)) ⊢
  @idtoiso_cat
    (Product_cat A B)
    (Struct_sigma x0 y0)
    (Struct_sigma x1 y1)
    (@Struct_sigma
      (@= (Obj A) x0 x1)
      (λ p : τ (@= (Obj A) x0 x1),
        @PathOver (Obj A) (λ _ : τ (Obj A), Obj B) x0 x1 p y0 y1)
      pA
      pB)
  ≡ @iso_evidence_product
      A
      B
      x0
      x1
      y0
      y1
      (@idtoiso_cat A x0 x1 pA)
      (@idtoiso_cat
        B
        y0
        y1
        (@const_pathover_path
          (Obj A)
          (Obj B)
          x0
          x1
          y0
          y1
          pA
          pB));

assert [A B : Cat]
  (x : τ (Obj A))
  (y : τ (Obj B)) ⊢
  @idtoiso_cat
    (Product_cat A B)
    (Struct_sigma x y)
    (Struct_sigma x y)
    (@Struct_sigma
      (@= (Obj A) x x)
      (λ p : τ (@= (Obj A) x x),
        @PathOver (Obj A) (λ _ : τ (Obj A), Obj B) x x p y y)
      (eq_refl x)
      (@pathover_refl (Obj A) (λ _ : τ (Obj A), Obj B) x y))
  ≡ @iso_evidence_refl
      (Product_cat A B)
      (Struct_sigma x y);

assert [A B : Cat]
  [x0 x1 : τ (Obj A)]
  [y0 y1 : τ (Obj B)]
  (eA : τ (OmegaEquiv A x0 x1))
  (eB : τ (OmegaEquiv B y0 y1)) ⊢
  @omega_equiv_product A B x0 x1 y0 y1 eA eB
  : τ (OmegaEquiv
      (Product_cat A B)
      (Struct_sigma x0 y0)
      (Struct_sigma x1 y1));

assert [A B : Cat]
  [x0 x1 : τ (Obj A)]
  [y0 y1 : τ (Obj B)]
  (eA : τ (OmegaEquiv A x0 x1))
  (eB : τ (OmegaEquiv B y0 y1)) ⊢
  sigma_Fst
    (@omega_equiv_to
      (Product_cat A B)
      (Struct_sigma x0 y0)
      (Struct_sigma x1 y1)
      (@omega_equiv_product A B x0 x1 y0 y1 eA eB))
  ≡ @omega_equiv_to A x0 x1 eA;

assert [A B : Cat]
  [x0 x1 : τ (Obj A)]
  [y0 y1 : τ (Obj B)]
  (eA : τ (OmegaEquiv A x0 x1))
  (eB : τ (OmegaEquiv B y0 y1)) ⊢
  sigma_Snd
    (@omega_equiv_to
      (Product_cat A B)
      (Struct_sigma x0 y0)
      (Struct_sigma x1 y1)
      (@omega_equiv_product A B x0 x1 y0 y1 eA eB))
  ≡ @omega_equiv_to B y0 y1 eB;

assert [A B : Cat]
  [x0 x1 : τ (Obj A)]
  [y0 y1 : τ (Obj B)]
  (eA : τ (OmegaEquiv A x0 x1))
  (eB : τ (OmegaEquiv B y0 y1)) ⊢
  sigma_Fst
    (@omega_equiv_left_inv
      (Product_cat A B)
      (Struct_sigma x0 y0)
      (Struct_sigma x1 y1)
      (@omega_equiv_product A B x0 x1 y0 y1 eA eB))
  ≡ @omega_equiv_left_inv A x0 x1 eA;

assert [A B : Cat]
  [x0 x1 : τ (Obj A)]
  [y0 y1 : τ (Obj B)]
  (eA : τ (OmegaEquiv A x0 x1))
  (eB : τ (OmegaEquiv B y0 y1)) ⊢
  sigma_Snd
    (@omega_equiv_right_inv
      (Product_cat A B)
      (Struct_sigma x0 y0)
      (Struct_sigma x1 y1)
    (@omega_equiv_product A B x0 x1 y0 y1 eA eB))
  ≡ @omega_equiv_right_inv B y0 y1 eB;

assert [A B : Cat]
  [x0 x1 : τ (Obj A)]
  [y0 y1 : τ (Obj B)]
  (eA : τ (OmegaEquiv A x0 x1))
  (eB : τ (OmegaEquiv B y0 y1)) ⊢
  sigma_Fst
    (@omega_equiv_path
      (Product_cat A B)
      (Struct_sigma x0 y0)
      (Struct_sigma x1 y1)
      (@omega_equiv_product A B x0 x1 y0 y1 eA eB))
  ≡ @omega_equiv_path A x0 x1 eA;

assert [A B : Cat]
  [x0 x1 : τ (Obj A)]
  [y0 y1 : τ (Obj B)]
  (eA : τ (OmegaEquiv A x0 x1))
  (eB : τ (OmegaEquiv B y0 y1)) ⊢
  sigma_Snd
    (@omega_equiv_path
      (Product_cat A B)
      (Struct_sigma x0 y0)
      (Struct_sigma x1 y1)
      (@omega_equiv_product A B x0 x1 y0 y1 eA eB))
  ≡ @const_pathover
      (Obj A)
      (Obj B)
      x0
      x1
      y0
      y1
      (@omega_equiv_path A x0 x1 eA)
      (@omega_equiv_path B y0 y1 eB);

assert [A B : Cat]
  [x0 x1 : τ (Obj A)]
  [y0 y1 : τ (Obj B)]
  (pA : τ (x0 = x1))
  (pB : τ (@PathOver (Obj A) (λ _ : τ (Obj A), Obj B) x0 x1 pA y0 y1)) ⊢
  @idtoequiv_cat
    (Product_cat A B)
    (Struct_sigma x0 y0)
    (Struct_sigma x1 y1)
    (@Struct_sigma
      (@= (Obj A) x0 x1)
      (λ p : τ (@= (Obj A) x0 x1),
        @PathOver (Obj A) (λ _ : τ (Obj A), Obj B) x0 x1 p y0 y1)
      pA
      pB)
  ≡ @omega_equiv_product
      A
      B
      x0
      x1
      y0
      y1
      (@idtoequiv_cat A x0 x1 pA)
      (@idtoequiv_cat
        B
        y0
        y1
        (@const_pathover_path
          (Obj A)
          (Obj B)
          x0
          x1
          y0
          y1
          pA
          pB));

assert [A B : Cat]
  (x : τ (Obj A))
  (y : τ (Obj B)) ⊢
  @idtoequiv_cat
    (Product_cat A B)
    (Struct_sigma x y)
    (Struct_sigma x y)
    (@Struct_sigma
      (@= (Obj A) x x)
      (λ p : τ (@= (Obj A) x x),
        @PathOver (Obj A) (λ _ : τ (Obj A), Obj B) x x p y y)
      (eq_refl x)
      (@pathover_refl (Obj A) (λ _ : τ (Obj A), Obj B) x y))
  ≡ @omega_equiv_refl
      (Product_cat A B)
      (Struct_sigma x y);

assert [A B : Cat]
  (x : τ (Obj A))
  (y : τ (Obj B)) ⊢
  @omega_equiv_product
    A
    B
    x
    x
    y
    y
    (@omega_equiv_refl A x)
    (@omega_equiv_refl B y)
  ≡ @omega_equiv_refl
      (Product_cat A B)
      (Struct_sigma x y);

assert [A B : Cat]
  [x0 x1 : τ (Obj A)]
  [y0 y1 : τ (Obj B)]
  (eA : τ (OmegaEquiv A x0 x1))
  (eB : τ (OmegaEquiv B y0 y1)) ⊢
  @omega_equiv_left_cell
    (Product_cat A B)
    (Struct_sigma x0 y0)
    (Struct_sigma x1 y1)
    (@omega_equiv_product A B x0 x1 y0 y1 eA eB)
  ≡ @omega_equiv_product
      (Hom_cat A x0 x0)
      (Hom_cat B y0 y0)
      (@comp_fapp0
        A
        x0
        x1
        x0
        (@omega_equiv_left_inv A x0 x1 eA)
        (@omega_equiv_to A x0 x1 eA))
      (@id A x0)
      (@comp_fapp0
        B
        y0
        y1
        y0
        (@omega_equiv_left_inv B y0 y1 eB)
        (@omega_equiv_to B y0 y1 eB))
      (@id B y0)
      (@omega_equiv_left_cell A x0 x1 eA)
      (@omega_equiv_left_cell B y0 y1 eB);

assert [A B : Cat]
  [x0 x1 : τ (Obj A)]
  [y0 y1 : τ (Obj B)]
  (eA : τ (OmegaEquiv A x0 x1))
  (eB : τ (OmegaEquiv B y0 y1)) ⊢
  @omega_equiv_right_cell
    (Product_cat A B)
    (Struct_sigma x0 y0)
    (Struct_sigma x1 y1)
    (@omega_equiv_product A B x0 x1 y0 y1 eA eB)
  ≡ @omega_equiv_product
      (Hom_cat A x1 x1)
      (Hom_cat B y1 y1)
      (@comp_fapp0
        A
        x1
        x0
        x1
        (@omega_equiv_to A x0 x1 eA)
        (@omega_equiv_right_inv A x0 x1 eA))
      (@id A x1)
      (@comp_fapp0
        B
        y1
        y0
        y1
        (@omega_equiv_to B y0 y1 eB)
        (@omega_equiv_right_inv B y0 y1 eB))
      (@id B y1)
      (@omega_equiv_right_cell A x0 x1 eA)
      (@omega_equiv_right_cell B y0 y1 eB);

assert [C : Cat] (x : τ (Obj C)) ⊢
  @idtoequiv_cat C x x (eq_refl x)
  ≡ @omega_equiv_refl C x;

assert [C : Cat] (x : τ (Obj C)) ⊢
  @omega_equiv_path C x x (@omega_equiv_refl C x)
  ≡ @eq_refl (Obj C) x;

assert [C : Cat] (x : τ (Obj C)) ⊢
  omega_equiv_to (@idtoequiv_cat C x x (eq_refl x))
  ≡ @id C x;

assert [C : Cat]
  [x y : τ (Obj C)]
  (e : τ (OmegaEquiv C x y)) ⊢
  @equivtoid_cat C (cat_univalence C) x y e
  : τ (x = y);

assert ⊢
  cat_univalence Cat_cat
  : τ (CatUnivalence Cat_cat);

assert ⊢
  cat_univalence_by_decoder Cat_cat
  : τ (CatUnivalenceByDecoder Cat_cat);

assert [a b : Grpd] (f : τ a → τ b) (x : τ a) ⊢
  @eq_ap a b f x x (eq_refl x)
  ≡ eq_refl (f x);

assert [a : Grpd] (x : τ a) ⊢
  @eq_sym a x x (eq_refl x)
  ≡ eq_refl x;

// Groupoid path-over and dependent path action.
assert [A : Grpd]
  (P : τ A → Grpd)
  (x : τ A)
  (u v : τ (P x)) ⊢
  @PathOver A P x x (eq_refl x) u v
  ≡ u = v;

assert [A : Grpd]
  [P : τ A → Grpd]
  (f : Π x : τ A, τ (P x))
  (x : τ A) ⊢
  @eq_apd A P f x x (eq_refl x)
  ≡ eq_refl (f x);

assert [A : Grpd]
  (y : τ A)
  (P : Π x : τ A, τ (x = y) → Grpd)
  (u : τ (P y (eq_refl y))) ⊢
  @ind_eqr A y P u y (eq_refl y)
  ≡ u;

assert [A : Grpd]
  (x : τ A)
  (P : τ A → Grpd)
  (u : τ (P x)) ⊢
  @ind_eq A x x (eq_refl x) P u
  ≡ u;

assert [A : Grpd]
  [P : τ A → Grpd]
  (Q : @τΣ_ A P → Grpd)
  (c : Π x : τ A, Π u : τ (P x), τ (Q (@Struct_sigma A P x u)))
  (x : τ A)
  (u : τ (P x)) ⊢
  @sigma_ind A P Q c (@Struct_sigma A P x u)
  ≡ c x u;

assert [A : Grpd]
  [P : τ A → Grpd]
  (u : @τΣ_ A P) ⊢
  sigma_path_base (sigma_path_refl u)
  ≡ eq_refl (sigma_Fst u);

assert [A : Grpd]
  [P : τ A → Grpd]
  (u : @τΣ_ A P) ⊢
  sigma_path_fibre (sigma_path_refl u)
  ≡ @pathover_refl A P (sigma_Fst u) (sigma_Snd u);

assert [A : Grpd]
  [P : τ A → Grpd]
  (u : @τΣ_ A P) ⊢
  @sigma_path_encode A P u u (eq_refl u)
  ≡ sigma_path_refl u;

assert [A : Grpd]
  [P : τ A → Grpd]
  (x : τ A)
  (a b : τ (P x))
  (q : τ (a = b)) ⊢
  @sigma_path_intro A P x x a b (eq_refl x) q
  ≡ @eq_ap
      (P x)
      (@Σ_ A P)
      (λ z : τ (P x), @Struct_sigma A P x z)
      a
      b
      q;

assert [A : Grpd]
  [P : τ A → Grpd]
  (x : τ A)
  (a : τ (P x)) ⊢
  sigma_path_decode (sigma_path_refl (@Struct_sigma A P x a))
  ≡ @eq_refl (@Σ_ A P) (@Struct_sigma A P x a);

assert [A : Grpd]
  [P : τ A → Grpd]
  (u : @τΣ_ A P) ⊢
  eq_refl (@eq_refl (@Σ_ A P) u)
  : τ (@eq_refl (@Σ_ A P) u = sigma_path_refl u);

assert [A : Grpd]
  [P : τ A → Grpd]
  (u : @τΣ_ A P) ⊢
  eq_refl (@eq_refl (@Σ_ A P) u)
  : τ (sigma_path_refl u = @eq_refl (@Σ_ A P) u);

assert [A : Grpd]
  [B : τ A → Grpd]
  (f : Π x : τ A, τ (B x))
  (x : τ A) ⊢
  @eq_refl (@Pi_grpd A B) f x x (eq_refl x)
  ≡ eq_refl (f x);

assert [A : Grpd]
  [B : τ A → Grpd]
  (f : Π x : τ A, τ (B x))
  (x0 x1 : τ A)
  (p : τ (x0 = x1)) ⊢
  @eq_refl (@Pi_grpd A B) f x0 x1 p
  ≡ @eq_apd A B f x0 x1 p;

assert [A : Grpd]
  [B : τ A → Grpd]
  (f : Π x : τ A, τ (B x))
  (x0 x1 : τ A)
  (p : τ (x0 = x1)) ⊢
  pi_path_refl f x0 x1 p
  ≡ @eq_apd A B f x0 x1 p;

assert [A : Grpd]
  [B : τ A → Grpd]
  (f : Π x : τ A, τ (B x)) ⊢
  @eq_refl (@Pi_grpd A B) f
  ≡ @eq_apd A B f;

assert [A : Grpd]
  [B : τ A → Grpd] ⊢
  @eq_refl (@Pi_grpd A B)
  ≡ @eq_apd A B;

assert [A : Grpd]
  [B : τ A → Grpd]
  (f : Π x : τ A, τ (B x)) ⊢
  pi_path_refl f
  ≡ @eq_refl (@Pi_grpd A B) f;

assert [A : Grpd]
  [B : τ A → Grpd]
  (f : Π x : τ A, τ (B x)) ⊢
  @pi_path_encode A B f f (eq_refl f)
  ≡ pi_path_refl f;

assert [A : Grpd]
  [B : τ A → Grpd]
  (f g : Π x : τ A, τ (B x)) ⊢
  @= (@Pi_grpd A B) f g
  ≡ @PiPathView A B f g;

assert [A : Grpd]
  [B : τ A → Grpd]
  (f g : Π x : τ A, τ (B x))
  (w : τ (@PiPathView A B f g)) ⊢
  w
  : τ (@= (@Pi_grpd A B) f g);

assert [A : Grpd]
  [B : τ A → Grpd]
  (f : Π x : τ A, τ (B x))
  (M : τ (@Pi_grpd A B) → Grpd)
  (u : τ (M f)) ⊢
  @ind_eq
    (@Pi_grpd A B)
    f
    f
    (@eq_refl (@Pi_grpd A B) f)
    M
    u
  ≡ u;

// Groupoid-level Pi and contractible-fibre type equivalence infrastructure.
assert [A : Grpd] [B : τ A → Grpd] ⊢
  τ (@Pi_grpd A B) ≡ Π x : τ A, τ (B x);

assert [A B : Grpd] ⊢
  τ (Function_grpd A B) ≡ (τ A → τ B);

assert [A B : Grpd]
  (e : τ (TypeEquiv A B))
  (a : τ A) ⊢
  type_equiv_to e a
  : τ B;

assert [A B : Grpd]
  (e : τ (TypeEquiv A B))
  (b : τ B) ⊢
  type_equiv_from e b
  : τ A;

assert [A B : Grpd]
  (e : τ (TypeEquiv A B))
  (b : τ B) ⊢
  type_equiv_right e b
  : τ (type_equiv_to e (type_equiv_from e b) = b);

assert [A B : Grpd]
  (e : τ (TypeEquiv A B))
  (a : τ A) ⊢
  type_equiv_left e a
  : τ (type_equiv_from e (type_equiv_to e a) = a);

assert [A : Grpd] ⊢
  type_equiv_to (@type_equiv_refl A)
  ≡ λ x : τ A, x;

assert [A : Grpd] (a : τ A) ⊢
  type_equiv_from (@type_equiv_refl A) a
  ≡ a;

assert [A : Grpd] (a : τ A) ⊢
  type_equiv_right (@type_equiv_refl A) a
  ≡ eq_refl a;

assert [A : Grpd] (a : τ A) ⊢
  type_equiv_left (@type_equiv_refl A) a
  ≡ eq_refl a;

assert [A : Grpd] (a : τ A) ⊢
  @coe_grpd A A (eq_refl A) a
  ≡ a;

assert [A : Grpd] ⊢
  @idtoequiv_grpd A A (eq_refl A)
  ≡ @type_equiv_refl A;

assert [A : Grpd] ⊢
  @grpd_equiv_path A A (@type_equiv_refl A)
  ≡ @eq_refl Grpd_grpd A;

assert [A A' B B' : Grpd] ⊢
  @ProductGrpdPathView A A' B B'
  ≡ `Σ_ pA : τ (@= Grpd_grpd A A'),
     @PathOver Grpd_grpd (λ _ : Grpd, Grpd_grpd) A A' pA B B';

assert [A A' B B' : Grpd]
  (pA : τ (@= Grpd_grpd A A'))
  (pB : τ (@PathOver Grpd_grpd (λ _ : Grpd, Grpd_grpd) A A' pA B B')) ⊢
  @product_grpd_path A A' B B' pA pB
  : τ (@= Grpd_grpd (Product_grpd A B) (Product_grpd A' B'));

assert [A A' B B' : Grpd]
  (eA : τ (TypeEquiv A A'))
  (eB : τ (TypeEquiv B B')) ⊢
  @grpd_equiv_path
      (Product_grpd A B)
      (Product_grpd A' B')
      (@product_type_equiv A A' B B' eA eB)
  ≡ @product_grpd_path
      A
      A'
      B
      B'
      (@grpd_equiv_path A A' eA)
      (@const_pathover
        Grpd_grpd
        Grpd_grpd
        A
        A'
        B
        B'
        (@grpd_equiv_path A A' eA)
        (@grpd_equiv_path B B' eB));

assert [A A' B B' : Grpd]
  (pA : τ (@= Grpd_grpd A A'))
  (pB : τ (@PathOver Grpd_grpd (λ _ : Grpd, Grpd_grpd) A A' pA B B')) ⊢
  @idtoequiv_grpd
    (Product_grpd A B)
    (Product_grpd A' B')
    (@product_grpd_path A A' B B' pA pB)
  ≡ @product_type_equiv
      A
      A'
      B
      B'
      (@idtoequiv_grpd A A' pA)
      (@idtoequiv_grpd
        B
        B'
        (@const_pathover_path
          Grpd_grpd
          Grpd_grpd
          A
          A'
          B
          B'
          pA
          pB));

assert [A B : Grpd] ⊢
  @idtoequiv_grpd
    (Product_grpd A B)
    (Product_grpd A B)
    (@product_grpd_path
      A
      A
      B
      B
      (eq_refl A)
      (@pathover_refl Grpd_grpd (λ _ : Grpd, Grpd_grpd) A B))
  ≡ @product_type_equiv
      A
      A
      B
      B
      (@type_equiv_refl A)
      (@type_equiv_refl B);

assert ⊢
  grpd_univalence_by_decoder
  : τ GrpdUnivalenceByDecoder;

assert [A : Grpd] (a : τ A) ⊢
  type_equiv_to (@idtoequiv_grpd A A (eq_refl A)) a
  ≡ a;

assert (U : τ GrpdUnivalence) [A B : Grpd]
  (e : τ (TypeEquiv A B)) ⊢
  @ua_grpd U A B e
  : τ (@= Grpd_grpd A B);

assert (U : τ GrpdUnivalence)
  [A B : Grpd]
  (e : τ (TypeEquiv A B))
  (a : τ A) ⊢
  @coe_grpd A B (@ua_grpd U A B e) a
  ≡ type_equiv_to e a;

// Constructor-specific computational-univalence skeleton.
assert [A B : Grpd] ⊢
  τ (Product_grpd A B)
  ≡ @τΣ_ A (λ _ : τ A, B);

assert [A : Grpd]
  [P : τ A → Grpd]
  (u v : @τΣ_ A P) ⊢
  @= (@Σ_ A P) u v
  ≡ @SigmaPathView A P u v;

assert [A B : Grpd]
  (p q : τ (Product_grpd A B)) ⊢
  @= (Product_grpd A B) p q
  ≡ @SigmaPathView A (λ _ : τ A, B) p q;

assert [A B : Grpd]
  (x : τ A)
  (y : τ B) ⊢
  sigma_Fst (@eq_refl (Product_grpd A B) (@Product_pair_grpd A B x y))
  ≡ eq_refl x;

assert [A B : Grpd]
  (x : τ A)
  (y : τ B) ⊢
  sigma_Snd (@eq_refl (Product_grpd A B) (@Product_pair_grpd A B x y))
  ≡ @pathover_refl A (λ _ : τ A, B) x y;

assert [A B : Grpd]
  [x : τ A]
  [u v : τ B]
  (q : τ (u = v)) ⊢
  @const_pathover A B x x u v (eq_refl x) q
  ≡ q;

assert [A B : Grpd]
  [x : τ A]
  [u v : τ B]
  (q : τ (@PathOver A (λ _ : τ A, B) x x (eq_refl x) u v)) ⊢
  @const_pathover_path A B x x u v (eq_refl x) q
  ≡ q;

assert [A B : Grpd]
  (x : τ A)
  (y : τ B)
  (M : τ (Product_grpd A B) → Grpd)
  (u : τ (M (@Product_pair_grpd A B x y))) ⊢
  @ind_eq
    (Product_grpd A B)
    (@Product_pair_grpd A B x y)
    (@Product_pair_grpd A B x y)
    (@eq_refl (Product_grpd A B) (@Product_pair_grpd A B x y))
    M
    u
  ≡ u;

assert [A A' B B' : Grpd]
  (eA : τ (TypeEquiv A A'))
  (eB : τ (TypeEquiv B B'))
  (x : τ A)
  (y : τ B) ⊢
  type_equiv_to (@product_type_equiv A A' B B' eA eB)
    (@Product_pair_grpd A B x y)
  ≡ @Product_pair_grpd A' B'
      (type_equiv_to eA x)
      (type_equiv_to eB y);

assert (U : τ GrpdUnivalence)
  [A A' B B' : Grpd]
  (eA : τ (TypeEquiv A A'))
  (eB : τ (TypeEquiv B B'))
  (x : τ A)
  (y : τ B) ⊢
  @coe_grpd
    (Product_grpd A B)
    (Product_grpd A' B')
    (@ua_grpd U
      (Product_grpd A B)
      (Product_grpd A' B')
      (@product_type_equiv A A' B B' eA eB))
    (@Product_pair_grpd A B x y)
  ≡ @Product_pair_grpd A' B'
      (type_equiv_to eA x)
      (type_equiv_to eB y);

assert [A : Grpd]
  [P Q : τ A → Grpd]
  (e : Π x : τ A, τ (TypeEquiv (P x) (Q x)))
  (x : τ A)
  (u : τ (P x)) ⊢
  type_equiv_to (@sigma_type_equiv_same_base A P Q e)
    (@Struct_sigma A P x u)
  ≡ @Struct_sigma A Q x (type_equiv_to (e x) u);

assert (U : τ GrpdUnivalence)
  [A : Grpd]
  [P Q : τ A → Grpd]
  (e : Π x : τ A, τ (TypeEquiv (P x) (Q x)))
  (x : τ A)
  (u : τ (P x)) ⊢
  @coe_grpd
    (@Σ_ A P)
    (@Σ_ A Q)
    (@ua_grpd U (@Σ_ A P) (@Σ_ A Q)
      (@sigma_type_equiv_same_base A P Q e))
    (@Struct_sigma A P x u)
  ≡ @Struct_sigma A Q x (type_equiv_to (e x) u);

assert [A : Grpd]
  [B C : τ A → Grpd]
  (e : Π x : τ A, τ (TypeEquiv (B x) (C x)))
  (f : τ (@Pi_grpd A B))
  (x : τ A) ⊢
  type_equiv_to (@pi_type_equiv_same_domain A B C e) f x
  ≡ type_equiv_to (e x) (f x);

assert (U : τ GrpdUnivalence)
  [A : Grpd]
  [B C : τ A → Grpd]
  (e : Π x : τ A, τ (TypeEquiv (B x) (C x)))
  (f : τ (@Pi_grpd A B))
  (x : τ A) ⊢
  @coe_grpd
    (@Pi_grpd A B)
    (@Pi_grpd A C)
    (@ua_grpd U (@Pi_grpd A B) (@Pi_grpd A C)
      (@pi_type_equiv_same_domain A B C e))
    f
    x
  ≡ type_equiv_to (e x) (f x);

// Core inclusion/path-to-arrow is functor-owned. Composition is checked
// through the generic fapp1_fapp0 composition rule, not a specialized rule.
assert [C : Cat] (x : τ (Obj C)) ⊢
  @path_to_hom C x x (eq_refl x)
  ≡ @id C x;

assert [C : Cat]
  [x y z : τ (Obj C)]
  (p : τ (x = y))
  (q : τ (y = z)) ⊢
  @comp_fapp0 C x y z
    (@path_to_hom C y z q)
    (@path_to_hom C x y p)
  ≡ @path_to_hom C x z
      (@eq_trans (Obj C) x y z p q);

assert [C : Cat] [w x y z : τ (Obj C)]
  (h : τ (Hom C y z))
  (g : τ (Hom C x y))
  (f : τ (Hom C w x)) ⊢
  @comp_assoc C w x y z h g f
  ≡ eq_refl
      (@comp_fapp0 C w y z h
        (@comp_fapp0 C w x y g f));

assert [C : Cat] [x y z : τ (Obj C)]
  (j : τ (IsoEvidence C y z))
  (i : τ (IsoEvidence C x y)) ⊢
  @iso_evidence_to C x z
    (@iso_evidence_comp C x y z j i)
  ≡ @comp_fapp0 C x y z
      (@iso_evidence_to C y z j)
      (@iso_evidence_to C x y i);

assert [C : Cat] [x y z : τ (Obj C)]
  (j : τ (IsoEvidence C y z))
  (i : τ (IsoEvidence C x y)) ⊢
  @iso_evidence_from C x z
    (@iso_evidence_comp C x y z j i)
  ≡ @comp_fapp0 C z y x
      (@iso_evidence_from C x y i)
      (@iso_evidence_from C y z j);

assert [C D : Cat] (F : τ (Functor C D))
  [x y : τ (Obj C)]
  (i : τ (IsoEvidence C x y)) ⊢
  @iso_evidence_to
    D
    (@fapp0 C D F x)
    (@fapp0 C D F y)
    (@iso_evidence_fmap C D F x y i)
  ≡ @fapp1_fapp0 C D F x y
      (@iso_evidence_to C x y i);

assert [C D : Cat] (F : τ (Functor C D))
  [x y : τ (Obj C)]
  (i : τ (IsoEvidence C x y)) ⊢
  @iso_evidence_from
    D
    (@fapp0 C D F x)
    (@fapp0 C D F y)
    (@iso_evidence_fmap C D F x y i)
  ≡ @fapp1_fapp0 C D F y x
      (@iso_evidence_from C x y i);

// From emdash3_2.lp:446.
assert ⊢ τ (Obj Grpd_cat) ≡ Grpd;

// From emdash3_2.lp:447.
assert ⊢ τ (Obj Cat_cat) ≡ Cat;

// From emdash3_2.lp:448.
assert (A B : Cat) ⊢ Hom_cat Cat_cat A B ≡ Functor_cat A B;

// From emdash3_2.lp:539.
assert [K : Cat] ⊢ Functor_cat K Cat_cat ≡ Catd_cat K;

// From emdash3_2.lp:540.
assert [K : Cat] (E D : τ (Catd K)) ⊢
  Hom_cat (Catd_cat K) E D ≡ Functord_cat E D;

// From emdash3_2.lp:542.
assert [K : Cat] [E D : τ (Catd K)] (FF GG : τ (Functord E D)) ⊢
  Hom_cat (Functord_cat E D) FF GG ≡ Transfd_cat FF GG;

// From emdash3_2.lp:544.
assert [K : Cat] (E D : τ (Catd K)) (FF : τ (Functord E D)) ⊢
  @id (@Functord_cat K E D) FF
    ≡ @id_transfd K E D FF;

// From emdash3_2.lp:965.
assert [A B : Cat] (F : τ (Functor B A)) (W : τ (Obj A)) (y : τ (Obj B)) ⊢
  @fapp0 B Cat_cat (@hom_ A B F W) y ≡ Hom_cat A W (@fapp0 B A F y);

// From emdash3_2.lp:968.
assert [A B : Cat] (F : τ (Functor B A)) (W : τ (Obj A)) (x : τ (Obj (Op_cat B))) ⊢
  @fapp0 (Op_cat B) Cat_cat (@hom_con A W B F) x ≡ Hom_cat A (@fapp0 B A F x) W;

// From emdash3_2.lp:971.
assert [A B : Cat] (F : τ (Functor B A)) (W : τ (Obj (Op_cat A))) ⊢
  @fapp0 (Op_cat A) (Catd_cat B) (@hom_int A B F) W
    ≡ @hom_ A B F W;

// From emdash3_2.lp:975.
assert [A B : Cat] (F : τ (Functor B A)) (X : τ (Obj (Op_cat A))) (Y : τ (Obj B)) ⊢
  @fapp0 B Cat_cat (@fapp0 (Op_cat A) (Catd_cat B) (@hom_int A B F) X) Y
    ≡ Hom_cat A X (fapp0 F Y);

// From emdash3_2.lp:979.
assert [A B : Cat] (F : τ (Functor B A)) (W : τ (Obj A))
  (X Y : τ (Obj B)) (f : τ (Hom B X Y)) (g : τ (Hom A W (fapp0 F X))) ⊢
  fapp0 (@fapp1_fapp0 B Cat_cat (@hom_ A B F W) X Y f) g
    ≡ @comp_fapp0 A W (fapp0 F X) (fapp0 F Y)
        (fapp0 (@fapp1_func B A F X Y) f) g;

assert [A B : Cat] (F : τ (Functor B A)) (W : τ (Obj A))
  (X Y : τ (Obj B)) (f : τ (Hom B X Y))
  (g : τ (Hom A W (@fapp0 B A F X))) ⊢
  @hom_postcomp_fapp1_fapp0
    A
    B
    F
    W
    X
    Y
    f
    g
    g
    (@id (Hom_cat A W (@fapp0 B A F X)) g)
  ≡ @id
      (Hom_cat A W (@fapp0 B A F Y))
      (@comp_fapp0
        A
        W
        (@fapp0 B A F X)
        (@fapp0 B A F Y)
        (@fapp1_fapp0 B A F X Y f)
        g);

// From emdash3_2.lp:985.
assert [A : Cat] (x y z : τ (Obj A))
  (p : τ (Hom A x y)) (q : τ (Hom A y z)) ⊢
  @fapp0
    (Hom_cat A y z)
    (Hom_cat A x z)
    (@hom_precomp_along_func A A (@id_func A) z x y p)
    q
    ≡ @comp_fapp0 A x y z q p;

assert [A B : Cat] (F : τ (Functor A B)) (z : τ (Obj B))
  (w x : τ (Obj A)) (h : τ (Hom A w x))
  (g : τ (Hom B (@fapp0 A B F x) z)) ⊢
  fapp0 (@hom_precomp_along_func A B F z w x h) g
    ≡ @comp_fapp0 B
        (@fapp0 A B F w)
        (@fapp0 A B F x)
        z
        g
        (@fapp1_fapp0 A B F w x h);

// Generalized precomposition projection ladder.
assert [A B : Cat] (F : τ (Functor A B)) (z : τ (Obj B))
  (w x : τ (Obj A)) (h : τ (Hom A w x)) ⊢
  fapp0 (@hom_precomp_along_tele_func A B F z w x) h
    ≡ @hom_precomp_along_func A B F z w x h;

assert [A B : Cat] (F : τ (Functor A B)) (z : τ (Obj B))
  (w x : τ (Obj A)) (h : τ (Hom A w x)) ⊢
  @fapp1_fapp0
    (Op_cat A)
    Cat_cat
    (@hom_ (Op_cat B) (Op_cat A) (@Op_func A B F) z)
    x
    w
    h
  ≡ @hom_precomp_along_func A B F z w x h;

assert [A B : Cat] (F : τ (Functor A B)) (z : τ (Obj B))
  (w x : τ (Obj A)) (h : τ (Hom A w x))
  (g k : τ (Hom B (@fapp0 A B F x) z)) ⊢
  @fapp1_func
    (Hom_cat B (@fapp0 A B F x) z)
    (Hom_cat B (@fapp0 A B F w) z)
    (@hom_precomp_along_func A B F z w x h)
    g
    k
  ≡ @hom_precomp_along_fapp1_func A B F z w x h g k;

assert [A B : Cat] (F : τ (Functor A B)) (z : τ (Obj B))
  (w x : τ (Obj A)) (h : τ (Hom A w x))
  (g k : τ (Hom B (@fapp0 A B F x) z))
  (alpha : τ (Hom (Hom_cat B (@fapp0 A B F x) z) g k)) ⊢
  @fapp1_fapp0
    (Hom_cat B (@fapp0 A B F x) z)
    (Hom_cat B (@fapp0 A B F w) z)
    (@hom_precomp_along_func A B F z w x h)
    g
    k
    alpha
  ≡ @hom_precomp_along_fapp1_fapp0 A B F z w x h g k alpha;

assert [A B : Cat] (F : τ (Functor A B)) (z : τ (Obj B))
  (w x : τ (Obj A)) (h : τ (Hom A w x))
  (g : τ (Hom B (@fapp0 A B F x) z)) ⊢
  @hom_precomp_along_fapp1_fapp0
    A
    B
    F
    z
    w
    x
    h
    g
    g
    (@id (Hom_cat B (@fapp0 A B F x) z) g)
  ≡ @id
      (Hom_cat B (@fapp0 A B F w) z)
      (@comp_fapp0
        B
        (@fapp0 A B F w)
        (@fapp0 A B F x)
        z
        g
        (@fapp1_fapp0 A B F w x h));

// Opposite-specialized postcomposition bridges to precomposition-along after
// projection. Direct head equality over unreduced opposites is intentionally
// not the diagnostic surface.
assert [A B : Cat] (F : τ (Functor A B)) (z : τ (Obj B))
  (w x : τ (Obj A)) (h : τ (Hom A w x)) ⊢
  fapp0
    (@hom_postcomp_tele_func
      (Op_cat B)
      (Op_cat A)
      (@Op_func A B F)
      z
      x
      w)
    h
  ≡ @hom_precomp_along_func A B F z w x h;

assert [A B : Cat] (F : τ (Functor A B)) (z : τ (Obj B))
  (w x : τ (Obj A)) (h : τ (Hom A w x))
  (g : τ (Hom B (@fapp0 A B F x) z)) ⊢
  fapp0
    (@hom_postcomp_func
      (Op_cat B)
      (Op_cat A)
      (@Op_func A B F)
      z
      x
      w
      h)
    g
  ≡ @comp_fapp0
      B
      (@fapp0 A B F w)
      (@fapp0 A B F x)
      z
      g
      (@fapp1_fapp0 A B F w x h);

assert [A B : Cat] (F : τ (Functor A B)) (z : τ (Obj B))
  (w x : τ (Obj A)) (h : τ (Hom A w x))
  (g k : τ (Hom B (@fapp0 A B F x) z))
  (alpha : τ (Hom (Hom_cat B (@fapp0 A B F x) z) g k)) ⊢
  fapp0
    (@hom_postcomp_fapp1_func
      (Op_cat B)
      (Op_cat A)
      (@Op_func A B F)
      z
      x
      w
      h
      g
      k)
    alpha
  ≡ @hom_precomp_along_fapp1_fapp0 A B F z w x h g k alpha;

assert [X Y Z : Cat] (F : τ (Functor X Y)) ⊢
  fapp0 (@comp_cat_con_func_func X Y Z) F
    ≡ @comp_cat_con_func X Y Z F;

assert (F : τ (Functor Cat_cat Cat_cat)) (Z W X : Cat) ⊢
  @hom_precomp_along_tele_func Cat_cat Cat_cat F Z W X
    ≡ @comp_cat_fapp0
        (Functor_cat W X)
        (Functor_cat
          (@fapp0 Cat_cat Cat_cat F W)
          (@fapp0 Cat_cat Cat_cat F X))
        (Functor_cat
          (Functor_cat (@fapp0 Cat_cat Cat_cat F X) Z)
          (Functor_cat (@fapp0 Cat_cat Cat_cat F W) Z))
        (@comp_cat_con_func_func
          (@fapp0 Cat_cat Cat_cat F W)
          (@fapp0 Cat_cat Cat_cat F X)
          Z)
        (@fapp1_func Cat_cat Cat_cat F W X);

assert (F : τ (Functor Cat_cat Cat_cat)) (Z W X : Cat)
  (H : τ (Functor W X)) ⊢
  @hom_precomp_along_func Cat_cat Cat_cat F Z W X H
    ≡ @comp_cat_con_func
        (@fapp0 Cat_cat Cat_cat F W)
        (@fapp0 Cat_cat Cat_cat F X)
        Z
        (@fapp1_fapp0 Cat_cat Cat_cat F W X H);

assert (F : τ (Functor Cat_cat Cat_cat)) (Z W X : Cat)
  (H : τ (Functor W X))
  (G K : τ (Functor (@fapp0 Cat_cat Cat_cat F X) Z)) ⊢
  @fapp1_func
    (Functor_cat (@fapp0 Cat_cat Cat_cat F X) Z)
    (Functor_cat (@fapp0 Cat_cat Cat_cat F W) Z)
    (@hom_precomp_along_func Cat_cat Cat_cat F Z W X H)
    G
    K
  ≡ @comp_cat_con_fapp1_func
      (@fapp0 Cat_cat Cat_cat F W)
      (@fapp0 Cat_cat Cat_cat F X)
      Z
      (@fapp1_fapp0 Cat_cat Cat_cat F W X H)
      G
      K;

assert (F : τ (Functor Cat_cat Cat_cat)) (Z W X : Cat)
  (H : τ (Functor W X))
  (G K : τ (Functor (@fapp0 Cat_cat Cat_cat F X) Z))
  (eta : τ (Transf G K)) ⊢
  @fapp1_fapp0
    (Functor_cat (@fapp0 Cat_cat Cat_cat F X) Z)
    (Functor_cat (@fapp0 Cat_cat Cat_cat F W) Z)
    (@hom_precomp_along_func Cat_cat Cat_cat F Z W X H)
    G
    K
    eta
  ≡ @comp_cat_con_transf
      (@fapp0 Cat_cat Cat_cat F W)
      (@fapp0 Cat_cat Cat_cat F X)
      Z
      (@fapp1_fapp0 Cat_cat Cat_cat F W X H)
      G
      K
      eta;

assert (E : τ (Functor Cat_cat Cat_cat)) (W X Y : Cat) ⊢
  @hom_postcomp_tele_func Cat_cat Cat_cat E W X Y
    ≡ @comp_cat_fapp0
        (Functor_cat X Y)
        (Functor_cat
          (@fapp0 Cat_cat Cat_cat E X)
          (@fapp0 Cat_cat Cat_cat E Y))
        (Functor_cat
          (Functor_cat W (@fapp0 Cat_cat Cat_cat E X))
          (Functor_cat W (@fapp0 Cat_cat Cat_cat E Y)))
        (@comp_cat_cov_func_func
          W
          (@fapp0 Cat_cat Cat_cat E X)
          (@fapp0 Cat_cat Cat_cat E Y))
        (@fapp1_func Cat_cat Cat_cat E X Y);

assert (E : τ (Functor Cat_cat Cat_cat)) (W X Y : Cat)
  (L : τ (Functor X Y)) ⊢
  @hom_postcomp_func Cat_cat Cat_cat E W X Y L
    ≡ @comp_cat_cov_func
        W
        (@fapp0 Cat_cat Cat_cat E X)
        (@fapp0 Cat_cat Cat_cat E Y)
        (@fapp1_fapp0 Cat_cat Cat_cat E X Y L);

assert (E : τ (Functor Cat_cat Cat_cat)) (W X Y : Cat)
  (L : τ (Functor X Y))
  (G K : τ (Functor W (@fapp0 Cat_cat Cat_cat E X))) ⊢
  @fapp1_func
    (Functor_cat W (@fapp0 Cat_cat Cat_cat E X))
    (Functor_cat W (@fapp0 Cat_cat Cat_cat E Y))
    (@hom_postcomp_func Cat_cat Cat_cat E W X Y L)
    G
    K
  ≡ @comp_cat_cov_fapp1_func
      W
      (@fapp0 Cat_cat Cat_cat E X)
      (@fapp0 Cat_cat Cat_cat E Y)
      (@fapp1_fapp0 Cat_cat Cat_cat E X Y L)
      G
      K;

assert (E : τ (Functor Cat_cat Cat_cat)) (W X Y : Cat)
  (L : τ (Functor X Y))
  (G K : τ (Functor W (@fapp0 Cat_cat Cat_cat E X)))
  (eta : τ (Transf G K)) ⊢
  @fapp1_fapp0
    (Functor_cat W (@fapp0 Cat_cat Cat_cat E X))
    (Functor_cat W (@fapp0 Cat_cat Cat_cat E Y))
    (@hom_postcomp_func Cat_cat Cat_cat E W X Y L)
    G
    K
    eta
  ≡ @comp_cat_cov_transf
      W
      (@fapp0 Cat_cat Cat_cat E X)
      (@fapp0 Cat_cat Cat_cat E Y)
      (@fapp1_fapp0 Cat_cat Cat_cat E X Y L)
      G
      K
      eta;

// Higher action of the tele-level postcomposition stable head.
assert [A B : Cat] (F : τ (Functor B A)) (W : τ (Obj A))
  (X Y : τ (Obj B)) (f g : τ (Hom B X Y)) ⊢
  @fapp1_func
    (Hom_cat B X Y)
    (Functor_cat
      (Hom_cat A W (@fapp0 B A F X))
      (Hom_cat A W (@fapp0 B A F Y)))
    (@hom_postcomp_tele_func A B F W X Y)
    f
    g
  ≡ @hom_postcomp_tele_fapp1_func A B F W X Y f g;

assert [A B : Cat] (F : τ (Functor B A)) (W : τ (Obj A))
  (X Y : τ (Obj B)) (f g : τ (Hom B X Y))
  (alpha : τ (Hom (Hom_cat B X Y) f g)) ⊢
  @fapp1_fapp0
    (Hom_cat B X Y)
    (Functor_cat
      (Hom_cat A W (@fapp0 B A F X))
      (Hom_cat A W (@fapp0 B A F Y)))
    (@hom_postcomp_tele_func A B F W X Y)
    f
    g
    alpha
  ≡ @hom_postcomp_tele_fapp1_fapp0 A B F W X Y f g alpha;

assert (E : τ (Functor Cat_cat Cat_cat)) (W X Y : Cat)
  (G H : τ (Functor X Y)) ⊢
  @hom_postcomp_tele_fapp1_func Cat_cat Cat_cat E W X Y G H
  ≡ @fapp1_func
      (Functor_cat X Y)
      (Functor_cat
        (Functor_cat W (@fapp0 Cat_cat Cat_cat E X))
        (Functor_cat W (@fapp0 Cat_cat Cat_cat E Y)))
      (@comp_cat_fapp0
        (Functor_cat X Y)
        (Functor_cat
          (@fapp0 Cat_cat Cat_cat E X)
          (@fapp0 Cat_cat Cat_cat E Y))
        (Functor_cat
          (Functor_cat W (@fapp0 Cat_cat Cat_cat E X))
          (Functor_cat W (@fapp0 Cat_cat Cat_cat E Y)))
        (@comp_cat_cov_func_func
          W
          (@fapp0 Cat_cat Cat_cat E X)
          (@fapp0 Cat_cat Cat_cat E Y))
        (@fapp1_func Cat_cat Cat_cat E X Y))
      G
      H;

assert (E : τ (Functor Cat_cat Cat_cat)) (W X Y : Cat)
  (G H : τ (Functor X Y)) (eta : τ (Transf G H)) ⊢
  @hom_postcomp_tele_fapp1_fapp0 Cat_cat Cat_cat E W X Y G H eta
  ≡ @comp_cat_cov_func_func_transf
      W
      (@fapp0 Cat_cat Cat_cat E X)
      (@fapp0 Cat_cat Cat_cat E Y)
      (@fapp1_fapp0 Cat_cat Cat_cat E X Y G)
      (@fapp1_fapp0 Cat_cat Cat_cat E X Y H)
      (@fapp1_fapp0
        (Functor_cat X Y)
        (Functor_cat
          (@fapp0 Cat_cat Cat_cat E X)
          (@fapp0 Cat_cat Cat_cat E Y))
        (@fapp1_func Cat_cat Cat_cat E X Y)
        G
        H
        eta);

assert (W X Y : Cat) (G H : τ (Functor X Y)) ⊢
  @hom_postcomp_tele_fapp1_func Cat_cat Cat_cat (@id_func Cat_cat) W X Y G H
    ≡ @comp_cat_cov_func_func_fapp1_func W X Y G H;

assert (W X Y : Cat) (G H : τ (Functor X Y)) (eta : τ (Transf G H)) ⊢
  @hom_postcomp_tele_fapp1_fapp0 Cat_cat Cat_cat (@id_func Cat_cat) W X Y G H eta
    ≡ @comp_cat_cov_func_func_transf W X Y G H eta;

// Higher action of the tele-level precomposition-along stable head.
assert [A B : Cat] (F : τ (Functor A B)) (Z : τ (Obj B))
  (W X : τ (Obj A)) (h k : τ (Hom A W X)) ⊢
  @fapp1_func
    (Hom_cat A W X)
    (Functor_cat
      (Hom_cat B (@fapp0 A B F X) Z)
      (Hom_cat B (@fapp0 A B F W) Z))
    (@hom_precomp_along_tele_func A B F Z W X)
    h
    k
  ≡ @hom_precomp_along_tele_fapp1_func A B F Z W X h k;

assert [A B : Cat] (F : τ (Functor A B)) (Z : τ (Obj B))
  (W X : τ (Obj A)) (h k : τ (Hom A W X))
  (alpha : τ (Hom (Hom_cat A W X) h k)) ⊢
  @fapp1_fapp0
    (Hom_cat A W X)
    (Functor_cat
      (Hom_cat B (@fapp0 A B F X) Z)
      (Hom_cat B (@fapp0 A B F W) Z))
    (@hom_precomp_along_tele_func A B F Z W X)
    h
    k
    alpha
  ≡ @hom_precomp_along_tele_fapp1_fapp0 A B F Z W X h k alpha;

assert [A B : Cat] (F : τ (Functor A B)) (Z : τ (Obj B))
  (W X : τ (Obj A)) (h k : τ (Hom A W X))
  (alpha : τ (Hom (Hom_cat A W X) h k)) ⊢
  fapp0
    (@hom_postcomp_tele_fapp1_func
      (Op_cat B)
      (Op_cat A)
      (@Op_func A B F)
      Z
      X
      W
      h
      k)
    alpha
  ≡ @hom_precomp_along_tele_fapp1_fapp0 A B F Z W X h k alpha;

assert [X Y Z : Cat] (F K : τ (Functor X Y)) ⊢
  @fapp1_func
    (Functor_cat X Y)
    (Functor_cat (Functor_cat Y Z) (Functor_cat X Z))
    (@comp_cat_con_func_func X Y Z)
    F
    K
  ≡ @comp_cat_con_func_func_fapp1_func X Y Z F K;

assert [X Y Z : Cat] (F K : τ (Functor X Y))
  (alpha : τ (Transf F K)) ⊢
  @fapp1_fapp0
    (Functor_cat X Y)
    (Functor_cat (Functor_cat Y Z) (Functor_cat X Z))
    (@comp_cat_con_func_func X Y Z)
    F
    K
    alpha
  ≡ @comp_cat_con_func_func_transf X Y Z F K alpha;

assert [X Y Z : Cat] (F K : τ (Functor X Y))
  (alpha : τ (Transf F K)) (G : τ (Functor Y Z)) ⊢
  @tapp0_fapp0
    (Functor_cat Y Z)
    (Functor_cat X Z)
    (@comp_cat_con_func X Y Z F)
    (@comp_cat_con_func X Y Z K)
    G
    (@comp_cat_con_func_func_transf X Y Z F K alpha)
  ≡ @comp_cat_cov_transf X Y Z G F K alpha;

assert (E : τ (Functor Cat_cat Cat_cat)) (Z W X : Cat)
  (G H : τ (Functor W X)) (eta : τ (Transf G H)) ⊢
  @hom_precomp_along_tele_fapp1_fapp0 Cat_cat Cat_cat E Z W X G H eta
  ≡ @comp_cat_con_func_func_transf
      (@fapp0 Cat_cat Cat_cat E W)
      (@fapp0 Cat_cat Cat_cat E X)
      Z
      (@fapp1_fapp0 Cat_cat Cat_cat E W X G)
      (@fapp1_fapp0 Cat_cat Cat_cat E W X H)
      (@fapp1_fapp0
        (Functor_cat W X)
        (Functor_cat
          (@fapp0 Cat_cat Cat_cat E W)
          (@fapp0 Cat_cat Cat_cat E X))
        (@fapp1_func Cat_cat Cat_cat E W X)
        G
        H
        eta);

assert (Z W X : Cat) (G H : τ (Functor W X)) ⊢
  @hom_precomp_along_tele_fapp1_func Cat_cat Cat_cat (@id_func Cat_cat) Z W X G H
    ≡ @comp_cat_con_func_func_fapp1_func W X Z G H;

assert (Z W X : Cat) (G H : τ (Functor W X)) (eta : τ (Transf G H)) ⊢
  @hom_precomp_along_tele_fapp1_fapp0 Cat_cat Cat_cat (@id_func Cat_cat) Z W X G H eta
    ≡ @comp_cat_con_func_func_transf W X Z G H eta;

// From emdash3_2.lp:994.
assert [A : Cat] (x y z : τ (Obj A))
  (p : τ (Hom A x y)) (q : τ (Hom A y z)) ⊢
  @fapp0
    (Hom_cat A x y)
    (Hom_cat A x z)
    (@hom_postcomp_func A A (@id_func A) x y z q)
    p
    ≡ @comp_fapp0 A x y z q p;

// From emdash3_2.lp:1003.
assert [A B C : Cat] (F : τ (Functor B C)) (G : τ (Functor A B))
  (x y : τ (Obj A)) (f : τ (Hom A x y)) ⊢
  @fapp1_fapp0
    A
    C
    (@comp_cat_fapp0 A B C F G)
    x
    y
    f
    ≡ @fapp1_fapp0
        B
        C
        F
        (@fapp0 A B G x)
        (@fapp0 A B G y)
        (@fapp1_fapp0 A B G x y f);

// From emdash3_2.lp:1020.
assert [A : Cat] (x y : τ (Obj A)) (p : τ (Hom A x y)) ⊢
  @fapp1_fapp0 A A (@id_func A) x y p
    ≡ p;

// From emdash3_2.lp:1170.
assert [A B : Cat] (x : τ (Obj A)) (u : τ (Obj B)) ⊢
  @Product_projL A B (@Product_pair A B x u) ≡ x;

// From emdash3_2.lp:1173.
assert [A B : Cat] (x : τ (Obj A)) (u : τ (Obj B)) ⊢
  @Product_projR A B (@Product_pair A B x u) ≡ u;

// From emdash3_2.lp:1176.
assert [A B : Cat]
  (p q : τ (Obj (Product_cat A B))) ⊢
  @Hom_cat (Product_cat A B) p q
    ≡ @Product_cat
        (Hom_cat A (sigma_Fst p) (sigma_Fst q))
        (Hom_cat B (sigma_Snd p) (sigma_Snd q));

// From emdash3_2.lp:1183.
assert [A B : Cat] (x : τ (Obj A)) (u : τ (Obj B)) ⊢
  @id (Product_cat A B) (Struct_sigma x u)
    ≡ @Struct_sigma
        (Obj (Hom_cat A x x))
        (λ _ : τ (Obj (Hom_cat A x x)), Obj (Hom_cat B u u))
        (@id A x)
        (@id B u);

assert [A B : Cat]
  (xu : τ (Obj (Product_cat A B))) ⊢
  sigma_Fst (@id (Product_cat A B) xu)
    ≡ @id A (sigma_Fst xu);

assert [A B : Cat]
  (xu : τ (Obj (Product_cat A B))) ⊢
  sigma_Snd (@id (Product_cat A B) xu)
    ≡ @id B (sigma_Snd xu);

// From emdash3_2.lp:1191.
assert [A B : Cat]
  (x y z : τ (Obj A))
  (u v w : τ (Obj B))
  (f : τ (Hom A x y))
  (g : τ (Hom A y z))
  (alpha : τ (Hom B u v))
  (beta : τ (Hom B v w)) ⊢
  @comp_fapp0
    (Product_cat A B)
    (Struct_sigma x u)
    (Struct_sigma y v)
    (Struct_sigma z w)
    (Struct_sigma g beta)
    (Struct_sigma f alpha)
    ≡ @Struct_sigma
        (Obj (Hom_cat A x z))
        (λ _ : τ (Obj (Hom_cat A x z)), Obj (Hom_cat B u w))
        (@comp_fapp0 A x y z g f)
        (@comp_fapp0 B u v w beta alpha);

// From emdash3_2.lp:1211.
assert [A B I : Cat]
  (F : τ (Functor I A))
  (G : τ (Functor I B))
  (i : τ (Obj I)) ⊢
  @fapp0 I (Product_cat A B)
    (@Struct_sigma
      (Obj (Functor_cat I A))
      (λ _ : τ (Obj (Functor_cat I A)), Obj (Functor_cat I B))
      F
      G)
    i
    ≡ @Struct_sigma
        (Obj A)
        (λ _ : τ (Obj A), Obj B)
        (@fapp0 I A F i)
        (@fapp0 I B G i);

// From emdash3_2.lp:1228.
assert [A B I : Cat]
  (F : τ (Functor I A))
  (G : τ (Functor I B))
  (i j : τ (Obj I)) ⊢
  @fapp1_func I (Product_cat A B)
    (@Struct_sigma
      (Obj (Functor_cat I A))
      (λ _ : τ (Obj (Functor_cat I A)), Obj (Functor_cat I B))
      F
      G)
    i
    j
    ≡ @Struct_sigma
        (Obj (Functor_cat
          (Hom_cat I i j)
          (Hom_cat A (@fapp0 I A F i) (@fapp0 I A F j))))
        (λ _ : τ (Obj (Functor_cat
          (Hom_cat I i j)
          (Hom_cat A (@fapp0 I A F i) (@fapp0 I A F j)))),
          Obj (Functor_cat
            (Hom_cat I i j)
            (Hom_cat B (@fapp0 I B G i) (@fapp0 I B G j))))
        (@fapp1_func I A F i j)
        (@fapp1_func I B G i j);

// From emdash3_2.lp:1253.
assert [A B : Cat]
  (p q : τ (Obj (Product_cat A B))) ⊢
  @fapp1_func (Product_cat A B) A (@Product_projL_func A B) p q
    ≡ @Product_projL_func
        (Hom_cat A (sigma_Fst p) (sigma_Fst q))
        (Hom_cat B (sigma_Snd p) (sigma_Snd q));

// From emdash3_2.lp:1260.
assert [A B : Cat]
  (p q : τ (Obj (Product_cat A B)))
  (h : τ (Hom (Product_cat A B) p q)) ⊢
  @fapp1_fapp0 (Product_cat A B) A (@Product_projL_func A B) p q h
    ≡ sigma_Fst h;

// From emdash3_2.lp:1266.
assert [I A B : Cat]
  (H : τ (Functor I (Product_cat A B)))
  (i : τ (Obj I)) ⊢
  sigma_Fst (@fapp0 I (Product_cat A B) H i)
    ≡ @fapp0 I A (sigma_Fst H) i;

// From emdash3_2.lp:1317.
assert [K : Cat] (E D : τ (Catd K)) ⊢
  Hom_cat (Catd_cat K) E D ≡ @Transf_cat K Cat_cat E D;

// From emdash3_2.lp:1319.
assert [K : Cat] (E D : τ (Catd K)) ⊢
  Hom_cat (Functor_cat K Cat_cat) E D ≡ @Functord_cat K E D;

// From emdash3_2.lp:1352.
assert [X A B : Cat]
  (F G : τ (Functor X (Product_cat A B)))
  (eta : τ (@Transf X (Product_cat A B) F G))
  (i : τ (Obj X)) ⊢
  sigma_Fst (@tapp0_fapp0 X (Product_cat A B) F G i eta)
    ≡ @tapp0_fapp0 X A (sigma_Fst F) (sigma_Fst G) i (sigma_Fst eta);

// From emdash3_2.lp:1391.
assert [A B : Cat] (F : τ (Functor B A))
  (x y : τ (Obj A)) (p : τ (Hom A x y)) (b : τ (Obj B)) ⊢
  @tapp0_fapp0
    B
    Cat_cat
    (@hom_ A B F y)
    (@hom_ A B F x)
    b
    (@fapp1_fapp0 (Op_cat A) (@Catd_cat B) (@hom_int A B F) y x p)
    ≡ @hom_precomp_along_func A A (@id_func A) (@fapp0 B A F b) x y p;

// From emdash3_2.lp:1443.
assert [X A B : Cat]
  (F G : τ (Functor X (Product_cat A B)))
  (eta : τ (@Transf X (Product_cat A B) F G))
  (i j : τ (Obj X)) ⊢
  sigma_Fst (@tapp1_func X (Product_cat A B) F G i j eta)
    ≡ @tapp1_func X A (sigma_Fst F) (sigma_Fst G) i j (sigma_Fst eta);

// From emdash3_2.lp:1487.
assert [K A : Cat] (x y : τ (Obj A)) (p : τ (Hom A x y))
  (k : τ (Obj K)) ⊢
  @tapp0_fapp0
      K A
      (@Const_func K A x)
      (@Const_func K A y)
      k
      (@Const_transf K A x y p)
    ≡ p;

// From emdash3_2.lp:1497.
assert [K A : Cat] (x y : τ (Obj A)) (p : τ (Hom A x y))
  (k k' : τ (Obj K)) ⊢
  @tapp1_func
      K A
      (@Const_func K A x)
      (@Const_func K A y)
      k k'
      (@Const_transf K A x y p)
    ≡ @Const_func (Hom_cat K k k') (Hom_cat A x y) p;

// From emdash3_2.lp:1507.
assert [K A : Cat] (x y : τ (Obj A)) (p : τ (Hom A x y))
  (k k' : τ (Obj K)) (q : τ (Hom K k k')) ⊢
  @tapp1_fapp0
      K A
      (@Const_func K A x)
      (@Const_func K A y)
      k k'
      (@Const_transf K A x y p)
      q
    ≡ p;

// From emdash3_2.lp:1624.
assert [X Y Z : Cat] (G : τ (Functor Y Z)) (F H : τ (Functor X Y))
  (eta : τ (Transf F H)) (i : τ (Obj X)) ⊢
  @tapp0_fapp0
    X
    Z
    (@comp_cat_fapp0 X Y Z G F)
    (@comp_cat_fapp0 X Y Z G H)
    i
    (@comp_cat_cov_transf X Y Z G F H eta)
  ≡ @fapp1_fapp0
      Y
      Z
      G
      (@fapp0 X Y F i)
      (@fapp0 X Y H i)
      (@tapp0_fapp0 X Y F H i eta);

// From emdash3_2.lp:1641.
assert [X Y Z : Cat] (G : τ (Functor Y Z)) (F H : τ (Functor X Y))
  (eta : τ (Transf F H)) (i j : τ (Obj X)) ⊢
  @tapp1_func
    X
    Z
    (@comp_cat_fapp0 X Y Z G F)
    (@comp_cat_fapp0 X Y Z G H)
    i j
    (@comp_cat_cov_transf X Y Z G F H eta)
  ≡ @comp_cat_fapp0
      (Hom_cat X i j)
      (Hom_cat Y
        (@fapp0 X Y F i)
        (@fapp0 X Y H j))
      (Hom_cat Z
        (@fapp0 Y Z G (@fapp0 X Y F i))
        (@fapp0 Y Z G (@fapp0 X Y H j)))
      (@fapp1_func
        Y
        Z
        G
        (@fapp0 X Y F i)
        (@fapp0 X Y H j))
      (@tapp1_func X Y F H i j eta);

// From emdash3_2.lp:1666.
assert [X Y Z : Cat] (G : τ (Functor Y Z)) (F H : τ (Functor X Y))
  (eta : τ (Transf F H)) (i j : τ (Obj X)) (p : τ (Hom X i j)) ⊢
  @tapp1_fapp0
    X
    Z
    (@comp_cat_fapp0 X Y Z G F)
    (@comp_cat_fapp0 X Y Z G H)
    i j
    (@comp_cat_cov_transf X Y Z G F H eta)
    p
  ≡ @fapp1_fapp0
      Y
      Z
      G
      (@fapp0 X Y F i)
      (@fapp0 X Y H j)
      (@tapp1_fapp0 X Y F H i j eta p);

assert [X Y Z : Cat] (G : τ (Functor Y Z)) (F : τ (Functor X Y)) ⊢
  @comp_cat_cov_transf X Y Z G F F (@id (Functor_cat X Y) F)
    ≡ @id
        (Functor_cat X Z)
        (@comp_cat_fapp0 X Y Z G F);

// From emdash3_2.lp:1834.
assert [X Y Z : Cat] (G H : τ (Functor Y Z))
  (eta : τ (Transf G H)) (F : τ (Functor X Y)) ⊢
  @tapp0_fapp0
    (Functor_cat X Y)
    (Functor_cat X Z)
    (@comp_cat_cov_func X Y Z G)
    (@comp_cat_cov_func X Y Z H)
    F
    (@comp_cat_cov_func_func_transf X Y Z G H eta)
  ≡ @comp_cat_con_transf X Y Z F G H eta;

// From emdash3_2.lp:1845.
assert [X Y Z : Cat] (G H : τ (Functor Y Z))
  (eta : τ (Transf G H)) (F K : τ (Functor X Y)) ⊢
  @tapp1_func
    (Functor_cat X Y)
    (Functor_cat X Z)
    (@comp_cat_cov_func X Y Z G)
    (@comp_cat_cov_func X Y Z H)
    F
    K
    (@comp_cat_cov_func_func_transf X Y Z G H eta)
  ≡ @comp_cat_cov_func_func_tapp1_func X Y Z G H eta F K;

// From emdash3_2.lp:1857.
assert [X Y Z : Cat] (G H : τ (Functor Y Z))
  (eta : τ (Transf G H)) (F K : τ (Functor X Y))
  (alpha : τ (Transf F K)) ⊢
  @tapp1_fapp0
    (Functor_cat X Y)
    (Functor_cat X Z)
    (@comp_cat_cov_func X Y Z G)
    (@comp_cat_cov_func X Y Z H)
    F
    K
    (@comp_cat_cov_func_func_transf X Y Z G H eta)
    alpha
  ≡ @comp_cat_cov_func_func_tapp1_fapp0 X Y Z G H eta F K alpha;

// From emdash3_2.lp:1946.
assert [X Y Z : Cat] (F : τ (Functor X Y)) (G H : τ (Functor Y Z))
  (eta : τ (Transf G H)) (i : τ (Obj X)) ⊢
  @tapp0_fapp0
    X
    Z
    (@comp_cat_fapp0 X Y Z G F)
    (@comp_cat_fapp0 X Y Z H F)
    i
    (@comp_cat_con_transf X Y Z F G H eta)
  ≡ @tapp0_fapp0
      Y
      Z
      G
      H
      (@fapp0 X Y F i)
      eta;

// From emdash3_2.lp:1963.
assert [X Y Z : Cat] (F : τ (Functor X Y)) (G H : τ (Functor Y Z))
  (eta : τ (Transf G H)) (i j : τ (Obj X)) ⊢
  @tapp1_func
    X
    Z
    (@comp_cat_fapp0 X Y Z G F)
    (@comp_cat_fapp0 X Y Z H F)
    i j
    (@comp_cat_con_transf X Y Z F G H eta)
  ≡ @comp_cat_fapp0
      (Hom_cat X i j)
      (Hom_cat Y
        (@fapp0 X Y F i)
        (@fapp0 X Y F j))
      (Hom_cat Z
        (@fapp0 Y Z G (@fapp0 X Y F i))
        (@fapp0 Y Z H (@fapp0 X Y F j)))
      (@tapp1_func
        Y
        Z
        G
        H
        (@fapp0 X Y F i)
        (@fapp0 X Y F j)
        eta)
      (@fapp1_func X Y F i j);

// From emdash3_2.lp:1990.
assert [X Y Z : Cat] (F : τ (Functor X Y)) (G H : τ (Functor Y Z))
  (eta : τ (Transf G H)) (i j : τ (Obj X)) (p : τ (Hom X i j)) ⊢
  @tapp1_fapp0
    X
    Z
    (@comp_cat_fapp0 X Y Z G F)
    (@comp_cat_fapp0 X Y Z H F)
    i j
    (@comp_cat_con_transf X Y Z F G H eta)
    p
  ≡ @tapp1_fapp0
      Y
      Z
      G
      H
      (@fapp0 X Y F i)
      (@fapp0 X Y F j)
      eta
      (@fapp1_fapp0 X Y F i j p);

assert [X Y Z : Cat] (F : τ (Functor X Y)) (G : τ (Functor Y Z)) ⊢
  @comp_cat_con_transf X Y Z F G G (@id (Functor_cat Y Z) G)
    ≡ @id
        (Functor_cat X Z)
        (@comp_cat_fapp0 X Y Z G F);

// From emdash3_2.lp:2019.
assert [X A B : Cat]
  (F G : τ (Functor X (Product_cat A B)))
  (eta : τ (@Transf X (Product_cat A B) F G))
  (i j : τ (Obj X))
  (p : τ (Hom X i j)) ⊢
  sigma_Fst (@tapp1_fapp0 X (Product_cat A B) F G i j eta p)
    ≡ @tapp1_fapp0 X A (sigma_Fst F) (sigma_Fst G) i j (sigma_Fst eta) p;

// From emdash3_2.lp:2206.
assert [A A' B : Cat] (G : τ (Functor A A'))
  (x : τ (Obj A)) (y : τ (Obj B)) ⊢
  sigma_Fst
    (fapp0 (@Product_cat_fapp1_tapp0_func A A' B G) (Struct_sigma x y))
    ≡ fapp0 G x;

// From emdash3_2.lp:2212.
assert [A A' B : Cat] (G : τ (Functor A A'))
  (x : τ (Obj A)) (y : τ (Obj B)) ⊢
  sigma_Snd
    (fapp0 (@Product_cat_fapp1_tapp0_func A A' B G) (Struct_sigma x y))
    ≡ y;

// From emdash3_2.lp:2218.
assert [A A' B : Cat] (G : τ (Functor A A'))
  (x x' : τ (Obj A)) (y y' : τ (Obj B))
  (p : τ (Hom A x x')) (q : τ (Hom B y y')) ⊢
  sigma_Fst
    (@fapp1_fapp0
      (Product_cat A B)
      (Product_cat A' B)
      (@Product_cat_fapp1_tapp0_func A A' B G)
      (Struct_sigma x y)
      (Struct_sigma x' y')
      (Struct_sigma p q))
    ≡ @fapp1_fapp0 A A' G x x' p;

// From emdash3_2.lp:2231.
assert [A A' B : Cat] (G : τ (Functor A A'))
  (x x' : τ (Obj A)) (y y' : τ (Obj B))
  (p : τ (Hom A x x')) (q : τ (Hom B y y')) ⊢
  sigma_Snd
    (@fapp1_fapp0
      (Product_cat A B)
      (Product_cat A' B)
      (@Product_cat_fapp1_tapp0_func A A' B G)
      (Struct_sigma x y)
      (Struct_sigma x' y')
      (Struct_sigma p q))
    ≡ q;

// From emdash3_2.lp:2244.
assert [A A' B : Cat] (G : τ (Functor A A')) ⊢
  @fapp0
    (Functor_cat A A')
    (Functor_cat (Product_cat A B) (Product_cat A' B))
    (@Product_mapL_func_func A A' B)
    G
    ≡ @Product_cat_fapp1_tapp0_func A A' B G;

// From emdash3_2.lp:2292.
assert [A B : Cat] (F : τ (Functor A B)) (x : τ (Obj A)) ⊢
  fapp0 (@Eval_func A B) (Struct_sigma F x)
    ≡ fapp0 F x;

// From emdash3_2.lp:2296.
assert [A B : Cat]
  (F G : τ (Functor A B))
  (x y : τ (Obj A)) ⊢
  @fapp1_func
    (Product_cat (Functor_cat A B) A)
    B
    (@Eval_func A B)
    (Struct_sigma F x)
    (Struct_sigma G y)
  ≡ @Eval_fapp1_func A B F G x y;

// From emdash3_2.lp:2307.
assert [A B : Cat]
  (F G : τ (Functor A B))
  (x y : τ (Obj A))
  (eta : τ (Transf F G))
  (p : τ (Hom A x y)) ⊢
  @fapp1_fapp0
    (Product_cat (Functor_cat A B) A)
    B
    (@Eval_func A B)
    (Struct_sigma F x)
    (Struct_sigma G y)
    (Struct_sigma eta p)
  ≡ @tapp1_fapp0 A B F G x y eta p;

// From emdash3_2.lp:2368.
assert [A B : Cat] (x : τ (Obj A)) (F : τ (Functor A B)) ⊢
  fapp0 (fapp0_func x) F
    ≡ fapp0 F x;

// From emdash3_2.lp:2372.
assert [A B : Cat] (x : τ (Obj A)) (F G : τ (Functor A B)) ⊢
  @fapp1_func
    (Functor_cat A B)
    B
    (@fapp0_func A B x)
    F
    G
  ≡ @tapp0_func A B F G x;

// From emdash3_2.lp:2381.
assert [A B : Cat] (x : τ (Obj A)) (F G : τ (Functor A B))
  (eta : τ (Transf F G)) ⊢
  @fapp1_fapp0
    (Functor_cat A B)
    B
    (@fapp0_func A B x)
    F
    G
    eta
  ≡ @tapp0_fapp0 A B F G x eta;

// From emdash3_2.lp:2392.
assert [A B : Cat] (x : τ (Obj A)) ⊢
  @comp_cat_fapp0
    (Functor_cat A B)
    (Product_cat (Functor_cat A B) A)
    B
    (@Eval_func A B)
    (@Eval_at_func A B x)
  ≡ @fapp0_func A B x;

// From emdash3_2.lp:2468.
assert [A B C : Cat]
  (G : τ (Functor A (Functor_cat B C)))
  (x : τ (Obj A))
  (y : τ (Obj B)) ⊢
  fapp0 (uncurry_func G) (Struct_sigma x y)
    ≡ fapp0 (fapp0 G x) y;

// From emdash3_2.lp:2475.
assert [A B C : Cat]
  (G : τ (Functor A (Functor_cat B C)))
  (x x' : τ (Obj A))
  (y y' : τ (Obj B))
  (p : τ (Hom A x x'))
  (q : τ (Hom B y y')) ⊢
  @fapp1_fapp0
    (Product_cat A B)
    C
    (@uncurry_func A B C G)
    (Struct_sigma x y)
    (Struct_sigma x' y')
    (Struct_sigma p q)
    ≡ @tapp1_fapp0
      B
      C
      (@fapp0 A (Functor_cat B C) G x)
      (@fapp0 A (Functor_cat B C) G x')
      y
      y'
      (@fapp1_fapp0 A (Functor_cat B C) G x x' p)
      q;

// From emdash3_2.lp:2498.
assert [A B C : Cat]
  (F : τ (Functor (Product_cat A B) C)) ⊢
  fapp0 curry_func_func F
    ≡ curry_func F;

// From emdash3_2.lp:2503.
assert [A B C : Cat]
  (G : τ (Functor A (Functor_cat B C))) ⊢
  fapp0 uncurry_func_func G
    ≡ uncurry_func G;

// Ordinary adjunction triangle cut-elimination.
assert [R L : Cat]
  (J : τ (Adjunction R L))
  (X X' : τ (Obj R))
  (Y : τ (Obj L))
  (g : τ (Hom R X X'))
  (f : τ (Hom L (@fapp0 R L (@left_adj_func R L J) X') Y)) ⊢
  comp_fapp0
    (@tapp1_fapp0
      L
      L
      (@comp_cat_fapp0
        L
        R
        L
        (@left_adj_func R L J)
        (@right_adj_func R L J))
      (@id_func L)
      (@fapp0 R L (@left_adj_func R L J) X')
      Y
      (@counit_adj_transf R L J)
      f)
    (@fapp1_fapp0
      R
      L
      (@left_adj_func R L J)
      X
      (@fapp0 L R (@right_adj_func R L J)
        (@fapp0 R L (@left_adj_func R L J) X'))
      (@tapp1_fapp0
        R
        R
        (@id_func R)
        (@comp_cat_fapp0
          R
          L
          R
          (@right_adj_func R L J)
          (@left_adj_func R L J))
        X
        X'
        (@unit_adj_transf R L J)
        g))
  ≡ comp_fapp0
      f
      (@fapp1_fapp0 R L (@left_adj_func R L J) X X' g);

assert [R L : Cat]
  (J : τ (Adjunction R L))
  (X : τ (Obj R))
  (Y' Y : τ (Obj L))
  (f : τ (Hom R X (@fapp0 L R (@right_adj_func R L J) Y')))
  (g : τ (Hom L Y' Y)) ⊢
  comp_fapp0
    (@fapp1_fapp0
      L
      R
      (@right_adj_func R L J)
      (@fapp0 R L (@left_adj_func R L J)
        (@fapp0 L R (@right_adj_func R L J) Y'))
      Y
      (@tapp1_fapp0
        L
        L
        (@comp_cat_fapp0
          L
          R
          L
          (@left_adj_func R L J)
          (@right_adj_func R L J))
        (@id_func L)
        Y'
        Y
        (@counit_adj_transf R L J)
        g))
    (@tapp1_fapp0
      R
      R
      (@id_func R)
      (@comp_cat_fapp0
        R
        L
        R
        (@right_adj_func R L J)
        (@left_adj_func R L J))
      X
      (@fapp0 L R (@right_adj_func R L J) Y')
      (@unit_adj_transf R L J)
      f)
  ≡ comp_fapp0
      (@fapp1_fapp0 L R (@right_adj_func R L J) Y' Y g)
      f;

assert [A B : Cat]
  [F G : τ (Functor A B)]
  (eta : τ (Transf F G)) ⊢
  @Op_transf A B F G eta
  : τ (Transf (@Op_func A B G) (@Op_func A B F));

assert [A B : Cat]
  [F G : τ (Functor A B)]
  (eta : τ (Transf F G)) ⊢
  @Op_transf
    (Op_cat A) (Op_cat B)
    (@Op_func A B G)
    (@Op_func A B F)
    (@Op_transf A B F G eta)
  ≡ eta;

assert [A B : Cat]
  (F : τ (Functor A B)) ⊢
  @Op_transf
    A B F F
    (@id (Functor_cat A B) F)
  ≡ @id
      (Functor_cat (Op_cat A) (Op_cat B))
      (@Op_func A B F);

assert [A B : Cat]
  (adj : τ (Adjunction A B)) ⊢
  @left_adj_func
    (Op_cat B) (Op_cat A)
    (@Op_adjunction A B adj)
  ≡ @Op_func B A (@right_adj_func A B adj);

assert [A B : Cat]
  (adj : τ (Adjunction A B)) ⊢
  @right_adj_func
    (Op_cat B) (Op_cat A)
    (@Op_adjunction A B adj)
  ≡ @Op_func A B (@left_adj_func A B adj);

assert [A B : Cat]
  (adj : τ (Adjunction A B)) ⊢
  @unit_adj_transf
    (Op_cat B) (Op_cat A)
    (@Op_adjunction A B adj)
  ≡ @Op_transf
      B B
      (@comp_cat_fapp0
        B A B
        (@left_adj_func A B adj)
        (@right_adj_func A B adj))
      (@id_func B)
      (@counit_adj_transf A B adj);

assert [A B : Cat]
  (adj : τ (Adjunction A B)) ⊢
  @counit_adj_transf
    (Op_cat B) (Op_cat A)
    (@Op_adjunction A B adj)
  ≡ @Op_transf
      A A
      (@id_func A)
      (@comp_cat_fapp0
        A B A
        (@right_adj_func A B adj)
        (@left_adj_func A B adj))
      (@unit_adj_transf A B adj);

assert [A B : Cat]
  (x : τ (Obj A))
  (y : τ (Obj B)) ⊢
  @fapp0
    (Product_cat A B)
    (Product_cat B A)
    (@Product_swap_func A B)
    (Struct_sigma x y)
  ≡ @Struct_sigma
      (Obj B)
      (λ _ : τ (Obj B), Obj A)
      y x;

assert [A B : Cat] ⊢
  @comp_cat_fapp0
    (Product_cat A B)
    (Product_cat B A)
    (Product_cat A B)
    (@Product_swap_func B A)
    (@Product_swap_func A B)
  ≡ @id_func (Product_cat A B);

assert [A B : Cat] ⊢
  @Op_func
    (Product_cat A B)
    (Product_cat B A)
    (@Product_swap_func A B)
  ≡ @Product_swap_func (Op_cat A) (Op_cat B);

assert [A B : Cat]
  (R : τ (Catd (Product_cat (Op_cat A) B)))
  (a : τ (Obj A))
  (b : τ (Obj B)) ⊢
  @fapp0
    (Product_cat B (Op_cat A))
    Cat_cat
    (@Op_prof A B R)
    (Struct_sigma b a)
  ≡ @fapp0
      (Product_cat (Op_cat A) B)
      Cat_cat
      R
      (Struct_sigma a b);

assert [A B X : Cat]
  (F : τ (Functor A X))
  (G : τ (Functor B X))
  (a : τ (Obj A))
  (b : τ (Obj B)) ⊢
  @fapp0
    (Product_cat B (Op_cat A))
    Cat_cat
    (@Op_prof A B (@Hom_prof_along A B X F G))
    (Struct_sigma b a)
  ≡ @Hom_cat
      X
      (@fapp0 A X F a)
      (@fapp0 B X G b);

// From emdash3_2.lp:2636.
assert [A B : Cat] (F : τ (Functor A B)) (X : τ (Obj A)) ⊢
  @tapp0_fapp0
      (Op_cat A)
      (@Catd_cat A)
      (@hom_int A A (@id_func A))
      (@comp_cat_fapp0
        (Op_cat A)
        (Op_cat B)
        (@Catd_cat A)
        (@hom_int B A F)
        (@Op_func A B F))
      X
      (@fapp1_int_transf A B F)
    ≡ @fapp1_at_transf A B F X;

// From emdash3_2.lp:2651.
assert [A B : Cat] (F : τ (Functor A B)) (X : τ (Obj A)) ⊢
  @tapp1_at_transf A B F F X (id (Functor_cat A B) F)
    ≡ @fapp1_at_transf A B F X;

// From emdash3_2.lp:2655.
assert [A B : Cat] (F : τ (Functor A B)) (X Y : τ (Obj A)) ⊢
  @tapp0_fapp0
      A
      Cat_cat
      (@hom_ A A (@id_func A) X)
      (@hom_ B A F (@fapp0 A B F X))
      Y
      (@fapp1_at_transf A B F X)
    ≡ @fapp1_func A B F X Y;

// From emdash3_2.lp:2665.
assert [A B : Cat] (F : τ (Functor A B)) (X Y : τ (Obj A)) ⊢
  @tapp0_fapp0
      A
      Cat_cat
      _
      _
      Y
      (@tapp0_fapp0
        (Op_cat A)
        (@Catd_cat A)
        _
        _
        X
        (@fapp1_int_transf A B F))
    ≡ @fapp1_func A B F X Y;

// From emdash3_2.lp:2681.
assert [A B : Cat] (F : τ (Functor A B))
  (X Y : τ (Obj A)) (f : τ (Hom A X Y)) ⊢
  fapp0 (@fapp1_func A B F X Y) f
    ≡ @fapp1_fapp0 A B F X Y f;

// From emdash3_2.lp:2686.
assert [A B : Cat] (F G : τ (Functor A B))
  (ϵ : τ (Transf F G)) (X : τ (Obj A)) ⊢
  @tapp0_fapp0
      (Op_cat A)
      (@Catd_cat A)
      (@hom_int A A (@id_func A))
      (@comp_cat_fapp0
        (Op_cat A)
        (Op_cat B)
        (@Catd_cat A)
        (@hom_int B A G)
        (@Op_func A B F))
      X
      (@tapp1_int_fapp0_transf A B F G ϵ)
    ≡ @tapp1_at_transf A B F G X ϵ;

// From emdash3_2.lp:2702.
assert [A B : Cat] (F G : τ (Functor A B))
  (ϵ : τ (Transf F G)) (X Y : τ (Obj A)) ⊢
  @tapp0_fapp0
      A
      Cat_cat
      (@hom_ A A (@id_func A) X)
      (@hom_ B A G (@fapp0 A B F X))
      Y
      (@tapp1_at_transf A B F G X ϵ)
    ≡ @tapp1_func A B F G X Y ϵ;

// From emdash3_2.lp:2713.
assert [A B : Cat] (F G : τ (Functor A B))
  (ϵ : τ (Transf F G)) (X Y : τ (Obj A)) ⊢
  @tapp0_fapp0
      A
      Cat_cat
      _
      _
      Y
      (@tapp0_fapp0
        (Op_cat A)
        (@Catd_cat A)
        _
        _
        X
        (@tapp1_int_fapp0_transf A B F G ϵ))
    ≡ @tapp1_func A B F G X Y ϵ;

// From emdash3_2.lp:2738.
assert [A B : Cat] (F G : τ (Functor A B)) (ϵ : τ (Transf F G)) ⊢
  fapp0 (@tapp1_int_func_transf A B F G) ϵ
    ≡ @tapp1_int_fapp0_transf A B F G ϵ;

// From emdash3_2.lp:2742.
assert [A B : Cat] (F G : τ (Functor A B))
  (ϵ ϵ' : τ (Transf F G)) ⊢
  @fapp1_func _ _ (@tapp1_int_func_transf A B F G) ϵ ϵ'
    ≡ @tapp1_int_fapp1_func_transf A B F G ϵ ϵ';

// From emdash3_2.lp:2747.
assert [A B : Cat] (F G : τ (Functor A B))
  (X Y Z : τ (Obj A))
  (f : τ (Hom A X Y))
  (g : τ (Hom A Y Z))
  (ϵ : τ (Transf F G)) ⊢
  @comp_fapp0
    B
    (@fapp0 A B F X)
    (@fapp0 A B G Y)
    (@fapp0 A B G Z)
    (@fapp1_fapp0 A B G Y Z g)
    (@tapp1_fapp0 A B F G X Y ϵ f)
    ≡ @tapp1_fapp0 A B F G X Z ϵ
        (@comp_fapp0 A X Y Z g f);

// From emdash3_2.lp:2762.
assert [A B : Cat] (F G : τ (Functor A B))
  (X0 X Y : τ (Obj A))
  (g : τ (Hom A X0 X))
  (f : τ (Hom A X Y))
  (ϵ : τ (Transf F G)) ⊢
  @comp_fapp0
    B
    (@fapp0 A B F X0)
    (@fapp0 A B F X)
    (@fapp0 A B G Y)
    (@tapp1_fapp0 A B F G X Y ϵ f)
    (@fapp1_fapp0 A B F X0 X g)
    ≡ @tapp1_fapp0 A B F G X0 Y ϵ
        (@comp_fapp0 A X0 X Y f g);

// Full strict naturality: post/left accumulation before capping.
assert [A B : Cat] (F G : τ (Functor A B)) (X Y Z : τ (Obj A))
  (g : τ (Hom A Y Z)) (ϵ : τ (Transf F G)) ⊢
  @comp_cat_fapp0
    (Hom_cat A X Y)
    (Hom_cat B (@fapp0 A B F X) (@fapp0 A B G Y))
    (Hom_cat B (@fapp0 A B F X) (@fapp0 A B G Z))
    (@hom_postcomp_func B A G (@fapp0 A B F X) Y Z g)
    (@tapp1_func A B F G X Y ϵ)
  ≡ @comp_cat_fapp0
    (Hom_cat A X Y)
    (Hom_cat A X Z)
    (Hom_cat B (@fapp0 A B F X) (@fapp0 A B G Z))
    (@tapp1_func A B F G X Z ϵ)
    (@hom_postcomp_func A A (@id_func A) X Y Z g);

assert [A B : Cat] (F G : τ (Functor A B)) (X Y Z : τ (Obj A))
  (f : τ (Hom A X Y)) (g : τ (Hom A Y Z)) (ϵ : τ (Transf F G)) ⊢
  fapp0
    (@comp_cat_fapp0
      (Hom_cat A X Y)
      (Hom_cat B (@fapp0 A B F X) (@fapp0 A B G Y))
      (Hom_cat B (@fapp0 A B F X) (@fapp0 A B G Z))
      (@hom_postcomp_func B A G (@fapp0 A B F X) Y Z g)
      (@tapp1_func A B F G X Y ϵ))
    f
  ≡ @tapp1_fapp0 A B F G X Z ϵ
      (@comp_fapp0 A X Y Z g f);

// Full strict naturality: pre/right accumulation before capping.
assert [A B : Cat] (F G : τ (Functor A B)) (W X Y : τ (Obj A))
  (h : τ (Hom A W X)) (ϵ : τ (Transf F G)) ⊢
  @comp_cat_fapp0
    (Hom_cat A X Y)
    (Hom_cat B (@fapp0 A B F X) (@fapp0 A B G Y))
    (Hom_cat B (@fapp0 A B F W) (@fapp0 A B G Y))
    (@hom_precomp_along_func A B F (@fapp0 A B G Y) W X h)
    (@tapp1_func A B F G X Y ϵ)
  ≡ @comp_cat_fapp0
    (Hom_cat A X Y)
    (Hom_cat A W Y)
    (Hom_cat B (@fapp0 A B F W) (@fapp0 A B G Y))
    (@tapp1_func A B F G W Y ϵ)
    (@hom_precomp_along_func A A (@id_func A) Y W X h);

assert [A B : Cat] (F G : τ (Functor A B)) (W X Y : τ (Obj A))
  (h : τ (Hom A W X)) (f : τ (Hom A X Y)) (ϵ : τ (Transf F G)) ⊢
  fapp0
    (@comp_cat_fapp0
      (Hom_cat A X Y)
      (Hom_cat B (@fapp0 A B F X) (@fapp0 A B G Y))
      (Hom_cat B (@fapp0 A B F W) (@fapp0 A B G Y))
      (@hom_precomp_along_func A B F (@fapp0 A B G Y) W X h)
      (@tapp1_func A B F G X Y ϵ))
    f
  ≡ @tapp1_fapp0 A B F G W Y ϵ
      (@comp_fapp0 A W X Y f h);

// Full strict functoriality: post/left accumulation for a single functor.
assert [A B : Cat] (F : τ (Functor A B)) (X Y Z : τ (Obj A))
  (g : τ (Hom A Y Z)) ⊢
  @comp_cat_fapp0
    (Hom_cat A X Y)
    (Hom_cat B (@fapp0 A B F X) (@fapp0 A B F Y))
    (Hom_cat B (@fapp0 A B F X) (@fapp0 A B F Z))
    (@hom_postcomp_func B A F (@fapp0 A B F X) Y Z g)
    (@fapp1_func A B F X Y)
  ≡ @comp_cat_fapp0
    (Hom_cat A X Y)
    (Hom_cat A X Z)
    (Hom_cat B (@fapp0 A B F X) (@fapp0 A B F Z))
    (@fapp1_func A B F X Z)
    (@hom_postcomp_func A A (@id_func A) X Y Z g);

assert [A B : Cat] (F : τ (Functor A B)) (X Y Z : τ (Obj A))
  (f : τ (Hom A X Y)) (g : τ (Hom A Y Z)) ⊢
  fapp0
    (@comp_cat_fapp0
      (Hom_cat A X Y)
      (Hom_cat B (@fapp0 A B F X) (@fapp0 A B F Y))
      (Hom_cat B (@fapp0 A B F X) (@fapp0 A B F Z))
      (@hom_postcomp_func B A F (@fapp0 A B F X) Y Z g)
      (@fapp1_func A B F X Y))
    f
  ≡ @fapp1_fapp0 A B F X Z
      (@comp_fapp0 A X Y Z g f);

// Full strict functoriality: pre/right accumulation for a single functor.
assert [A B : Cat] (F : τ (Functor A B)) (W X Y : τ (Obj A))
  (h : τ (Hom A W X)) ⊢
  @comp_cat_fapp0
    (Hom_cat A X Y)
    (Hom_cat B (@fapp0 A B F X) (@fapp0 A B F Y))
    (Hom_cat B (@fapp0 A B F W) (@fapp0 A B F Y))
    (@hom_precomp_along_func A B F (@fapp0 A B F Y) W X h)
    (@fapp1_func A B F X Y)
  ≡ @comp_cat_fapp0
    (Hom_cat A X Y)
    (Hom_cat A W Y)
    (Hom_cat B (@fapp0 A B F W) (@fapp0 A B F Y))
    (@fapp1_func A B F W Y)
    (@hom_precomp_along_func A A (@id_func A) Y W X h);

assert [A B : Cat] (F : τ (Functor A B)) (W X Y : τ (Obj A))
  (h : τ (Hom A W X)) (f : τ (Hom A X Y)) ⊢
  fapp0
    (@comp_cat_fapp0
      (Hom_cat A X Y)
      (Hom_cat B (@fapp0 A B F X) (@fapp0 A B F Y))
      (Hom_cat B (@fapp0 A B F W) (@fapp0 A B F Y))
      (@hom_precomp_along_func A B F (@fapp0 A B F Y) W X h)
      (@fapp1_func A B F X Y))
    f
  ≡ @fapp1_fapp0 A B F W Y
      (@comp_fapp0 A W X Y f h);

// Interchange law instance for the Cat-valued representable `hom_`
// (postcomposition). This is the v3.2 full-owner form of the old v2
// "exchange law" check.
assert [B : Cat] (M N L : τ (Obj B))
  (f g : τ (Hom B N L)) (e_fg : τ (Hom (Hom_cat B N L) f g))
  (X Y Z : τ (Hom B M N))
  (α : τ (Hom (Hom_cat B M N) X Y))
  (β : τ (Hom (Hom_cat B M N) Y Z)) ⊢
  @comp_cat_fapp0
    (Hom_cat (Hom_cat B M N) X Y)
    (Hom_cat
      (Hom_cat B M L)
      (fapp0 (@hom_postcomp_func B B (@id_func B) M N L f) X)
      (fapp0 (@hom_postcomp_func B B (@id_func B) M N L g) Y))
    (Hom_cat
      (Hom_cat B M L)
      (fapp0 (@hom_postcomp_func B B (@id_func B) M N L f) X)
      (fapp0 (@hom_postcomp_func B B (@id_func B) M N L g) Z))
    (@hom_postcomp_func
      (Hom_cat B M L)
      (Hom_cat B M N)
      (@hom_postcomp_func B B (@id_func B) M N L g)
      (fapp0 (@hom_postcomp_func B B (@id_func B) M N L f) X)
      Y
      Z
      β)
    (@tapp1_func
      (Hom_cat B M N)
      (Hom_cat B M L)
      (@hom_postcomp_func B B (@id_func B) M N L f)
      (@hom_postcomp_func B B (@id_func B) M N L g)
      X
      Y
      (@fapp1_fapp0
        (Hom_cat B N L)
        (Functor_cat (Hom_cat B M N) (Hom_cat B M L))
        (@hom_postcomp_tele_func B B (@id_func B) M N L)
        f
        g
        e_fg))
  ≡ @comp_cat_fapp0
    (Hom_cat (Hom_cat B M N) X Y)
    (Hom_cat (Hom_cat B M N) X Z)
    (Hom_cat
      (Hom_cat B M L)
      (fapp0 (@hom_postcomp_func B B (@id_func B) M N L f) X)
      (fapp0 (@hom_postcomp_func B B (@id_func B) M N L g) Z))
    (@tapp1_func
      (Hom_cat B M N)
      (Hom_cat B M L)
      (@hom_postcomp_func B B (@id_func B) M N L f)
      (@hom_postcomp_func B B (@id_func B) M N L g)
      X
      Z
      (@fapp1_fapp0
        (Hom_cat B N L)
        (Functor_cat (Hom_cat B M N) (Hom_cat B M L))
        (@hom_postcomp_tele_func B B (@id_func B) M N L)
        f
        g
        e_fg))
    (@hom_postcomp_func
      (Hom_cat B M N)
      (Hom_cat B M N)
      (@id_func (Hom_cat B M N))
      X
      Y
      Z
      β);

