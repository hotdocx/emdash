    (@id_func I)
    (@id_func K)
    (@id_func I)
    (@id_func K)
    (@Adjunction_prof_transpose A B adj I K M F)
    (@Adjunction_prof_untranspose A B adj I K M F)
  ≡ @Prof_id_transf
      I K
      (@Hom_prof_along
        I K A
        M
        (@comp_cat_fapp0 K B A (@right_adj_func A B adj) F));

assert [A B : Cat]
