/*
  m- / emdash3.2
  Directed-family mixed-variance v3.2 migration draft.

  This file is forked from emdash3_1.lp and implements
  reports/REPORT_EMDASH_V3_HOM_FAM_PI_CONST_PLAN.md incrementally.  It uses
  directed Cat-valued families directly:

    Functor_cat K Cat_cat --> Catd_cat K.
*/

flag "eta_equality" on;
flag "print_implicits" on;
flag "print_contexts" on;
flag "print_domains" on;
flag "print_meta_args" on;

/*
  Ported working conventions from emdash2.lp

  This file is intentionally kernel-like: primitives stay small, and
  computational behavior is made explicit by rewrite and unification rules.
  Comments should name the categorical intent, but rules should stay close to
  the stable heads actually used by Lambdapi.

  Surface reading for this directed-family draft:
    - `E[x]` means `Fibre_cat E x`, for `E : Catd Z`.
    - `F[x]` means `fapp0 F x`, for an ordinary functor.
    - `Пө[x]` means the diagonal component extracted by `tapp0_fapp0 x Пө`.
    - `homd_int (id_funcd E)`, after projection at x,u,y,v, normalizes through
      `homd_src_func`, `homd_src_sec`, `homd_tgt_func`, then generalized
      `homd_` at the identity displayed functor.
    - `homd_int FF`, for `FF : Functord D E`, follows the generalized
      `homd_src_funcd`, `homd_src_secd`, `homd_tgt_funcd`, then `homd_`.

  Rewrite hygiene:
    - Lambdapi rule LHSs are matched and typechecked modulo conversion.
      Over-specifying inferred/implicit arguments can force expensive
      conversion problems, or make a rule fail to match after the inferred term
      reduces to a canonical expression.
    - Keep inferred/implicit arguments on rule LHSs as `_` unless they are
      essential discriminators.
    - In particular, do not spell defined aliases or reducible compound
      expressions in implicit LHS slots just because the rule typechecks.
      Such a rule can be accepted but later fail to fire when Lambdapi infers
      the same slot through a different normal form. Match on the stable head
      or explicit data argument instead, and let typing/unification recover
      the implicit endpoint.
    - If there are multiple inferred arguments in a nested expression, check
      all of them.  Omitting only one brittle argument is often not enough.
    - Be especially cautious when an implicit argument contains a reducible
      subterm such as `fapp0 F x`, `comp_cat_fapp0 F G`, `Functor_catd ...`,
      `HomPresheaf_catd ...`, or `Homd_target_catd ...`, or a compound
      canonical expression such as `Op_cat (Hom_cat ...)`.
    - Prefer small projection rules with stable heads over one large nested
      redex. The homd projection path is split into `tapp0_fapp0` and `fapp0`
      folds; surface `piapp0` notation unfolds through `tapp0_fapp0`.

  Stable heads and unification helpers:
    - Stable heads are the intended normal forms for operations that later
      rules need to recognize (`comp_cat_fapp0`, `tapp0_fapp0`,
      `homd_src_func`, `homd_src_sec`, `homd_tgt_func`).
    - Controlled `Obj`-inversion unification rules for chosen heads
      (`Hom_cat`, `Functor_cat`, `Transf_cat`, `Fibre_cat`) are elaboration
      aids.  They are not semantic claims that `Obj` is globally injective.
    - If a concrete constructor does not reduce early enough and needs one of
      these unification helpers, that is usually a signal to add a computation
      rule or introduce a smaller stable head.

  Omega-friendly normalization:
    - Prefer functor-level folds over capped pointwise rewrites when the result
      must remain iterable to higher cells.  A rule whose RHS is just
      `fapp0 (...) cell` computes one selected cell but can lose the functor
      object that would support another hom-action.
    - Use pointwise endpoint notation only when the current construction
      genuinely needs an endpoint. Here `homd_` is defined by the semantic
      `hom_con` endpoint; internal rules should discriminate on `homd_int`.

  Naming conventions:
    - Categories use uppercase letters (`A B C K Z`), with `Z` often the base.
    - Directed Cat-valued families use `E D A B` depending on variance; fibre
      objects are usually lowercase `u v`.
    - Ordinary functors use `F G`; transfors use Greek names such as `Пө О·`.
    - Projection/application heads follow the v2 pattern:
      `fapp*` for ordinary functors, `tapp*` for transfors, `piapp0` for a
      section of a `Pi_cat`, and `homd_*` for the dependent-hom projection
      pipeline.
*/

/*
  Maintenance inventory (v3.2)

  For each Cat-valued constructor, decide which projections compute by rewrite
  and which remain abstract.  Use this as a checklist before adding new rules.

    - Core `Op_cat`, `Path_cat`, `Terminal_cat`, `Cat_cat`: object/hom and
      basic identity/composition behavior compute by rewrite.
    - `Functor_cat`: object encoding is abstract; homs reduce to `Transf_cat`.
      Use `fapp0`, `fapp1_func`, `fapp1_fapp0`, and `tapp*` projections rather
      than exposing a record of functor data.
    - `Transf_cat`: object encoding is abstract; diagonal components compute
      through `tapp0_fapp0`, including identity and vertical composition.
    - `Catd_cat K`: the canonical category of directed Cat-valued families,
      reached by reducing `Functor_cat K Cat_cat`; `Fibre_cat` is notation for
      the surface reading of `E[k]`.
    - `Pi_cat E`: stable section category for a directed family. It joins
      `Functord_cat (Const_catd K Terminal_cat) E`; the corresponding
      `Transf_cat` source reaches it through the canonical `Functord_cat`
      contraction.
    - `Sigma_cat E`: object decoding is Sigma-shaped; homs between total
      objects route through the endpoint `homd_`.
    - `Functor_catd` / `Functor_catd_mix_func`: mixed-variance family formation
      is functorial in family arguments, not just an object-level recipe.
    - `Edge_catd_fam` / `HomPresheaf_catd`: internal representable/presheaf-family
      classifiers.  Keep them as named constructor pipelines; do not inline
      them into rewrite-rule LHSs.
    - `Homd_*`: source/section/target family names are readability and
      assertion handles.  Projection-rule LHSs should keep those inferred
      source/target family arguments implicit.
    - `homd_` is the generalized endpoint with an explicit displayed functor
      argument. The old one-family endpoint is represented by the identity
      specialization `homd_ (id_funcd E)`.
    - `FibCov_*`: the internal covariant fibre-transport package; it projects
      through `fib_cov_src_func` to the external `fib_cov_transf`, then to
      `fib_cov_tapp0_func`.
    - `tapp1_int_func_transf` / `fapp1_int_transf`: ordinary internal
      hom-action heads ported from v2, including stable object/hom action
      package heads.
    - `tdapp1_int_func_transfd` / `fdapp1_int_transfd`: displayed internal
      analogues targeting the generalized `homd_int` arity, also with stable
      object/hom action package heads.
    - `tdapp0_func` / `tdapp0_fapp0`: derived notation, not primitive
      structure; it is ordinary `fapp1_func` of component evaluation.
    - `Fibre_func` / `Fibre_transf` / `Fibre_transf_app`: derived fibre-level
      projections over `tapp0`/`tdapp0`, useful for later bridges but not
      rewrite discriminators.
    - Pointwise displayed-functor calculus: `Op_funcd` projects through
      `tapp0_fapp0` to ordinary fibre opposites. The analogous displayed
      composition projection is deferred after a timeout probe.
    - `fdapp1_int_fibre_transf` / `fdapp1_int_fibre_app`: derived projections
      of the internal displayed hom-action, still below any external
      `fdapp1_*` surface API.
    - `piapp1_func` / `piapp1_fapp0`: section action over a base arrow. The
      capped component is a definition by `piapp0`; the terminal-specialization
      fold from displayed internal action is still deferred.
    - `Terminal_catd K` and `piapp0` are readability definitions, not rewrite
      discriminators. Operational rules use the unfolded constant-terminal
      source or lower-level `tapp0_fapp0` folds.
    - Generic Sigma/Pi weakening helpers are deferred until the directed-family
      core has enough stable beta assertions.
*/

// -------------------------------------------------------------------------------------------------
// 0. Groupoid universe and equality
// -------------------------------------------------------------------------------------------------

constant symbol Grpd : TYPE;
injective symbol П„ : Grpd вҶ’ TYPE;
builtin "T" вү” П„;
builtin "Prop" вү” Grpd;
builtin "P" вү” П„;

constant symbol = : О  [a: Grpd], П„ a вҶ’ П„ a вҶ’ Grpd;
notation = infix 10;

constant symbol eq_refl : О  [a: Grpd], О  x: П„ a, П„ (x = x);

symbol ind_eq : О  [a: Grpd], О  [x: П„ a], О  [y: П„ a],
  П„ (x = y) вҶ’ О  p: (П„ a вҶ’ Grpd), П„ (p y) вҶ’ П„ (p x);
rule ind_eq (eq_refl $x) $p $u вҶӘ $u;

symbol eq_trans : О  [a : Grpd], О  [x : П„ a], О  [y : П„ a], О  [z : П„ a],
  П„ (x = y) вҶ’ П„ (y = z) вҶ’ П„ (x = z)
вү” О» a x y z p q, ind_eq p (О» t : П„ a, t = z) q;

builtin "eq"    вү” =;
builtin "refl"  вү” eq_refl;
builtin "eqind" вү” ind_eq;

inductive unit : TYPE вү” | tt : unit;

constant symbol Unit_grpd : Grpd;
rule П„ Unit_grpd вҶӘ unit;

inductive nat : TYPE вү”
| zero : nat
| succ : nat вҶ’ nat;

// -------------------------------------------------------------------------------------------------
// 1. Core categories
// -------------------------------------------------------------------------------------------------

constant symbol Cat : TYPE;

symbol Obj : Cat вҶ’ Grpd;

injective symbol Hom_cat : О  (A : Cat) (X_A Y_A : П„ (Obj A)), Cat;

symbol Hom (A : Cat) (X_A Y_A : П„ (Obj A)) : Grpd
вү” Obj (Hom_cat A X_A Y_A);

/*
  Inference-helper policy:
  These unification rules are local elaboration aids for chosen heads such as
  `Hom_cat`, `Functor_cat`, and `Transf_cat`. They should be read as controlled
  "associativity of Obj" hints, not as global semantic injectivity claims for
  arbitrary category constructors.
*/
unif_rule Obj (Hom_cat $A $X $Y) вүЎ Obj (Hom_cat $A' $X' $Y') вҶӘ [ $A вүЎ $A'; $X вүЎ $X'; $Y вүЎ $Y' ];
unif_rule Hom $A $X $Y вүЎ Hom $A' $X' $Y' вҶӘ [ $A вүЎ $A'; $X вүЎ $X'; $Y вүЎ $Y' ];

injective symbol id : О  (A : Cat), О  (X_A: П„ (Obj A)), П„ (Hom A X_A X_A);

symbol comp_fapp0 : О  [A : Cat], О  [X_A Y_A : П„ (Obj A)], О  [Z_A: П„ (Obj A)],
  О  (g: П„ (Hom A Y_A Z_A)), О  (f: П„ (Hom A X_A Y_A)),
  П„ (Hom A X_A Z_A);

injective symbol Op_cat : Cat вҶ’ Cat;
rule Op_cat (Op_cat $A) вҶӘ $A;
rule Obj (Op_cat $A) вҶӘ Obj $A;
rule Hom_cat (Op_cat $A) $X $Y вҶӘ Hom_cat $A $Y $X;
rule @id (Op_cat $A) $X вҶӘ @id $A $X;
rule @comp_fapp0 (Op_cat $A) $X $Y $Z $g $f вҶӘ @comp_fapp0 $A $Z $Y $X $f $g;

// Path categories internalize HoTT equality as a groupoidal category.
injective symbol Path_cat : Grpd вҶ’ Cat;
rule Obj (Path_cat $A) вҶӘ $A;
rule Hom_cat (Path_cat $A) $x $y вҶӘ Path_cat ($x = $y);
rule @id (Path_cat $A) $x вҶӘ eq_refl $x;
rule @comp_fapp0 (Path_cat $A) $x $y $z $q $p вҶӘ eq_trans $p $q;
rule Op_cat (Path_cat $A) вҶӘ Path_cat $A;

symbol Core_cat (C : Cat) : Cat вү” Path_cat (Obj C);

assert [A : Grpd] вҠў Obj (Path_cat A) вүЎ A;
assert [A : Grpd] (x y : П„ A) вҠў Hom_cat (Path_cat A) x y вүЎ Path_cat (x = y);
assert [A : Grpd] (x : П„ A) вҠў @id (Path_cat A) x вүЎ eq_refl x;
assert [A : Grpd] (x y z : П„ A) (p : П„ (x = y)) (q : П„ (y = z)) вҠў
  @comp_fapp0 (Path_cat A) x y z q p вүЎ eq_trans p q;

// -------------------------------------------------------------------------------------------------
// 2. Ordinary functors and universe categories
// -------------------------------------------------------------------------------------------------

symbol Functor_cat : О  (A B : Cat), Cat;

symbol Functor (A B : Cat) : Grpd
вү” Obj (Functor_cat A B);

unif_rule Functor $A $B вүЎ Functor $A' $B' вҶӘ [ $A вүЎ $A'; $B вүЎ $B' ];
unif_rule Obj (Functor_cat $A $B) вүЎ Obj (Functor_cat $A' $B') вҶӘ [ $A вүЎ $A'; $B вүЎ $B' ];

symbol fapp0 : О  [A B : Cat], О  (F_AB : П„ (Functor A B)),
  П„ (Obj A) вҶ’ П„ (Obj B);

symbol fapp1_func : О  [A B : Cat], О  (F_AB : П„ (Functor A B)),
  О  [X_A Y_A : П„ (Obj A)],
  П„ (Functor (Hom_cat A X_A Y_A) (Hom_cat B (fapp0 F_AB X_A) (fapp0 F_AB Y_A)));

symbol fapp1_fapp0 : О  [A B : Cat], О  (F_AB : П„ (Functor A B)),
  О  [X_A Y_A : П„ (Obj A)],
  О  (f : П„ (Hom A X_A Y_A)),
  П„ (Hom B (fapp0 F_AB X_A) (fapp0 F_AB Y_A));

rule fapp0 (fapp1_func $F_AB) $f вҶӘ fapp1_fapp0 $F_AB $f;

constant symbol Grpd_grpd : Grpd;
constant symbol Cat_grpd  : Grpd;
rule П„ Grpd_grpd вҶӘ Grpd;
rule П„ Cat_grpd  вҶӘ Cat;

constant symbol Grpd_cat : Cat;
rule Obj Grpd_cat вҶӘ Grpd_grpd;
rule П„ (Obj (Hom_cat Grpd_cat $X $Y)) вҶӘ (П„ $X вҶ’ П„ $Y);

constant symbol Cat_cat : Cat;
rule Obj Cat_cat вҶӘ Cat_grpd;
rule Hom_cat Cat_cat $X $Y вҶӘ Functor_cat $X $Y;

assert вҠў П„ (Obj Grpd_cat) вүЎ Grpd;
assert вҠў П„ (Obj Cat_cat) вүЎ Cat;
assert (A B : Cat) вҠў Hom_cat Cat_cat A B вүЎ Functor_cat A B;

// Directed Cat-valued families are canonical Cat-valued functors.
symbol Catd_cat (K : Cat) : Cat;

symbol Catd (K : Cat) : Grpd
вү” Obj (Catd_cat K);

rule Functor_cat $K Cat_cat вҶӘ @Catd_cat $K;

unif_rule Catd $K вүЎ Catd $K' вҶӘ [ $K вүЎ $K' ];
unif_rule Obj (@Catd_cat $K) вүЎ Obj (@Catd_cat $K') вҶӘ [ $K вүЎ $K' ];

// Natural families of functors between directed Cat-valued families.
symbol Functord_cat [K : Cat] (E D : П„ (Catd K)) : Cat;

symbol Functord [K : Cat] (E D : П„ (Catd K)) : Grpd
вү” Obj (@Functord_cat K E D);

unif_rule Functord $E $D вүЎ Functord $E' $D' вҶӘ [ $E вүЎ $E'; $D вүЎ $D' ];
unif_rule Obj (@Functord_cat $K $E $D) вүЎ Obj (@Functord_cat $K' $E' $D')
  вҶӘ [ $K вүЎ $K'; $E вүЎ $E'; $D вүЎ $D' ];

rule Hom_cat (@Catd_cat $K) $E $D вҶӘ @Functord_cat $K $E $D;

symbol id_funcd [K : Cat] [E : П„ (Catd K)] : П„ (Functord E E);
rule @id (@Catd_cat $K) $E вҶӘ @id_funcd $K $E;

symbol comp_catd_fapp0 [K : Cat] [E D : П„ (Catd K)] [C : П„ (Catd K)]
  (FF : П„ (Functord D C)) (GG : П„ (Functord E D)) : П„ (Functord E C);

// Stable displayed-composition head, parallel to `comp_cat_fapp0`.
rule @comp_fapp0 (@Catd_cat $K) $E $D $C $FF $GG
  вҶӘ @comp_catd_fapp0 $K $E $D $C $FF $GG;

rule @comp_catd_fapp0 $K $E $E $C $FF (@id_funcd $K $E)
  вҶӘ $FF;
rule @comp_catd_fapp0 $K $E $D $D (@id_funcd $K $D) $GG
  вҶӘ $GG;


// Natural families of transformations, i.e. modifications between
// directed-family functors.
symbol Transfd_cat [K : Cat] [E D : П„ (Catd K)]
  (FF GG : П„ (Functord E D)) : Cat;

symbol Transfd [K : Cat] [E D : П„ (Catd K)]
  (FF GG : П„ (Functord E D)) : Grpd
вү” Obj (@Transfd_cat K E D FF GG);

unif_rule Transfd $FF $GG вүЎ Transfd $FF' $GG' вҶӘ [ $FF вүЎ $FF'; $GG вүЎ $GG' ];
unif_rule Obj (@Transfd_cat $K $E $D $FF $GG) вүЎ Obj (@Transfd_cat $K' $E' $D' $FF' $GG')
  вҶӘ [ $K вүЎ $K'; $E вүЎ $E'; $D вүЎ $D'; $FF вүЎ $FF'; $GG вүЎ $GG' ];

rule Hom_cat (@Functord_cat $K $E $D) $FF $GG
  вҶӘ @Transfd_cat $K $E $D $FF $GG;

// Stable displayed identity. The ordinary identity at a displayed-functor
// category folds here when that category is still visible; terminal-source
// section cases can use this head directly after Functord_cat contracts to
// Pi_cat.
symbol id_transfd [K : Cat] [E D : П„ (Catd K)]
  (FF : П„ (Functord E D))
  : П„ (@Transfd K E D FF FF);

rule @id (@Functord_cat $K $E $D) $FF
  вҶӘ @id_transfd $K $E $D $FF;

assert [K : Cat] вҠў Functor_cat K Cat_cat вүЎ Catd_cat K;
assert [K : Cat] (E D : П„ (Catd K)) вҠў
  Hom_cat (Catd_cat K) E D вүЎ Functord_cat E D;
assert [K : Cat] [E D : П„ (Catd K)] (FF GG : П„ (Functord E D)) вҠў
  Hom_cat (Functord_cat E D) FF GG вүЎ Transfd_cat FF GG;
assert [K : Cat] (E D : П„ (Catd K)) (FF : П„ (Functord E D)) вҠў
  @id (@Functord_cat K E D) FF
    вүЎ @id_transfd K E D FF;

symbol id_func [A: Cat] : П„ (Functor A A);
rule @id Cat_cat $A вҶӘ @id_func $A;
rule fapp0 (@id_func $A) $xA вҶӘ $xA;

symbol comp_cat_fapp0 [A B : Cat] [C : Cat]
  (F : П„ (Functor B C)) (G : П„ (Functor A B)) : П„ (Functor A C);

rule @comp_fapp0 Cat_cat $A $B $C $F $G вҶӘ @comp_cat_fapp0 $A $B $C $F $G;
rule @fapp0 $A $C (@comp_cat_fapp0 $A $B $C $F $G) $x вҶӘ @fapp0 $B $C $F (@fapp0 $A $B $G $x);

rule @comp_fapp0 $A $Y $Y $Z $g (@id $A $Y) вҶӘ $g;
rule @comp_fapp0 $A $X $Z $Z (@id $A $Z) $f вҶӘ $f;

injective symbol Op_func : О  [A B : Cat],
  П„ (Functor A B) вҶ’ П„ (Functor (Op_cat A) (Op_cat B));

rule Op_func (@Op_func $A $B $F) вҶӘ $F;
rule @fapp0 _ _ (@Op_func $A $B $F) $xA вҶӘ @fapp0 $A $B $F $xA;
rule @fapp1_func _ _ (@Op_func $A $B $F) $X $Y вҶӘ @fapp1_func $A $B $F $Y $X;
rule @Op_func _ _ (@id_func $A) вҶӘ @id_func (Op_cat $A);
rule @Op_func _ _ (@comp_cat_fapp0 $A $B $C $F $G)
  вҶӘ comp_cat_fapp0 (Op_func $F) (Op_func $G);

// Terminal category and points-as-functors are needed to derive unary homs from binary hom.
constant symbol Terminal_cat : Cat;
rule Op_cat Terminal_cat вҶӘ Terminal_cat;
rule Obj Terminal_cat вҶӘ Unit_grpd;
rule Hom_cat Terminal_cat _ _ вҶӘ Terminal_cat;

constant symbol Terminal_obj : П„ (Obj Terminal_cat);
rule @id Terminal_cat _ вҶӘ Terminal_obj;
rule @comp_fapp0 Terminal_cat _ _ _ _ _ вҶӘ Terminal_obj;

injective symbol Terminal_func : О  (A : Cat), П„ (Functor A Terminal_cat);
rule @Op_func _ _ (@Terminal_func $A) вҶӘ @Terminal_func (Op_cat $A);

injective symbol Obj_func : О  [Y : Cat], П„ (Obj Y) вҶ’ П„ (Functor Terminal_cat Y);
rule fapp0 (Obj_func $y) _ вҶӘ $y;
rule @Op_func _ _ (@Obj_func $Y $y) вҶӘ @Obj_func (Op_cat $Y) $y;

symbol fapp0_func : О  [A B : Cat],
  П„ (Obj A) вҶ’ П„ (Functor (Functor_cat A B) B);
rule fapp0 (fapp0_func $x) $F вҶӘ fapp0 $F $x;

// Constant functor, used by constant directed families without capping the
// hom-action too early.
symbol Const_func [A B : Cat] (b : П„ (Obj B)) : П„ (Functor A B);
rule @fapp0 $A $B (@Const_func $A $B $b) $_ вҶӘ $b;
rule @fapp1_func $A $B (@Const_func $A $B $b) $x $y
  вҶӘ @Const_func
      (Hom_cat $A $x $y)
      (Hom_cat $B $b $b)
      (@id $B $b);
rule @fapp1_fapp0 $A $B (@Const_func $A $B $b) $x $y $_ вҶӘ @id $B $b;
rule @Op_func $A $B (@Const_func $A $B $b)
  вҶӘ @Const_func (Op_cat $A) (Op_cat $B) $b;
rule @comp_cat_fapp0 $A $B $C $F (@Const_func $A $B $b)
  вҶӘ @Const_func $A $C (@fapp0 $B $C $F $b);
rule @comp_cat_fapp0 $A $B $C (@Const_func $B $C $c) $G
  вҶӘ @Const_func $A $C $c;

// Internalized opposite as a functor in Cat: A |-> A^op.
constant symbol op : П„ (Functor Cat_cat Cat_cat);
rule @fapp0 Cat_cat Cat_cat op $A вҶӘ Op_cat $A;
rule @fapp1_fapp0 Cat_cat Cat_cat op $A $B $F вҶӘ @Op_func $A $B $F;

// Internalized ordinary functor-category formation.
symbol Functor_cat_func : П„ (Functor (Op_cat Cat_cat) (Functor_cat Cat_cat Cat_cat));

symbol Functor_cat_fapp0_func (A : Cat) : П„ (Functor Cat_cat Cat_cat);

rule @fapp0 _ _ Functor_cat_func $A
  вҶӘ Functor_cat_fapp0_func $A;
rule @fapp0 Cat_cat Cat_cat (Functor_cat_fapp0_func $A) $B
  вҶӘ Functor_cat $A $B;

// Curried postcomposition in Cat, used to build constructor pipelines.
symbol comp_cat_cov_func : О  [X Y Z : Cat],
  О  (G : П„ (Functor Y Z)),
  П„ (Functor (Functor_cat X Y) (Functor_cat X Z));

rule fapp0 (@comp_cat_cov_func $X $Y $Z $G) $F
  вҶӘ comp_cat_fapp0 $G $F;

symbol op_val_func [Z : Cat] : П„ (Functor (Catd_cat Z) (Catd_cat Z))
вү” @comp_cat_cov_func Z Cat_cat Cat_cat op;

// -------------------------------------------------------------------------------------------------
// 3. Curried internal hom
// -------------------------------------------------------------------------------------------------

symbol hom_ [A B : Cat] (F : П„ (Functor B A)) (W : П„ (Obj A))
  : П„ (Functor B Cat_cat);
rule @fapp0 $B Cat_cat (@hom_ $A $B $F $W) $y
  вҶӘ Hom_cat $A $W (@fapp0 $B $A $F $y);

// Ordinary hom-action computes by postcomposition:
// ((Hom_A(W,F-))_1 f)_0 g вҶӘ (F f) вҲҳ g.
rule fapp0 (@fapp1_fapp0 $B Cat_cat (@hom_ $A $B $F $W) $X $Y $f) $g
  вҶӘ comp_fapp0 (fapp1_fapp0 $F $f) $g;

symbol hom_con [A : Cat] (W : П„ (Obj A)) [B : Cat] (F : П„ (Functor B A))
  : П„ (Functor (Op_cat B) Cat_cat);
rule @hom_con $A $W $B $F
  вҶӘ @hom_ (Op_cat $A) (Op_cat $B) (@Op_func $B $A $F) $W;

symbol hom_int [A B : Cat] (F : П„ (Functor B A))
  : П„ (Functor (Op_cat A) (Catd_cat B));

rule @fapp0 _ _ (@hom_int $A $B $F) $W
  вҶӘ @hom_ $A $B $F $W;

assert [A B : Cat] (F : П„ (Functor B A)) (W : П„ (Obj A)) (y : П„ (Obj B)) вҠў
  @fapp0 B Cat_cat (@hom_ A B F W) y вүЎ Hom_cat A W (@fapp0 B A F y);

assert [A B : Cat] (F : П„ (Functor B A)) (W : П„ (Obj A)) (x : П„ (Obj (Op_cat B))) вҠў
  @fapp0 (Op_cat B) Cat_cat (@hom_con A W B F) x вүЎ Hom_cat A (@fapp0 B A F x) W;

assert [A B : Cat] (F : П„ (Functor B A)) (W : П„ (Obj (Op_cat A))) вҠў
  @fapp0 (Op_cat A) (Catd_cat B) (@hom_int A B F) W
    вүЎ @hom_ A B F W;

assert [A B : Cat] (F : П„ (Functor B A)) (X : П„ (Obj (Op_cat A))) (Y : П„ (Obj B)) вҠў
  @fapp0 B Cat_cat (@fapp0 (Op_cat A) (Catd_cat B) (@hom_int A B F) X) Y
    вүЎ Hom_cat A X (fapp0 F Y);

assert [A B : Cat] (F : П„ (Functor B A)) (W : П„ (Obj A))
  (X Y : П„ (Obj B)) (f : П„ (Hom B X Y)) (g : П„ (Hom A W (fapp0 F X))) вҠў
  fapp0 (@fapp1_fapp0 B Cat_cat (@hom_ A B F W) X Y f) g
    вүЎ @comp_fapp0 A W (fapp0 F X) (fapp0 F Y)
        (fapp0 (@fapp1_func B A F X Y) f) g;

// -------------------------------------------------------------------------------------------------
// 4. Encoded Sigma types for object layers
// -------------------------------------------------------------------------------------------------

inductive П„ОЈ_ [a : Grpd] (P : П„ a вҶ’ Grpd) : TYPE вү”
| Struct_sigma [a P] : О  (sigma_Fst : П„ a) (sigma_Snd : П„ (P sigma_Fst)), @П„ОЈ_ a P;
notation П„ОЈ_ quantifier;

constant symbol ОЈ_ [a : Grpd] (P : П„ a вҶ’ Grpd) : Grpd;
notation ОЈ_ quantifier;
rule П„ (ОЈ_ $P) вҶӘ П„ОЈ_ $P;

injective symbol sigma_Fst [a P] (s : @П„ОЈ_ a P) : П„ a;
rule sigma_Fst (Struct_sigma $1 $2) вҶӘ $1;

injective symbol sigma_Snd [a P] (s : @П„ОЈ_ a P) : П„ (P (sigma_Fst s));
rule sigma_Snd (Struct_sigma $1 $2) вҶӘ $2;

// -------------------------------------------------------------------------------------------------
// 5. Ordinary transfors
// -------------------------------------------------------------------------------------------------

symbol Transf_cat : О  [A B : Cat], О  (F G : П„ (Functor A B)), Cat;

symbol Transf [A B : Cat] (F G : П„ (Functor A B)) : Grpd
вү” Obj (@Transf_cat A B F G);

// Controlled Obj-inversion for transformation categories. This is the
// emdash2 helper that lets projection rules keep source/target functors
// implicit, e.g. `@tapp0_fapp0 ... _ _ ...`, without forcing reducible
// compound family expressions into rewrite-rule LHSs.
unif_rule Obj (@Transf_cat $A $B $F $G) вүЎ Obj (@Transf_cat $A' $B' $F' $G')
  вҶӘ [ $A вүЎ $A'; $B вүЎ $B'; $F вүЎ $F'; $G вүЎ $G' ];
unif_rule Transf $F $G вүЎ Transf $F' $G' вҶӘ [ $F вүЎ $F'; $G вүЎ $G' ];

rule Hom_cat (Functor_cat _ _) $F $G вҶӘ Transf_cat $F $G;
rule @Transf_cat $K Cat_cat $E $D вҶӘ @Functord_cat $K $E $D;

symbol tapp0_func : О  [A B : Cat], О  [F G : П„ (Functor A B)],
  О  (Y : П„ (Obj A)),
  П„ (Functor (Transf_cat F G) (Hom_cat B (fapp0 F Y) (fapp0 G Y)));

symbol tapp0_fapp0 : О  [A B : Cat], О  [F G : П„ (Functor A B)],
  О  (Y : П„ (Obj A)),
  О  (Пө : П„ (Obj (Transf_cat F G))),
  П„ (Hom B (fapp0 F Y) (fapp0 G Y));

/*
  Design note: `tapp0_fapp0` is a primitive projection head, not a
  definitional abbreviation.  This follows emdash2: the head must remain
  visible so later rules can attach component computations directly to it.
*/
rule fapp0 (@tapp0_func $A $B $F $G $Y) $Пө
  вҶӘ @tapp0_fapp0 $A $B $F $G $Y $Пө;

rule @tapp0_fapp0 $A $B $F $F $Y (@id (Functor_cat $A $B) $F)
  вҶӘ @id $B (@fapp0 $A $B $F $Y);

rule @tapp0_fapp0 $K Cat_cat $E $E $Y (@id_funcd $K $E)
  вҶӘ @id_func (@fapp0 $K Cat_cat $E $Y);

rule @tapp0_fapp0 $A $B $F $H $Y (@comp_fapp0 (Functor_cat $A $B) $F $G $H $О· $Пө)
  вҶӘ @comp_fapp0
      $B
      (@fapp0 $A $B $F $Y)
      (@fapp0 $A $B $G $Y)
      (@fapp0 $A $B $H $Y)
      (@tapp0_fapp0 $A $B $G $H $Y $О·)
      (@tapp0_fapp0 $A $B $F $G $Y $Пө);

symbol tapp1_fapp0 : О  [A B : Cat], О  [F G : П„ (Functor A B)],
  О  [X Y : П„ (Obj A)],
  О  (Пө : П„ (Obj (Transf_cat F G))),
  О  (f : П„ (Hom A X Y)),
  П„ (Hom B (fapp0 F X) (fapp0 G Y));

/*
  More-internal ordinary hom-action.

  This ports the settled v2 core without also committing to the later
  hom-action packaging heads.  The functor sends a transfor Пө : F вҮ’ G to the
  internalized action

    hom_int(id_A) вҮ’ hom_int(G) вҲҳ F^op.
*/
symbol tapp1_int_func_transf : О  [A B : Cat], О  [F G : П„ (Functor A B)],
  П„ (Functor
      (Transf_cat F G)
      (Transf_cat
        (@hom_int A A (@id_func A))
        (@comp_cat_fapp0
          (Op_cat A)
          (Op_cat B)
          (Catd_cat A)
          (@hom_int B A G)
          (@Op_func A B F))));

symbol tapp1_int_fapp0_transf : О  [A B : Cat], О  [F G : П„ (Functor A B)],
  О  (Пө : П„ (Transf F G)),
  П„ (Transf
      (@hom_int A A (@id_func A))
      (@comp_cat_fapp0
        (Op_cat A)
        (Op_cat B)
        (Catd_cat A)
        (@hom_int B A G)
        (@Op_func A B F)));

rule fapp0 (@tapp1_int_func_transf $A $B $F $G) $Пө
  вҶӘ @tapp1_int_fapp0_transf $A $B $F $G $Пө;

symbol tapp1_int_fapp1_func_transf : О  [A B : Cat], О  [F G : П„ (Functor A B)],
  О  (Пө Пө' : П„ (Transf F G)),
  П„ (Functor
      (Hom_cat (@Transf_cat A B F G) Пө Пө')
      (Hom_cat
        (@Transf_cat
          (Op_cat A)
          (Catd_cat A)
          (@hom_int A A (@id_func A))
          (@comp_cat_fapp0
            (Op_cat A)
            (Op_cat B)
            (Catd_cat A)
            (@hom_int B A G)
            (@Op_func A B F)))
        (@tapp1_int_fapp0_transf A B F G Пө)
        (@tapp1_int_fapp0_transf A B F G Пө')));

rule @fapp1_func _ _ (@tapp1_int_func_transf $A $B $F $G) $Пө $Пө'
  вҶӘ @tapp1_int_fapp1_func_transf $A $B $F $G $Пө $Пө';

symbol fapp1_int_transf : О  [A B : Cat], О  (F : П„ (Functor A B)),
  П„ (Transf
      (@hom_int A A (@id_func A))
      (@comp_cat_fapp0
        (Op_cat A)
        (Op_cat B)
        (Catd_cat A)
        (@hom_int B A F)
        (@Op_func A B F)));

rule @tapp1_int_fapp0_transf $A $B $F $F (id (Functor_cat $A $B) $F)
  вҶӘ @fapp1_int_transf $A $B $F;

assert [A B : Cat] (F G : П„ (Functor A B)) (Пө : П„ (Transf F G)) вҠў
  fapp0 (@tapp1_int_func_transf A B F G) Пө
    вүЎ @tapp1_int_fapp0_transf A B F G Пө;

assert [A B : Cat] (F G : П„ (Functor A B))
  (Пө Пө' : П„ (Transf F G)) вҠў
  @fapp1_func _ _ (@tapp1_int_func_transf A B F G) Пө Пө'
    вүЎ @tapp1_int_fapp1_func_transf A B F G Пө Пө';

assert [A B : Cat] (F : П„ (Functor A B)) вҠў
  @tapp1_int_fapp0_transf A B F F (id (Functor_cat A B) F)
    вүЎ @fapp1_int_transf A B F;

assert [A B : Cat] (F : П„ (Functor A B)) вҠў
  fapp0 (@tapp1_int_func_transf A B F F) (id (Functor_cat A B) F)
    вүЎ @fapp1_int_transf A B F;

// -------------------------------------------------------------------------------------------------
// 6. Directed Cat-valued family constructors
// -------------------------------------------------------------------------------------------------

symbol Fibre_cat [K : Cat] (E : П„ (Catd K)) (k : П„ (Obj K)) : Cat
вү” @fapp0 K Cat_cat E k;

// Directed-family inference helper for surface notation `E[x]`.
unif_rule Obj (Fibre_cat $E $k) вүЎ Obj (Fibre_cat $E' $k') вҶӘ [ $E вүЎ $E'; $k вүЎ $k' ];

symbol Pullback_catd [A B : Cat] (E : П„ (Catd B)) (F : П„ (Functor A B))
  : П„ (Catd A)
вү” @comp_cat_fapp0 A B Cat_cat E F;

symbol Const_catd (K : Cat) (A : Cat) : П„ (Catd K);

rule @fapp0 $K Cat_cat (@Const_catd $K $A) $_ вҶӘ $A;
rule @hom_ $A $B (@Const_func $B $A $u) $w
  вҶӘ @Const_catd $B (Hom_cat $A $w $u);

rule @fapp1_func $K Cat_cat (@Const_catd $K $A) $x $y
  вҶӘ @Const_func
      (Hom_cat $K $x $y)
      (Functor_cat $A $A)
      (@id_func $A);

rule @fapp1_fapp0 $K Cat_cat (@Const_catd $K $A) $x $y $_ вҶӘ @id_func $A;

symbol Terminal_catd (K : Cat) : П„ (Catd K)
вү” @Const_catd K Terminal_cat;

symbol Op_catd [K : Cat] (E : П„ (Catd K)) : П„ (Catd K);

rule @fapp0 $K Cat_cat (@Op_catd $K $E) $k
  вҶӘ Op_cat (@fapp0 $K Cat_cat $E $k);

rule @Op_catd $K (@Op_catd $K $E) вҶӘ $E;
rule @Op_catd $K (@Const_catd $K $A) вҶӘ @Const_catd $K (Op_cat $A);

symbol Op_funcd [K : Cat] [E D : П„ (Catd K)]
  (FF : П„ (Functord E D))
  : П„ (Functord (Op_catd E) (Op_catd D));

rule @Op_funcd $K (@Op_catd $K $E) (@Op_catd $K $D) (@Op_funcd $K $E $D $FF)
  вҶӘ $FF;

rule @Op_funcd $K $E $E (@id_funcd $K $E)
  вҶӘ @id_funcd $K (@Op_catd $K $E);

// Pointwise projection of displayed opposite. The source/target family slots
// are deliberately implicit; the explicit `Op_funcd` argument is the
// discriminator.
rule @tapp0_fapp0
      $K
      Cat_cat
      _
      _
      $x
      (@Op_funcd $K $E $D $FF)
  вҶӘ @Op_func
      (Fibre_cat $E $x)
      (Fibre_cat $D $x)
      (@tapp0_fapp0 $K Cat_cat $E $D $x $FF);

symbol Pi_cat [K : Cat] (E : П„ (Catd K)) : Cat;

rule @Functord_cat $K (@Const_catd $K Terminal_cat) $E вҶӘ @Pi_cat $K $E;
rule @Pi_cat $K (@Const_catd $K $A) вҶӘ Functor_cat $K $A;

unif_rule @Pi_cat $K $E вүЎ @Pi_cat $K' $E' вҶӘ [ $K вүЎ $K'; $E вүЎ $E' ];
unif_rule Obj (@Pi_cat $K $E) вүЎ Obj (@Pi_cat $K' $E') вҶӘ [ $K вүЎ $K'; $E вүЎ $E' ];

symbol Pi_func (K : Cat) : П„ (Functor (Catd_cat K) Cat_cat);
rule @fapp0 (@Catd_cat $K) Cat_cat (@Pi_func $K) $E
  вҶӘ @Pi_cat $K $E;

symbol piapp0_func [K : Cat] (E : П„ (Catd K)) (k : П„ (Obj K))
  : П„ (Functor (Pi_cat E) (Fibre_cat E k))
вү” @comp_cat_fapp0
     (@Transf_cat K Cat_cat (@Const_catd K Terminal_cat) E)
     (Functor_cat Terminal_cat (Fibre_cat E k))
     (Fibre_cat E k)
     (@fapp0_func Terminal_cat (Fibre_cat E k) Terminal_obj)
     (@tapp0_func K Cat_cat (@Const_catd K Terminal_cat) E k);

symbol piapp0 : О  [K : Cat], О  [E : П„ (Catd K)],
  О  (s : П„ (Obj (Pi_cat E))),
  О  (k : П„ (Obj K)),
  П„ (Obj (Fibre_cat E k))
вү” О» K E s k, @fapp0 (Pi_cat E) (Fibre_cat E k) (@piapp0_func K E k) s;

// Fibre transport is introduced later as a defined projection from the
// reordered functor `fib_cov_tapp0_func`. v3.2 deliberately avoids the v3.1
// generic strict identity/composition transport rewrites for arbitrary
// Cat-valued families.

// -------------------------------------------------------------------------------------------------
// 7. Directed Sigma categories and maps between totals
// -------------------------------------------------------------------------------------------------

symbol Sigma_cat [K : Cat] (E : П„ (Catd K)) : Cat;

symbol Sigma_func (K : Cat) : П„ (Functor (Catd_cat K) Cat_cat);
rule @fapp0 (@Catd_cat $K) Cat_cat (@Sigma_func $K) $E
  вҶӘ @Sigma_cat $K $E;

rule П„ (Obj (@Sigma_cat $K $E))
  вҶӘ `П„ОЈ_ k : П„ (Obj $K), Obj (Fibre_cat $E k);

injective symbol Sigma_proj1_func [K : Cat] (E : П„ (Catd K))
  : П„ (Functor (Sigma_cat E) K);

rule fapp0 (Sigma_proj1_func $E) (Struct_sigma $k $u) вҶӘ $k;

symbol sigma_map_func [K : Cat] [E D : П„ (Catd K)]
  (О· : П„ (Functord E D))
  : П„ (Functor (Sigma_cat E) (Sigma_cat D));

rule @fapp1_fapp0 (@Catd_cat $K) Cat_cat (@Sigma_func $K) $E $D $О·
  вҶӘ @sigma_map_func $K $E $D $О·;

rule @fapp0 _ _
      (@sigma_map_func $K $E $D $О·)
      (Struct_sigma $k $u)
  вҶӘ @Struct_sigma
      (Obj $K)
      (О» kk : П„ (Obj $K), Obj (Fibre_cat $D kk))
      $k
      (@fapp0 (Fibre_cat $E $k) (Fibre_cat $D $k)
        (@tapp0_fapp0 $K Cat_cat $E $D $k $О·) $u);

rule @comp_cat_fapp0 _ _ _
      (@Sigma_proj1_func $K $D)
      (@sigma_map_func $K $E $D $О·)
  вҶӘ @Sigma_proj1_func $K $E;

// -------------------------------------------------------------------------------------------------
// 8. Mixed-variance family functor
// -------------------------------------------------------------------------------------------------

symbol Functor_catd [K : Cat]
  (A : П„ (Catd (Op_cat K)))
  (B : П„ (Catd K))
  : П„ (Catd K);

rule @fapp0 $K Cat_cat (@Functor_catd $K $A $B) $k
  вҶӘ Functor_cat (Fibre_cat $A $k) (Fibre_cat $B $k);

symbol Functor_catd_mix_func (K : Cat)
  : П„ (Functor
      (Op_cat (Catd_cat (Op_cat K)))
      (Functor_cat (Catd_cat K) (Catd_cat K)));

symbol Functor_catd_mix_fapp0_func [K : Cat]
  (A : П„ (Catd (Op_cat K)))
  : П„ (Functor (Catd_cat K) (Catd_cat K));

rule @fapp0 _ _
      (@Functor_catd_mix_func $K) $A
  вҶӘ @Functor_catd_mix_fapp0_func $K $A;

rule @fapp0 _ _ (@Functor_catd_mix_fapp0_func $K $A) $B
  вҶӘ @Functor_catd $K $A $B;

symbol Hom_catd [K : Cat]
  (E : П„ (Catd K))
  (X : П„ (Obj (Pi_cat (Op_catd E))))
  (Y : П„ (Obj (Pi_cat E)))
  : П„ (Catd K);

rule @fapp0 $K Cat_cat (@Hom_catd $K $E $X $Y) $k
  вҶӘ Hom_cat
      (Fibre_cat $E $k)
      (@piapp0 $K (@Op_catd $K $E) $X $k)
      (@piapp0 $K $E $Y $k);

symbol Transf_catd [K : Cat]
  (A : П„ (Catd (Op_cat K)))
  (B : П„ (Catd K))
  (FF : П„ (Obj (Pi_cat (Op_catd (Functor_catd A B)))))
  (GG : П„ (Obj (Pi_cat (Functor_catd A B))))
  : П„ (Catd K);

rule @fapp0 $K Cat_cat (@Transf_catd $K $A $B $FF $GG) $k
  вҶӘ Transf_cat
      (@piapp0 $K (@Op_catd $K (@Functor_catd $K $A $B)) $FF $k)
      (@piapp0 $K (@Functor_catd $K $A $B) $GG $k);

rule @Hom_catd $K (@Const_catd $K Cat_cat) $X $Y
  вҶӘ @Functor_catd $K (@Op_func $K (Op_cat Cat_cat) $X) $Y;

rule @Hom_catd $K (@Functor_catd $K $A $B) $FF $GG
  вҶӘ @Transf_catd $K $A $B $FF $GG;

// -------------------------------------------------------------------------------------------------
// 9. Internal edge and presheaf-family classifiers
// -------------------------------------------------------------------------------------------------

symbol Edge_catd_fam [Z : Cat]
  : П„ (Functor (Op_cat Z) (Catd_cat Z))
вү” @comp_cat_fapp0
     (Op_cat Z)
     (Functor_cat Z Cat_cat)
     (Functor_cat Z Cat_cat)
     (@op_val_func Z)
     (@hom_int Z Z (@id_func Z));

symbol Presheaf_catd_func (K : Cat)
  : П„ (Functor
      (Op_cat (Catd_cat (Op_cat K)))
      (Catd_cat K))
вү” @comp_cat_fapp0
     (Op_cat (Catd_cat (Op_cat K)))
     (Functor_cat (Catd_cat K) (Catd_cat K))
     (Catd_cat K)
     (@fapp0_func (Catd_cat K) (Catd_cat K) (@Const_catd K Cat_cat))
     (@Functor_catd_mix_func K);

symbol HomPresheaf_catd [Z : Cat]
  : П„ (Functor Z (Catd_cat (Op_cat Z)))
вү” @comp_cat_fapp0
     Z
     (Op_cat (Catd_cat Z))
     (Catd_cat (Op_cat Z))
     (@Presheaf_catd_func (Op_cat Z))
     (@Op_func (Op_cat Z) (Catd_cat Z) (@Edge_catd_fam Z));

// -------------------------------------------------------------------------------------------------
// 10. Directed homd target and internal homd category
// -------------------------------------------------------------------------------------------------

/*
  Homd architecture note:
  `Homd_source_catd`, `Homd_section_catd`, and `Homd_target_catd` name the
  intended source/target families for readability and assertions.  They are
  not used as required discriminants in the projection-rule LHSs below, because
  those positions are inferred implicit arguments and may reduce to canonical
  compound terms before matching.
*/

symbol Homd_source_catd [Z : Cat] (E : П„ (Catd Z))
  : П„ (Catd Z)
вү” @Op_catd Z E;

symbol Homd_section_catd [Z : Cat] (E : П„ (Catd Z))
  (x : П„ (Obj Z))
  : П„ (Catd (Op_cat Z))
вү” @Functor_catd
     (Op_cat Z)
     E
     (@fapp0 Z (Catd_cat (Op_cat Z)) (@HomPresheaf_catd Z) x);

symbol Homd_target_catd [Z : Cat] (E : П„ (Catd Z))
  : П„ (Catd Z)
вү” @comp_cat_fapp0
     Z
     (Catd_cat (Op_cat Z))
     Cat_cat
     (@comp_cat_fapp0
       (Catd_cat (Op_cat Z))
       (Catd_cat (Op_cat Z))
       Cat_cat
       (@Pi_func (Op_cat Z))
       (@fapp0
         (Op_cat (Catd_cat Z))
         (Functor_cat (Catd_cat (Op_cat Z)) (Catd_cat (Op_cat Z)))
         (@Functor_catd_mix_func (Op_cat Z))
         E))
     (@HomPresheaf_catd Z);

symbol Homd_cat [Z : Cat] (E : П„ (Catd Z)) : Cat
вү” @Transf_cat Z Cat_cat (@Homd_source_catd Z E) (@Homd_target_catd Z E);

symbol Homd [Z : Cat] (E : П„ (Catd Z)) : Grpd
вү” Obj (@Homd_cat Z E);

constant symbol homd_int : О  [Z : Cat], О  [D E : П„ (Catd Z)],
  О  (FF : П„ (Functord D E)),
  П„ (Functord (Op_catd E) (@Homd_target_catd Z D));

// -------------------------------------------------------------------------------------------------
// 11. Endpoint normal forms for Sigma homs
// -------------------------------------------------------------------------------------------------

symbol fib_cov_tapp0_func [K : Cat] (E : П„ (Catd K))
  [x y : П„ (Obj K)]
  (u : П„ (Obj (Fibre_cat E x)))
  : П„ (Functor (Hom_cat K x y) (Fibre_cat E y))
вү” @comp_cat_fapp0
     (Hom_cat K x y)
     (Functor_cat (Fibre_cat E x) (Fibre_cat E y))
     (Fibre_cat E y)
     (@fapp0_func (Fibre_cat E x) (Fibre_cat E y) u)
     (@fapp1_func K Cat_cat E x y);

symbol fib_cov_transf [K : Cat] (E : П„ (Catd K))
  (x : П„ (Obj K))
  (u : П„ (Obj (Fibre_cat E x)))
  : П„ (@Transf K Cat_cat (@hom_ K K (@id_func K) x) E);

symbol FibCov_target_catd [K : Cat] (E : П„ (Catd K)) : П„ (Catd K)
вү” @hom_con
    (@Catd_cat K)
    E
    (Op_cat K)
    (@hom_int K K (@id_func K));

symbol FibCov_cat [K : Cat] (E : П„ (Catd K)) : Cat
вү” @Transf_cat K Cat_cat E (@FibCov_target_catd K E);

symbol FibCov [K : Cat] (E : П„ (Catd K)) : Grpd
вү” Obj (@FibCov_cat K E);

constant symbol fib_cov_int : О  [K : Cat], О  (E : П„ (Catd K)), П„ (FibCov E);

symbol fib_cov_src_func [K : Cat] (E : П„ (Catd K))
  (x : П„ (Obj K))
  : П„ (Functor
      (Fibre_cat E x)
      (@Transf_cat K Cat_cat (@hom_ K K (@id_func K) x) E));

rule @tapp0_fapp0
      $K
      Cat_cat
      _
      _
      $x
      (@fib_cov_int $K $E)
  вҶӘ @fib_cov_src_func $K $E $x;

rule fapp0 (@fib_cov_src_func $K $E $x) $u
  вҶӘ @fib_cov_transf $K $E $x $u;

rule @tapp0_fapp0
      $K
      Cat_cat
      _
      _
      $y
      (@fib_cov_transf $K $E $x $u)
  вҶӘ @fib_cov_tapp0_func $K $E $x $y $u;

symbol fib_cov_tapp0_fapp0 [K : Cat] (E : П„ (Catd K))
  [x y : П„ (Obj K)]
  (f : П„ (Hom K x y))
  (u : П„ (Obj (Fibre_cat E x)))
  : П„ (Obj (Fibre_cat E y))
вү” @fapp0
     (Hom_cat K x y)
     (Fibre_cat E y)
     (@fib_cov_tapp0_func K E x y u)
     f;

// General endpoint notation for dependent homs along a displayed functor. The
// old one-family endpoint is the identity-family specialization.
symbol homd_ [Z : Cat] [D E : П„ (Catd Z)]
  (FF : П„ (Functord D E))
  (x : П„ (Obj Z))
  (u : П„ (Obj (Fibre_cat E x)))
  (y : П„ (Obj Z))
  (v : П„ (Obj (Fibre_cat D y)))
  : П„ (Functor (Op_cat (Hom_cat Z x y)) Cat_cat)
вү” @hom_con
     (Fibre_cat E y)
     (@fapp0
       (Fibre_cat D y)
       (Fibre_cat E y)
       (@tapp0_fapp0 Z Cat_cat D E y FF)
       v)
     (Hom_cat Z x y)
     (@fib_cov_tapp0_func Z E x y u);

// General first projection of `homd_int`: externalize x and the source fibre
// object in E, while the probe family D remains internal.
symbol homd_src_funcd [Z : Cat] [D E : П„ (Catd Z)]
  (FF : П„ (Functord D E))
  (x : П„ (Obj Z))
  : П„ (Functor
        (Fibre_cat (@Op_catd Z E) x)
        (Pi_cat (@Homd_section_catd Z D x)));

// Component functor after projecting the fully internal homd object at x.
symbol homd_src_func [Z : Cat] (E : П„ (Catd Z))
  (x : П„ (Obj Z))
  : П„ (Functor
        (Fibre_cat (@Homd_source_catd Z E) x)
        (Pi_cat (@Homd_section_catd Z E x)));

rule @homd_src_funcd $Z $E $E (@id_funcd $Z $E) $x
  вҶӘ @homd_src_func $Z $E $x;

// First projection fold. The source and target family arguments are
// deliberately `_`: their canonical forms contain reducible expressions such
// as `fapp0 (op_val_func Z) E` and `Homd_target_catd E`.  The Transf_cat
// unification helper above supplies the needed endpoint information.
rule @tapp0_fapp0
      $Z
      Cat_cat
      _
      _
      $x
      (@homd_int $Z $D $E $FF)
  вҶӘ @homd_src_funcd $Z $D $E $FF $x;

// General source-fixed projection after evaluating the component functor at u.
symbol homd_src_secd [Z : Cat] [D E : П„ (Catd Z)]
  (FF : П„ (Functord D E))
  (x : П„ (Obj Z))
  (u : П„ (Obj (Fibre_cat E x)))
  : П„ (Obj (Pi_cat (@Homd_section_catd Z D x)));

// Source-fixed projection after evaluating the identity-specialized component
// functor at u.
symbol homd_src_sec [Z : Cat] (E : П„ (Catd Z))
  (x : П„ (Obj Z))
  (u : П„ (Obj (Fibre_cat E x)))
  : П„ (Obj (Pi_cat (@Homd_section_catd Z E x)));

rule @homd_src_secd $Z $E $E (@id_funcd $Z $E) $x $u
  вҶӘ @homd_src_sec $Z $E $x $u;

// Second projection fold: externalize x,u and keep the y,v endpoint internal.
rule fapp0 (@homd_src_funcd $Z $D $E $FF $x) $u
  вҶӘ @homd_src_secd $Z $D $E $FF $x $u;

// Identity-specialized compatibility fold retained for stable old normal
// forms and assertions.
rule fapp0 (@homd_src_func $Z $E $x) $u
  вҶӘ @homd_src_sec $Z $E $x $u;

// General inner endpoint functor after projecting the source-fixed section at y.
symbol homd_tgt_funcd [Z : Cat] [D E : П„ (Catd Z)]
  (FF : П„ (Functord D E))
  (x : П„ (Obj Z))
  (u : П„ (Obj (Fibre_cat E x)))
  (y : П„ (Obj Z))
  : П„ (Functor
        (Fibre_cat D y)
        (Fibre_cat
          (@fapp0 Z (Catd_cat (Op_cat Z)) (@HomPresheaf_catd Z) x)
          y));

// Inner endpoint functor after projecting the identity-specialized
// source-fixed section at y.
symbol homd_tgt_func [Z : Cat] (E : П„ (Catd Z))
  (x : П„ (Obj Z))
  (u : П„ (Obj (Fibre_cat E x)))
  (y : П„ (Obj Z))
  : П„ (Functor
        (Fibre_cat E y)
        (Fibre_cat
          (@fapp0 Z (Catd_cat (Op_cat Z)) (@HomPresheaf_catd Z) x)
          y));

rule @homd_tgt_funcd $Z $E $E (@id_funcd $Z $E) $x $u $y
  вҶӘ @homd_tgt_func $Z $E $x $u $y;

// Third projection fold. In v3.2 `piapp0` is a definition through ordinary
// terminal-source component evaluation, so this rule lives one layer down at
// the `tapp0_fapp0` component. The inferred source/target family arguments are
// deliberately `_` for the same stable-head hygiene as the other homd folds.
rule @tapp0_fapp0
      (Op_cat $Z)
      Cat_cat
      (@Const_catd (Op_cat $Z) Terminal_cat)
      _
      $y
      (@homd_src_secd $Z $D $E $FF $x $u)
  вҶӘ @Obj_func
      (Fibre_cat (@Homd_section_catd $Z $D $x) $y)
      (@homd_tgt_funcd $Z $D $E $FF $x $u $y);

// Identity-specialized compatibility fold retained for stable old normal
// forms and assertions.
rule @tapp0_fapp0
      (Op_cat $Z)
      Cat_cat
      (@Const_catd (Op_cat $Z) Terminal_cat)
      _
      $y
      (@homd_src_sec $Z $E $x $u)
  вҶӘ @Obj_func
      (Fibre_cat (@Homd_section_catd $Z $E $x) $y)
      (@homd_tgt_func $Z $E $x $u $y);

// Constant-family section evaluation follows ordinary functor application.
rule @tapp0_fapp0
      $K
      Cat_cat
      (@Const_catd $K Terminal_cat)
      (@Const_catd $K $A)
      $k
      $F
  вҶӘ @Obj_func $A (@fapp0 $K $A $F $k);

// Final endpoint fold. At this point the stable head `homd_` carries the
// endpoint family; pointwise object-action is handled by unfolding `homd_`.
rule fapp0 (@homd_tgt_funcd $Z $D $E $FF $x $u $y) $v
  вҶӘ @homd_ $Z $D $E $FF $x $u $y $v;

// Identity-specialized compatibility fold retained for stable old normal
// forms and assertions.
rule fapp0 (@homd_tgt_func $Z $E $x $u $y) $v
  вҶӘ @homd_ $Z $E $E (@id_funcd $Z $E) $x $u $y $v;

rule Hom_cat (@Sigma_cat $K $E) (Struct_sigma $x $u) (Struct_sigma $y $v)
  вҶӘ Op_cat
      (@Sigma_cat
        (Op_cat (Hom_cat $K $x $y))
        (@homd_ $K $E $E (@id_funcd $K $E) $x $u $y $v));

// -------------------------------------------------------------------------------------------------
// 12. Section action over dependent homs
// -------------------------------------------------------------------------------------------------

/*
  Full section action over a base arrow.

  `piapp1_func` is the section-level package over the base-arrow category.
  The capped object component is defined by ordinary section evaluation, so it
  remains iterable through `Pi_cat` rather than becoming only an object-level
  shortcut.  The later terminal-specialization fold from displayed internal
  action to this head is intentionally left for the next bridge pass.
*/
symbol piapp1_src_obj [K : Cat] (E : П„ (Catd K))
  (s : П„ (Obj (Pi_cat E)))
  [x y : П„ (Obj K)]
  (f : П„ (Hom K x y))
  : П„ (Obj (Fibre_cat E y))
вү” @fib_cov_tapp0_fapp0 K E x y f (@piapp0 K E s x);

symbol piapp1_func [K : Cat] (E : П„ (Catd K))
  (s : П„ (Obj (Pi_cat E)))
  (x y : П„ (Obj K))
  : П„ (Obj (Pi_cat
      (@homd_
        K
        E
        E
        (@id_funcd K E)
        x
        (@piapp0 K E s x)
        y
        (@piapp0 K E s y))));

symbol piapp1_fapp0 [K : Cat] (E : П„ (Catd K))
  (s : П„ (Obj (Pi_cat E)))
  [x y : П„ (Obj K)]
  (f : П„ (Hom K x y))
  : П„ (Obj
      (@fapp0
        (Op_cat (Hom_cat K x y))
        Cat_cat
        (@homd_
          K
          E
          E
          (@id_funcd K E)
          x
          (@piapp0 K E s x)
          y
          (@piapp0 K E s y))
        f))
вү” @piapp0
     (Op_cat (Hom_cat K x y))
     (@homd_
       K
       E
       E
       (@id_funcd K E)
       x
       (@piapp0 K E s x)
       y
       (@piapp0 K E s y))
     (@piapp1_func K E s x y)
     f;

// -------------------------------------------------------------------------------------------------
// 13. Internal displayed hom-action heads
// -------------------------------------------------------------------------------------------------

symbol tdapp1_int_func_transfd : О  [K : Cat], О  [E D : П„ (Catd K)],
  О  [FF GG : П„ (Functord E D)],
  П„ (Functor
      (@Transfd_cat K E D FF GG)
      (@Transfd_cat
        K
        (@Op_catd K E)
        (@Homd_target_catd K E)
        (@homd_int K E E (@id_funcd K E))
        (@comp_catd_fapp0
          K
          (@Op_catd K E)
          (@Op_catd K D)
          (@Homd_target_catd K E)
          (@homd_int K E D GG)
          (@Op_funcd K E D FF))));

symbol tdapp1_int_fapp0_transfd : О  [K : Cat], О  [E D : П„ (Catd K)],
  О  [FF GG : П„ (Functord E D)],
  О  (Пө : П„ (@Transfd K E D FF GG)),
  П„ (@Transfd
      K
      (@Op_catd K E)
      (@Homd_target_catd K E)
      (@homd_int K E E (@id_funcd K E))
      (@comp_catd_fapp0
        K
        (@Op_catd K E)
        (@Op_catd K D)
        (@Homd_target_catd K E)
        (@homd_int K E D GG)
        (@Op_funcd K E D FF)));

rule fapp0 (@tdapp1_int_func_transfd $K $E $D $FF $GG) $Пө
  вҶӘ @tdapp1_int_fapp0_transfd $K $E $D $FF $GG $Пө;

symbol tdapp1_int_fapp1_func_transfd : О  [K : Cat], О  [E D : П„ (Catd K)],
  О  [FF GG : П„ (Functord E D)],
  О  (Пө Пө' : П„ (@Transfd K E D FF GG)),
  П„ (Functor
      (Hom_cat (@Transfd_cat K E D FF GG) Пө Пө')
      (Hom_cat
        (@Transfd_cat
          K
          (@Op_catd K E)
          (@Homd_target_catd K E)
          (@homd_int K E E (@id_funcd K E))
          (@comp_catd_fapp0
            K
            (@Op_catd K E)
            (@Op_catd K D)
            (@Homd_target_catd K E)
            (@homd_int K E D GG)
            (@Op_funcd K E D FF)))
        (@tdapp1_int_fapp0_transfd K E D FF GG Пө)
        (@tdapp1_int_fapp0_transfd K E D FF GG Пө')));

rule @fapp1_func _ _ (@tdapp1_int_func_transfd $K $E $D $FF $GG) $Пө $Пө'
  вҶӘ @tdapp1_int_fapp1_func_transfd $K $E $D $FF $GG $Пө $Пө';

symbol fdapp1_int_transfd : О  [K : Cat], О  [E D : П„ (Catd K)],
  О  (FF : П„ (Functord E D)),
  П„ (@Transfd
      K
      (@Op_catd K E)
      (@Homd_target_catd K E)
      (@homd_int K E E (@id_funcd K E))
      (@comp_catd_fapp0
        K
        (@Op_catd K E)
        (@Op_catd K D)
        (@Homd_target_catd K E)
        (@homd_int K E D FF)
        (@Op_funcd K E D FF)));

// Identity-specialization fold for the internal displayed hom-action.
rule @tdapp1_int_fapp0_transfd $K $E $D $FF $FF
      (@id_transfd $K $E $D $FF)
  вҶӘ @fdapp1_int_transfd $K $E $D $FF;

// -------------------------------------------------------------------------------------------------
// 14. Derived displayed component notation
// -------------------------------------------------------------------------------------------------

/*
  `tdapp0_func` is not primitive kernel structure. It is the hom-action of
  ordinary component evaluation `tapp0_func` specialized to Cat-valued
  families. Its object action is a fibrewise ordinary transfor.
*/
symbol tdapp0_func [K : Cat] [E D : П„ (Catd K)]
  [FF GG : П„ (Functord E D)]
  (z : П„ (Obj K))
  : П„ (Functor
      (@Transfd_cat K E D FF GG)
      (@Transf_cat
        (Fibre_cat E z)
        (Fibre_cat D z)
        (@tapp0_fapp0 K Cat_cat E D z FF)
        (@tapp0_fapp0 K Cat_cat E D z GG)))
вү” @fapp1_func
     (@Transf_cat K Cat_cat E D)
     (@Hom_cat Cat_cat (Fibre_cat E z) (Fibre_cat D z))
     (@tapp0_func K Cat_cat E D z)
     FF
     GG;

symbol tdapp0_fapp0 [K : Cat] [E D : П„ (Catd K)]
  [FF GG : П„ (Functord E D)]
  (z : П„ (Obj K))
  (Пө : П„ (@Transfd K E D FF GG))
  : П„ (@Transf
      (Fibre_cat E z)
      (Fibre_cat D z)
      (@tapp0_fapp0 K Cat_cat E D z FF)
      (@tapp0_fapp0 K Cat_cat E D z GG))
вү” fapp0 (@tdapp0_func K E D FF GG z) Пө;

// Readable derived fibre-level notation. These are definitions over ordinary
// transfor projection; they are not additional kernel rewrite heads.
symbol Fibre_func [K : Cat] [E D : П„ (Catd K)]
  (FF : П„ (Functord E D))
  (z : П„ (Obj K))
  : П„ (Functor (Fibre_cat E z) (Fibre_cat D z))
вү” @tapp0_fapp0 K Cat_cat E D z FF;

symbol Fibre_transf [K : Cat] [E D : П„ (Catd K)]
  [FF GG : П„ (Functord E D)]
  (Пө : П„ (@Transfd K E D FF GG))
  (z : П„ (Obj K))
  : П„ (@Transf
      (Fibre_cat E z)
      (Fibre_cat D z)
      (@Fibre_func K E D FF z)
      (@Fibre_func K E D GG z))
вү” @tdapp0_fapp0 K E D FF GG z Пө;

symbol Fibre_transf_app [K : Cat] [E D : П„ (Catd K)]
  [FF GG : П„ (Functord E D)]
  (Пө : П„ (@Transfd K E D FF GG))
  (z : П„ (Obj K))
  (u : П„ (Obj (Fibre_cat E z)))
  : П„ (Hom
      (Fibre_cat D z)
      (@fapp0 (Fibre_cat E z) (Fibre_cat D z) (@Fibre_func K E D FF z) u)
      (@fapp0 (Fibre_cat E z) (Fibre_cat D z) (@Fibre_func K E D GG z) u))
вү” @tapp0_fapp0
     (Fibre_cat E z)
     (Fibre_cat D z)
     (@Fibre_func K E D FF z)
     (@Fibre_func K E D GG z)
     u
     (@Fibre_transf K E D FF GG Пө z);

// Derived fibre projection of the internal displayed hom-action. This is a
// named projection of `fdapp1_int_transfd`, not a separate external `fdapp1`
// surface operation.
symbol fdapp1_int_fibre_transf [K : Cat] [E D : П„ (Catd K)]
  (FF : П„ (Functord E D))
  (x : П„ (Obj K))
  : П„ (@Transf
      (Fibre_cat (@Op_catd K E) x)
      (Fibre_cat (@Homd_target_catd K E) x)
      (@Fibre_func
        K
        (@Op_catd K E)
        (@Homd_target_catd K E)
        (@homd_int K E E (@id_funcd K E))
        x)
      (@Fibre_func
        K
        (@Op_catd K E)
        (@Homd_target_catd K E)
        (@comp_catd_fapp0
          K
          (@Op_catd K E)
          (@Op_catd K D)
          (@Homd_target_catd K E)
          (@homd_int K E D FF)
          (@Op_funcd K E D FF))
        x))
вү” @Fibre_transf
     K
     (@Op_catd K E)
     (@Homd_target_catd K E)
     (@homd_int K E E (@id_funcd K E))
     (@comp_catd_fapp0
       K
       (@Op_catd K E)
       (@Op_catd K D)
       (@Homd_target_catd K E)
       (@homd_int K E D FF)
       (@Op_funcd K E D FF))
     (@fdapp1_int_transfd K E D FF)
     x;

symbol fdapp1_int_fibre_app [K : Cat] [E D : П„ (Catd K)]
  (FF : П„ (Functord E D))
  (x : П„ (Obj K))
  (u : П„ (Obj (Fibre_cat (@Op_catd K E) x)))
  : П„ (Hom
      (Fibre_cat (@Homd_target_catd K E) x)
      (@fapp0
        (Fibre_cat (@Op_catd K E) x)
        (Fibre_cat (@Homd_target_catd K E) x)
        (@Fibre_func
          K
          (@Op_catd K E)
          (@Homd_target_catd K E)
          (@homd_int K E E (@id_funcd K E))
          x)
        u)
      (@fapp0
        (Fibre_cat (@Op_catd K E) x)
        (Fibre_cat (@Homd_target_catd K E) x)
        (@Fibre_func
          K
          (@Op_catd K E)
          (@Homd_target_catd K E)
          (@comp_catd_fapp0
            K
            (@Op_catd K E)
            (@Op_catd K D)
            (@Homd_target_catd K E)
            (@homd_int K E D FF)
            (@Op_funcd K E D FF))
          x)
        u))
вү” @Fibre_transf_app
     K
     (@Op_catd K E)
     (@Homd_target_catd K E)
     (@homd_int K E E (@id_funcd K E))
     (@comp_catd_fapp0
       K
       (@Op_catd K E)
       (@Op_catd K D)
       (@Homd_target_catd K E)
       (@homd_int K E D FF)
       (@Op_funcd K E D FF))
     (@fdapp1_int_transfd K E D FF)
     x
     u;

// -------------------------------------------------------------------------------------------------
// 15. Generic Sigma/Pi weakening helpers
// -------------------------------------------------------------------------------------------------

// TODO(v3.2): generic Sigma/Pi helpers are deferred until the
// directed-family core is stable enough for robust beta assertions. See the
// backlog in reports/REPORT_EMDASH_V3_CONSOLIDATED.md.

// -------------------------------------------------------------------------------------------------
// 16. Regression assertions for the mixed-variance skeleton
// -------------------------------------------------------------------------------------------------

assert [K : Cat] (E : П„ (Catd K)) (k : П„ (Obj K)) вҠў
  Fibre_cat E k вүЎ @fapp0 K Cat_cat E k;

assert [K : Cat] (A : Cat) (k : П„ (Obj K)) вҠў
  Fibre_cat (Const_catd K A) k вүЎ A;

assert [K : Cat] (k : П„ (Obj K)) вҠў
  Fibre_cat (Terminal_catd K) k вүЎ Terminal_cat;

assert [K : Cat] вҠў
  Terminal_catd K вүЎ Const_catd K Terminal_cat;

assert [K : Cat] (E : П„ (Catd K)) (k : П„ (Obj K)) вҠў
  Fibre_cat (Op_catd E) k вүЎ Op_cat (Fibre_cat E k);

assert [K : Cat] (A : Cat) вҠў
  Op_catd (Const_catd K A) вүЎ Const_catd K (Op_cat A);

assert [A B : Cat] (E : П„ (Catd B)) (F : П„ (Functor A B)) (a : П„ (Obj A)) вҠў
  Fibre_cat (Pullback_catd E F) a вүЎ Fibre_cat E (fapp0 F a);

assert [K : Cat] (E : П„ (Catd K)) вҠў
  @Transf_cat K Cat_cat (@Terminal_catd K) E вүЎ Pi_cat E;

assert [K : Cat] (E : П„ (Catd K)) вҠў
  @Functord_cat K (@Terminal_catd K) E вүЎ Pi_cat E;

assert [K : Cat] (A : Cat) вҠў
  Pi_cat (Const_catd K A) вүЎ Functor_cat K A;

assert [K : Cat] (A : Cat)
  (F : П„ (Obj (Pi_cat (Const_catd K A))))
  (k : П„ (Obj K)) вҠў
  @piapp0 K (@Const_catd K A) F k
    вүЎ @fapp0 K A F k;

assert [K : Cat] (E : П„ (Catd K))
  (s : П„ (Obj (Pi_cat E)))
  (k : П„ (Obj K)) вҠў
  @fapp0
    Terminal_cat
    (Fibre_cat E k)
    (@tapp0_fapp0 K Cat_cat (@Const_catd K Terminal_cat) E k s)
    Terminal_obj
    вүЎ @piapp0 K E s k;

assert [K : Cat] (E : П„ (Catd K)) вҠў
  @fapp0 (Catd_cat K) Cat_cat (Pi_func K) E вүЎ Pi_cat E;

assert [K : Cat] (E : П„ (Catd K)) вҠў
  @fapp0 (Catd_cat K) Cat_cat (Sigma_func K) E вүЎ Sigma_cat E;

assert [K : Cat] (E D : П„ (Catd K)) (О· : П„ (Functord E D)) вҠў
  @fapp1_fapp0 (Catd_cat K) Cat_cat (@Sigma_func K) E D О·
    вүЎ @sigma_map_func K E D О·;

assert [K : Cat] (E : П„ (Catd K)) (k : П„ (Obj K)) (u : П„ (Obj (Fibre_cat E k))) вҠў
  fapp0 (Sigma_proj1_func E) (Struct_sigma k u) вүЎ k;

assert [K : Cat] (A : П„ (Catd (Op_cat K))) (B : П„ (Catd K)) (k : П„ (Obj K)) вҠў
  Fibre_cat (Functor_catd A B) k
    вүЎ Functor_cat (Fibre_cat A k) (Fibre_cat B k);

assert [K : Cat] (A : П„ (Catd (Op_cat K))) (B : П„ (Catd K)) вҠў
  @fapp0 (Catd_cat K) (Catd_cat K)
    (@fapp0
      (Op_cat (Catd_cat (Op_cat K)))
      (Functor_cat (Catd_cat K) (Catd_cat K))
      (@Functor_catd_mix_func K)
      A)
    B
    вүЎ Functor_catd A B;

assert [K : Cat] (E : П„ (Catd K))
  (X : П„ (Obj (Pi_cat (Op_catd E))))
  (Y : П„ (Obj (Pi_cat E)))
  (k : П„ (Obj K)) вҠў
  Fibre_cat (Hom_catd E X Y) k
    вүЎ Hom_cat
        (Fibre_cat E k)
        (@piapp0 K (@Op_catd K E) X k)
        (@piapp0 K E Y k);

assert [K : Cat] (A : П„ (Catd (Op_cat K))) (B : П„ (Catd K))
  (FF : П„ (Obj (Pi_cat (Op_catd (Functor_catd A B)))))
  (GG : П„ (Obj (Pi_cat (Functor_catd A B))))
  (k : П„ (Obj K)) вҠў
  Fibre_cat (Transf_catd A B FF GG) k
    вүЎ Transf_cat
        (@piapp0 K (@Op_catd K (@Functor_catd K A B)) FF k)
        (@piapp0 K (@Functor_catd K A B) GG k);

assert [K : Cat]
  (X : П„ (Obj (Pi_cat (Op_catd (Const_catd K Cat_cat)))))
  (Y : П„ (Obj (Pi_cat (Const_catd K Cat_cat)))) вҠў
  Hom_catd (Const_catd K Cat_cat) X Y
    вүЎ Functor_catd (@Op_func K (Op_cat Cat_cat) X) Y;

assert [K : Cat] (A : П„ (Catd (Op_cat K))) (B : П„ (Catd K))
  (FF : П„ (Obj (Pi_cat (Op_catd (Functor_catd A B)))))
  (GG : П„ (Obj (Pi_cat (Functor_catd A B)))) вҠў
  Hom_catd (Functor_catd A B) FF GG
    вүЎ Transf_catd A B FF GG;

assert [Z : Cat] (x : П„ (Obj (Op_cat Z))) (y : П„ (Obj Z)) вҠў
  @fapp0 Z Cat_cat
    (@fapp0 (Op_cat Z) (Catd_cat Z) (@Edge_catd_fam Z) x)
    y
    вүЎ Op_cat (Hom_cat Z x y);

assert [Z : Cat] (x : П„ (Obj Z)) (y : П„ (Obj (Op_cat Z))) вҠў
  Fibre_cat (@fapp0 Z (Catd_cat (Op_cat Z)) (@HomPresheaf_catd Z) x) y
    вүЎ Functor_cat (Op_cat (Hom_cat Z x y)) Cat_cat;

assert [Z : Cat] (E : П„ (Catd Z)) вҠў
  @Homd_source_catd Z E вүЎ @Op_catd Z E;

assert [Z : Cat] (E : П„ (Catd Z)) (x : П„ (Obj Z)) вҠў
  @Homd_section_catd Z E x
    вүЎ @Functor_catd
        (Op_cat Z)
        E
        (@fapp0 Z (Catd_cat (Op_cat Z)) (@HomPresheaf_catd Z) x);

assert [Z : Cat] (E : П„ (Catd Z)) (x : П„ (Obj Z)) вҠў
  @fapp0 Z Cat_cat (@Homd_target_catd Z E) x
    вүЎ Pi_cat
        (Functor_catd
          E
          (@fapp0 Z (Catd_cat (Op_cat Z)) (@HomPresheaf_catd Z) x));

assert [Z : Cat] (E : П„ (Catd Z)) (x : П„ (Obj Z)) вҠў
  @fapp0 Z Cat_cat (@Homd_target_catd Z E) x
    вүЎ Pi_cat (@Homd_section_catd Z E x);

assert [Z : Cat] (E : П„ (Catd Z)) вҠў
  @Homd_cat Z E
    вүЎ @Transf_cat Z Cat_cat
        (@Op_catd Z E)
        (@Homd_target_catd Z E);

assert [K : Cat] (E : П„ (Catd K)) (x : П„ (Obj K)) вҠў
  Fibre_cat (@FibCov_target_catd K E) x
    вүЎ @Transf_cat K Cat_cat (@hom_ K K (@id_func K) x) E;

assert [K : Cat] (E : П„ (Catd K)) вҠў
  @FibCov_cat K E
    вүЎ @Transf_cat K Cat_cat E (@FibCov_target_catd K E);

assert [K : Cat] (E : П„ (Catd K))
  (x : П„ (Obj K)) вҠў
  @tapp0_fapp0
    K
    Cat_cat
    E
    (@FibCov_target_catd K E)
    x
    (@fib_cov_int K E)
    вүЎ @fib_cov_src_func K E x;

assert [K : Cat] (E : П„ (Catd K))
  (x : П„ (Obj K))
  (u : П„ (Obj (Fibre_cat E x))) вҠў
  fapp0 (@fib_cov_src_func K E x) u
    вүЎ @fib_cov_transf K E x u;

assert [K : Cat] (E : П„ (Catd K))
  (x y : П„ (Obj K))
  (u : П„ (Obj (Fibre_cat E x))) вҠў
  @tapp0_fapp0
    K
    Cat_cat
    (@hom_ K K (@id_func K) x)
    E
    y
    (@fib_cov_transf K E x u)
    вүЎ @fib_cov_tapp0_func K E x y u;

assert [K : Cat] (E : П„ (Catd K)) вҠў
  @Op_funcd K E E (@id_funcd K E)
    вүЎ @id_funcd K (@Op_catd K E);

assert [K : Cat] (E D : П„ (Catd K)) (FF : П„ (Functord E D)) вҠў
  @Op_funcd K (@Op_catd K E) (@Op_catd K D) (@Op_funcd K E D FF)
    вүЎ FF;

assert [K : Cat] (E D C : П„ (Catd K))
  (FF : П„ (Functord D C))
  (GG : П„ (Functord E D)) вҠў
  @comp_fapp0 (@Catd_cat K) E D C FF GG
    вүЎ @comp_catd_fapp0 K E D C FF GG;

assert [K : Cat] (E C : П„ (Catd K))
  (FF : П„ (Functord E C)) вҠў
  @comp_catd_fapp0 K E E C FF (@id_funcd K E)
    вүЎ FF;

assert [K : Cat] (E D : П„ (Catd K))
  (GG : П„ (Functord E D)) вҠў
  @comp_catd_fapp0 K E D D (@id_funcd K D) GG
    вүЎ GG;

assert [K : Cat] (E D : П„ (Catd K)) (FF : П„ (Functord E D))
  (x : П„ (Obj K)) вҠў
  @tapp0_fapp0
    K
    Cat_cat
    (@Op_catd K E)
    (@Op_catd K D)
    x
    (@Op_funcd K E D FF)
    вүЎ @Op_func
        (Fibre_cat E x)
        (Fibre_cat D x)
        (@tapp0_fapp0 K Cat_cat E D x FF);

assert [K : Cat] (E : П„ (Catd K)) (y : П„ (Obj K)) вҠў
  @tapp0_fapp0 K Cat_cat E E y (@id_funcd K E)
    вүЎ @id_func (Fibre_cat E y);

assert [K : Cat] (E D : П„ (Catd K)) (FF GG : П„ (Functord E D))
  (Пө : П„ (@Transfd K E D FF GG)) вҠў
  fapp0 (@tdapp1_int_func_transfd K E D FF GG) Пө
    вүЎ @tdapp1_int_fapp0_transfd K E D FF GG Пө;

assert [K : Cat] (E D : П„ (Catd K)) (FF GG : П„ (Functord E D))
  (Пө Пө' : П„ (@Transfd K E D FF GG)) вҠў
  @fapp1_func _ _ (@tdapp1_int_func_transfd K E D FF GG) Пө Пө'
    вүЎ @tdapp1_int_fapp1_func_transfd K E D FF GG Пө Пө';

assert [K : Cat] (E D : П„ (Catd K)) (FF : П„ (Functord E D)) вҠў
  @tdapp1_int_fapp0_transfd K E D FF FF
    (@id (@Functord_cat K E D) FF)
    вүЎ @fdapp1_int_transfd K E D FF;

assert [K : Cat] (E : П„ (Catd K)) (s : П„ (Obj (Pi_cat E))) вҠў
  @tdapp1_int_fapp0_transfd
    K
    (@Const_catd K Terminal_cat)
    E
    s
    s
    (@id_transfd K (@Const_catd K Terminal_cat) E s)
    вүЎ @fdapp1_int_transfd K (@Const_catd K Terminal_cat) E s;

assert [K : Cat] (E D : П„ (Catd K)) (FF GG : П„ (Functord E D))
  (z : П„ (Obj K)) (Пө : П„ (@Transfd K E D FF GG)) вҠў
  fapp0 (@tdapp0_func K E D FF GG z) Пө
    вүЎ @tdapp0_fapp0 K E D FF GG z Пө;

assert [K : Cat] (E D : П„ (Catd K)) (FF : П„ (Functord E D))
  (z : П„ (Obj K)) вҠў
  @Fibre_func K E D FF z
    вүЎ @tapp0_fapp0 K Cat_cat E D z FF;

assert [K : Cat] (E : П„ (Catd K)) (z : П„ (Obj K)) вҠў
  @Fibre_func K E E (@id_funcd K E) z
    вүЎ @id_func (Fibre_cat E z);

assert [K : Cat] (E D : П„ (Catd K)) (FF : П„ (Functord E D))
  (z : П„ (Obj K)) вҠў
  @Fibre_func
    K
    (@Op_catd K E)
    (@Op_catd K D)
    (@Op_funcd K E D FF)
    z
    вүЎ @Op_func
        (Fibre_cat E z)
        (Fibre_cat D z)
        (@Fibre_func K E D FF z);

assert [K : Cat] (E D : П„ (Catd K)) (FF : П„ (Functord E D))
  (z : П„ (Obj K))
  (u : П„ (Obj (Fibre_cat (@Op_catd K E) z))) вҠў
  @fapp0
    (Fibre_cat (@Op_catd K E) z)
    (Fibre_cat (@Op_catd K D) z)
    (@Fibre_func K (@Op_catd K E) (@Op_catd K D) (@Op_funcd K E D FF) z)
    u
    вүЎ @fapp0
        (Fibre_cat E z)
        (Fibre_cat D z)
        (@Fibre_func K E D FF z)
        u;

assert [K : Cat] (E D : П„ (Catd K)) (FF GG : П„ (Functord E D))
  (Пө : П„ (@Transfd K E D FF GG)) (z : П„ (Obj K)) вҠў
  @Fibre_transf K E D FF GG Пө z
    вүЎ @tdapp0_fapp0 K E D FF GG z Пө;

assert [K : Cat] (E D : П„ (Catd K)) (FF GG : П„ (Functord E D))
  (Пө : П„ (@Transfd K E D FF GG))
  (z : П„ (Obj K))
  (u : П„ (Obj (Fibre_cat E z))) вҠў
  @Fibre_transf_app K E D FF GG Пө z u
    вүЎ @tapp0_fapp0
        (Fibre_cat E z)
        (Fibre_cat D z)
        (@Fibre_func K E D FF z)
        (@Fibre_func K E D GG z)
        u
        (@Fibre_transf K E D FF GG Пө z);

assert [K : Cat] (E D : П„ (Catd K)) (FF : П„ (Functord E D))
  (x : П„ (Obj K)) вҠў
  @fdapp1_int_fibre_transf K E D FF x
    вүЎ @Fibre_transf
        K
        (@Op_catd K E)
        (@Homd_target_catd K E)
        (@homd_int K E E (@id_funcd K E))
        (@comp_catd_fapp0
          K
          (@Op_catd K E)
          (@Op_catd K D)
          (@Homd_target_catd K E)
          (@homd_int K E D FF)
          (@Op_funcd K E D FF))
        (@fdapp1_int_transfd K E D FF)
        x;

assert [K : Cat] (E D : П„ (Catd K)) (FF : П„ (Functord E D))
  (x : П„ (Obj K))
  (u : П„ (Obj (Fibre_cat (@Op_catd K E) x))) вҠў
  @fdapp1_int_fibre_app K E D FF x u
    вүЎ @Fibre_transf_app
        K
        (@Op_catd K E)
        (@Homd_target_catd K E)
        (@homd_int K E E (@id_funcd K E))
        (@comp_catd_fapp0
          K
          (@Op_catd K E)
          (@Op_catd K D)
          (@Homd_target_catd K E)
          (@homd_int K E D FF)
          (@Op_funcd K E D FF))
        (@fdapp1_int_transfd K E D FF)
        x
        u;

assert [Z : Cat] (D E : П„ (Catd Z)) (FF : П„ (Functord D E))
  (x : П„ (Obj Z)) вҠў
  @tapp0_fapp0
    Z
    Cat_cat
    (@Op_catd Z E)
    (@Homd_target_catd Z D)
    x
    (@homd_int Z D E FF)
    вүЎ @homd_src_funcd Z D E FF x;

assert [Z : Cat] (D E : П„ (Catd Z)) (FF : П„ (Functord D E))
  (x : П„ (Obj Z)) вҠў
  @Fibre_func
    Z
    (@Op_catd Z E)
    (@Homd_target_catd Z D)
    (@homd_int Z D E FF)
    x
    вүЎ @homd_src_funcd Z D E FF x;

assert [Z : Cat] (D E : П„ (Catd Z)) (FF : П„ (Functord D E))
  (x : П„ (Obj Z))
  (u : П„ (Obj (Fibre_cat (@Op_catd Z E) x))) вҠў
  @fapp0
    (Fibre_cat (@Op_catd Z E) x)
    (Fibre_cat (@Homd_target_catd Z D) x)
    (@Fibre_func Z (@Op_catd Z E) (@Homd_target_catd Z D) (@homd_int Z D E FF) x)
    u
    вүЎ @homd_src_secd Z D E FF x u;

// Regression for the `homd_int` first projection. The rule itself keeps the
// source/target family arguments implicit; this assertion may spell them out
// because it is not a rewrite-pattern LHS.
assert [Z : Cat] (E : П„ (Catd Z))
  (x : П„ (Obj Z)) вҠў
  @tapp0_fapp0
    Z
    Cat_cat
    (@Homd_source_catd Z E)
    (@Homd_target_catd Z E)
    x
    (@homd_int Z E E (@id_funcd Z E))
    вүЎ @homd_src_func Z E x;

assert [K : Cat] (E D : П„ (Catd K)) (FF : П„ (Functord E D)) вҠў
  fapp0 (@tdapp1_int_func_transfd K E D FF FF)
    (@id (@Functord_cat K E D) FF)
    вүЎ @fdapp1_int_transfd K E D FF;

assert [Z : Cat] (D E : П„ (Catd Z)) (FF : П„ (Functord D E))
  (x : П„ (Obj Z))
  (u : П„ (Obj (Fibre_cat E x))) вҠў
  fapp0 (@homd_src_funcd Z D E FF x) u
    вүЎ @homd_src_secd Z D E FF x u;

assert [Z : Cat] (E : П„ (Catd Z))
  (x : П„ (Obj Z))
  (u : П„ (Obj (Fibre_cat E x))) вҠў
  fapp0 (@homd_src_func Z E x) u
    вүЎ @homd_src_sec Z E x u;

assert [Z : Cat] (D E : П„ (Catd Z)) (FF : П„ (Functord D E))
  (x y : П„ (Obj Z))
  (u : П„ (Obj (Fibre_cat E x))) вҠў
  @piapp0
    (Op_cat Z)
    (@Functor_catd
      (Op_cat Z)
      D
      (@fapp0 Z (Catd_cat (Op_cat Z)) (@HomPresheaf_catd Z) x))
    (@homd_src_secd Z D E FF x u)
    y
    вүЎ @homd_tgt_funcd Z D E FF x u y;

assert [Z : Cat] (E : П„ (Catd Z))
  (x y : П„ (Obj Z))
  (u : П„ (Obj (Fibre_cat E x))) вҠў
  @piapp0
    (Op_cat Z)
    (@Functor_catd
      (Op_cat Z)
      E
      (@fapp0 Z (Catd_cat (Op_cat Z)) (@HomPresheaf_catd Z) x))
    (@homd_src_sec Z E x u)
    y
    вүЎ @homd_tgt_func Z E x u y;

assert [Z : Cat] (E : П„ (Catd Z))
  (x y : П„ (Obj Z))
  (u : П„ (Obj (Fibre_cat E x)))
  (v : П„ (Obj (Fibre_cat E y))) вҠў
  fapp0 (@homd_tgt_func Z E x u y) v
    вүЎ @homd_ Z E E (@id_funcd Z E) x u y v;

assert [Z : Cat] (D E : П„ (Catd Z)) (FF : П„ (Functord D E))
  (x y : П„ (Obj Z))
  (u : П„ (Obj (Fibre_cat E x)))
  (v : П„ (Obj (Fibre_cat D y))) вҠў
  fapp0 (@homd_tgt_funcd Z D E FF x u y) v
    вүЎ @homd_ Z D E FF x u y v;

assert [Z : Cat] (D E : П„ (Catd Z)) (FF : П„ (Functord D E))
  (x y : П„ (Obj Z))
  (u : П„ (Obj (Fibre_cat E x)))
  (v : П„ (Obj (Fibre_cat D y))) вҠў
  @homd_ Z D E FF x u y v
    вүЎ @hom_con
        (Fibre_cat E y)
        (@fapp0
          (Fibre_cat D y)
          (Fibre_cat E y)
          (@tapp0_fapp0 Z Cat_cat D E y FF)
          v)
        (Hom_cat Z x y)
        (@fib_cov_tapp0_func Z E x y u);

assert [Z : Cat] (E : П„ (Catd Z))
  (x y : П„ (Obj Z))
  (u : П„ (Obj (Fibre_cat E x)))
  (v : П„ (Obj (Fibre_cat E y))) вҠў
  @homd_ Z E E (@id_funcd Z E) x u y v
    вүЎ @hom_con
        (Fibre_cat E y)
        v
        (Hom_cat Z x y)
        (@fib_cov_tapp0_func Z E x y u);

assert [K : Cat] (E : П„ (Catd K))
  (s : П„ (Obj (Pi_cat E)))
  (x y : П„ (Obj K)) вҠў
  @homd_
    K
    (@Const_catd K Terminal_cat)
    E
    s
    x
    (@piapp0 K E s x)
    y
    Terminal_obj
    вүЎ @homd_
        K
        E
        E
        (@id_funcd K E)
        x
        (@piapp0 K E s x)
        y
        (@piapp0 K E s y);

assert [K : Cat] (A : Cat)
  (x y : П„ (Obj K))
  (u : П„ (Obj (Fibre_cat (Const_catd K A) x)))
  (v : П„ (Obj (Fibre_cat (Const_catd K A) y))) вҠў
  @homd_ K
    (Const_catd K A)
    (Const_catd K A)
    (@id_funcd K (Const_catd K A))
    x u y v
    вүЎ @Const_catd (Op_cat (Hom_cat K x y)) (Hom_cat A u v);

assert [K : Cat] (A : Cat)
  (x y : П„ (Obj K))
  (u : П„ (Obj (Fibre_cat (Const_catd K A) x)))
  (v : П„ (Obj (Fibre_cat (Const_catd K A) y)))
  (f g : П„ (Obj (Op_cat (Hom_cat K x y)))) вҠў
  @fapp1_func
    (Op_cat (Hom_cat K x y))
    Cat_cat
    (@homd_ K
      (Const_catd K A)
      (Const_catd K A)
      (@id_funcd K (Const_catd K A))
      x u y v)
    f
    g
    вүЎ @fapp1_func
        (Op_cat (Hom_cat K x y))
        Cat_cat
        (@Const_catd (Op_cat (Hom_cat K x y)) (Hom_cat A u v))
        f
        g;

assert [K : Cat] (A : Cat)
  (x y : П„ (Obj K))
  (u : П„ (Obj (Fibre_cat (Const_catd K A) x)))
  (v : П„ (Obj (Fibre_cat (Const_catd K A) y)))
  (f g : П„ (Obj (Op_cat (Hom_cat K x y))))
  (alpha : П„ (Hom (Op_cat (Hom_cat K x y)) f g)) вҠў
  @fapp1_fapp0
    (Op_cat (Hom_cat K x y))
    Cat_cat
    (@homd_ K
      (Const_catd K A)
      (Const_catd K A)
      (@id_funcd K (Const_catd K A))
      x u y v)
    f
    g
    alpha
    вүЎ @fapp1_fapp0
        (Op_cat (Hom_cat K x y))
        Cat_cat
        (@Const_catd (Op_cat (Hom_cat K x y)) (Hom_cat A u v))
        f
        g
        alpha;

assert [K : Cat]
  (x y : П„ (Obj K))
  (u : П„ (Obj (Fibre_cat (Terminal_catd K) x)))
  (v : П„ (Obj (Fibre_cat (Terminal_catd K) y))) вҠў
  @homd_ K
    (Terminal_catd K)
    (Terminal_catd K)
    (@id_funcd K (Terminal_catd K))
    x u y v
    вүЎ @Terminal_catd (Op_cat (Hom_cat K x y));

assert [K : Cat]
  (x y : П„ (Obj K))
  (u : П„ (Obj (Fibre_cat (Terminal_catd K) x)))
  (v : П„ (Obj (Fibre_cat (Terminal_catd K) y)))
  (f g : П„ (Obj (Op_cat (Hom_cat K x y)))) вҠў
  @fapp1_func
    (Op_cat (Hom_cat K x y))
    Cat_cat
    (@homd_ K
      (Terminal_catd K)
      (Terminal_catd K)
      (@id_funcd K (Terminal_catd K))
      x u y v)
    f
    g
    вүЎ @fapp1_func
        (Op_cat (Hom_cat K x y))
        Cat_cat
        (@Terminal_catd (Op_cat (Hom_cat K x y)))
        f
        g;

assert [K : Cat]
  (x y : П„ (Obj K))
  (u : П„ (Obj (Fibre_cat (Terminal_catd K) x)))
  (v : П„ (Obj (Fibre_cat (Terminal_catd K) y)))
  (f g : П„ (Obj (Op_cat (Hom_cat K x y))))
  (alpha : П„ (Hom (Op_cat (Hom_cat K x y)) f g)) вҠў
  @fapp1_fapp0
    (Op_cat (Hom_cat K x y))
    Cat_cat
    (@homd_ K
      (Terminal_catd K)
      (Terminal_catd K)
      (@id_funcd K (Terminal_catd K))
      x u y v)
    f
    g
    alpha
    вүЎ @fapp1_fapp0
        (Op_cat (Hom_cat K x y))
        Cat_cat
        (@Terminal_catd (Op_cat (Hom_cat K x y)))
        f
        g
        alpha;

assert [K : Cat] (E : П„ (Catd K))
  (x y : П„ (Obj K))
  (u : П„ (Obj (Fibre_cat E x)))
  (f : П„ (Hom K x y)) вҠў
  @fapp0 (Hom_cat K x y) (Fibre_cat E y)
    (@fib_cov_tapp0_func K E x y u)
    f
    вүЎ @fib_cov_tapp0_fapp0 K E x y f u;

assert [K : Cat] (A : Cat)
  (x y : П„ (Obj K))
  (u : П„ (Obj (Fibre_cat (Const_catd K A) x))) вҠў
  @fib_cov_tapp0_func K (@Const_catd K A) x y u
    вүЎ @Const_func (Hom_cat K x y) A u;

assert [K : Cat] (A : Cat)
  (x y : П„ (Obj K))
  (f : П„ (Hom K x y))
  (u : П„ (Obj (Fibre_cat (Const_catd K A) x))) вҠў
  @fib_cov_tapp0_fapp0 K (@Const_catd K A) x y f u
    вүЎ u;

assert [K : Cat] (E : П„ (Catd K))
  (x y : П„ (Obj K))
  (u : П„ (Obj (Fibre_cat E x)))
  (v : П„ (Obj (Fibre_cat E y)))
  (f : П„ (Obj (Op_cat (Hom_cat K x y)))) вҠў
  @fapp0 (Op_cat (Hom_cat K x y)) Cat_cat
    (@homd_ K E E (@id_funcd K E) x u y v)
    f
    вүЎ Hom_cat (Fibre_cat E y)
        (@fib_cov_tapp0_fapp0 K E x y f u)
        v;

assert [K : Cat] (E : П„ (Catd K))
  (s : П„ (Obj (Pi_cat E)))
  (x y : П„ (Obj K))
  (f : П„ (Hom K x y)) вҠў
  @piapp1_src_obj K E s x y f
    вүЎ @fib_cov_tapp0_fapp0 K E x y f (@piapp0 K E s x);

assert [K : Cat] (E : П„ (Catd K))
  (s : П„ (Obj (Pi_cat E)))
  (x y : П„ (Obj K))
  (f : П„ (Hom K x y)) вҠў
  @fapp0 (Op_cat (Hom_cat K x y)) Cat_cat
    (@homd_
      K
      E
      E
      (@id_funcd K E)
      x
      (@piapp0 K E s x)
      y
      (@piapp0 K E s y))
    f
    вүЎ Hom_cat (Fibre_cat E y)
        (@piapp1_src_obj K E s x y f)
        (@piapp0 K E s y);

assert [K : Cat] (E : П„ (Catd K))
  (s : П„ (Obj (Pi_cat E)))
  (x y : П„ (Obj K))
  (f : П„ (Hom K x y)) вҠў
  @fapp0 (Op_cat (Hom_cat K x y)) Cat_cat
    (@homd_
      K
      (@Const_catd K Terminal_cat)
      E
      s
      x
      (@piapp0 K E s x)
      y
      Terminal_obj)
    f
    вүЎ Hom_cat (Fibre_cat E y)
        (@piapp1_src_obj K E s x y f)
        (@piapp0 K E s y);

assert [K : Cat] (A : Cat)
  (s : П„ (Obj (Pi_cat (Const_catd K A))))
  (x y : П„ (Obj K))
  (f : П„ (Hom K x y)) вҠў
  @piapp1_src_obj K (@Const_catd K A) s x y f
    вүЎ @fapp0 K A s x;

assert [K : Cat] (E : П„ (Catd K))
  (x y : П„ (Obj K))
  (u : П„ (Obj (Fibre_cat E x)))
  (v : П„ (Obj (Fibre_cat E y)))
  (f g : П„ (Obj (Op_cat (Hom_cat K x y)))) вҠў
  @fapp1_func
    (Op_cat (Hom_cat K x y))
    Cat_cat
    (@homd_ K E E (@id_funcd K E) x u y v)
    f
    g
    вүЎ @fapp1_func
        (Op_cat (Hom_cat K x y))
        Cat_cat
        (@hom_con
          (Fibre_cat E y)
          v
          (Hom_cat K x y)
          (@fib_cov_tapp0_func K E x y u))
        f
        g;

assert [K : Cat] (E : П„ (Catd K))
  (x y : П„ (Obj K))
  (u : П„ (Obj (Fibre_cat E x)))
  (v : П„ (Obj (Fibre_cat E y)))
  (f g : П„ (Obj (Op_cat (Hom_cat K x y))))
  (alpha : П„ (Hom (Op_cat (Hom_cat K x y)) f g)) вҠў
  @fapp1_fapp0
    (Op_cat (Hom_cat K x y))
    Cat_cat
    (@homd_ K E E (@id_funcd K E) x u y v)
    f
    g
    alpha
    вүЎ @fapp1_fapp0
        (Op_cat (Hom_cat K x y))
        Cat_cat
        (@hom_con
          (Fibre_cat E y)
          v
          (Hom_cat K x y)
          (@fib_cov_tapp0_func K E x y u))
        f
        g
        alpha;

assert [K : Cat] (E : П„ (Catd K))
  (s : П„ (Obj (Pi_cat E)))
  (x y : П„ (Obj K))
  (f : П„ (Hom K x y)) вҠў
  @piapp1_fapp0 K E s x y f
    вүЎ @piapp0
        (Op_cat (Hom_cat K x y))
        (@homd_
          K
          E
          E
          (@id_funcd K E)
          x
          (@piapp0 K E s x)
          y
          (@piapp0 K E s y))
        (@piapp1_func K E s x y)
        f;

assert [Z : Cat] (E : П„ (Catd Z))
  (x y : П„ (Obj Z))
  (u : П„ (Obj (Fibre_cat E x)))
  (v : П„ (Obj (Fibre_cat E y))) вҠў
  Hom_cat (@Sigma_cat Z E) (Struct_sigma x u) (Struct_sigma y v)
    вүЎ Op_cat
        (@Sigma_cat
          (Op_cat (Hom_cat Z x y))
          (@homd_ Z E E (@id_funcd Z E) x u y v));

assert [K : Cat] (E D : П„ (Catd K)) (О· : П„ (Functord E D))
  (k : П„ (Obj K)) (u : П„ (Obj (Fibre_cat E k))) вҠў
  @fapp0 (@Sigma_cat K E) (@Sigma_cat K D)
    (@sigma_map_func K E D О·)
    (Struct_sigma k u)
    вүЎ @Struct_sigma
        (Obj K)
        (О» kk : П„ (Obj K), Obj (Fibre_cat D kk))
        k
        (@fapp0 (Fibre_cat E k) (Fibre_cat D k)
          (@tapp0_fapp0 K Cat_cat E D k О·)
          u);

assert [K : Cat] (E D : П„ (Catd K)) (О· : П„ (Functord E D)) вҠў
  @comp_cat_fapp0 (@Sigma_cat K E) (@Sigma_cat K D) K
    (@Sigma_proj1_func K D)
    (@sigma_map_func K E D О·)
    вүЎ @Sigma_proj1_func K E;

