/*
  m- / emdash3
  Clean executable skeleton for computational-logical omega-categories in Lambdapi.

  v3 keeps the v2 stable-head rewrite discipline, but starts from categorical
  Sigma/Pi type formers and a uniform binary internal hom.
*/

flag "eta_equality" on;
flag "print_implicits" on;
flag "print_contexts" on;
flag "print_domains" on;
flag "print_meta_args" on;

// -------------------------------------------------------------------------------------------------
// 0. Groupoid universe and equality
// -------------------------------------------------------------------------------------------------

constant symbol Grpd : TYPE;
injective symbol Ď„ : Grpd â†’ TYPE;
builtin "T" â‰” Ď„;
builtin "Prop" â‰” Grpd;
builtin "P" â‰” Ď„;

constant symbol = : Î  [a: Grpd], Ď„ a â†’ Ď„ a â†’ Grpd;
notation = infix 10;

constant symbol eq_refl : Î  [a: Grpd], Î  x: Ď„ a, Ď„ (x = x);

symbol ind_eq : Î  [a: Grpd], Î  [x: Ď„ a], Î  [y: Ď„ a],
  Ď„ (x = y) â†’ Î  p: (Ď„ a â†’ Grpd), Ď„ (p y) â†’ Ď„ (p x);
rule ind_eq (eq_refl $x) $p $u â†Ş $u;

symbol eq_trans : Î  [a : Grpd], Î  [x : Ď„ a], Î  [y : Ď„ a], Î  [z : Ď„ a],
  Ď„ (x = y) â†’ Ď„ (y = z) â†’ Ď„ (x = z)
â‰” Î» a x y z p q, ind_eq p (Î» t : Ď„ a, t = z) q;

builtin "eq"    â‰” =;
builtin "refl"  â‰” eq_refl;
builtin "eqind" â‰” ind_eq;

inductive unit : TYPE â‰” | tt : unit;

constant symbol Unit_grpd : Grpd;
rule Ď„ Unit_grpd â†Ş unit;

inductive nat : TYPE â‰”
| zero : nat
| succ : nat â†’ nat;

// -------------------------------------------------------------------------------------------------
// 1. Core categories
// -------------------------------------------------------------------------------------------------

constant symbol Cat : TYPE;

symbol Obj : Cat â†’ Grpd;

injective symbol Hom_cat : Î  (A : Cat) (X_A Y_A : Ď„ (Obj A)), Cat;

symbol Hom (A : Cat) (X_A Y_A : Ď„ (Obj A)) : Grpd
â‰” Obj (Hom_cat A X_A Y_A);

unif_rule Obj (Hom_cat $A $X $Y) â‰ˇ Obj (Hom_cat $A' $X' $Y') â†Ş [ $A â‰ˇ $A'; $X â‰ˇ $X'; $Y â‰ˇ $Y' ];
unif_rule Hom $A $X $Y â‰ˇ Hom $A' $X' $Y' â†Ş [ $A â‰ˇ $A'; $X â‰ˇ $X'; $Y â‰ˇ $Y' ];

injective symbol id : Î  (A : Cat), Î  (X_A: Ď„ (Obj A)), Ď„ (Hom A X_A X_A);

symbol comp_fapp0 : Î  [A : Cat], Î  [X_A Y_A : Ď„ (Obj A)], Î  [Z_A: Ď„ (Obj A)],
  Î  (g: Ď„ (Hom A Y_A Z_A)), Î  (f: Ď„ (Hom A X_A Y_A)),
  Ď„ (Hom A X_A Z_A);

injective symbol Op_cat : Cat â†’ Cat;
rule Op_cat (Op_cat $A) â†Ş $A;
rule Obj (Op_cat $A) â†Ş Obj $A;
rule Hom_cat (Op_cat $A) $X $Y â†Ş Hom_cat $A $Y $X;
rule @id (Op_cat $A) $X â†Ş @id $A $X;
rule @comp_fapp0 (Op_cat $A) $X $Y $Z $g $f â†Ş @comp_fapp0 $A $Z $Y $X $f $g;

// Path categories internalize HoTT equality as a groupoidal category.
injective symbol Path_cat : Grpd â†’ Cat;
rule Obj (Path_cat $A) â†Ş $A;
rule Hom_cat (Path_cat $A) $x $y â†Ş Path_cat ($x = $y);
rule @id (Path_cat $A) $x â†Ş eq_refl $x;
rule @comp_fapp0 (Path_cat $A) $x $y $z $q $p â†Ş eq_trans $p $q;
rule Op_cat (Path_cat $A) â†Ş Path_cat $A;

symbol Core_cat (C : Cat) : Cat â‰” Path_cat (Obj C);

assert [A : Grpd] âŠ˘ Obj (Path_cat A) â‰ˇ A;
assert [A : Grpd] (x y : Ď„ A) âŠ˘ Hom_cat (Path_cat A) x y â‰ˇ Path_cat (x = y);
assert [A : Grpd] (x : Ď„ A) âŠ˘ @id (Path_cat A) x â‰ˇ eq_refl x;
assert [A : Grpd] (x y z : Ď„ A) (p : Ď„ (x = y)) (q : Ď„ (y = z)) âŠ˘
  @comp_fapp0 (Path_cat A) x y z q p â‰ˇ eq_trans p q;

// -------------------------------------------------------------------------------------------------
// 2. Ordinary functors and universe categories
// -------------------------------------------------------------------------------------------------

constant symbol Functor_cat : Î  (A B : Cat), Cat;

symbol Functor (A B : Cat) : Grpd
â‰” Obj (Functor_cat A B);

unif_rule Functor $A $B â‰ˇ Functor $A' $B' â†Ş [ $A â‰ˇ $A'; $B â‰ˇ $B' ];
unif_rule Obj (Functor_cat $A $B) â‰ˇ Obj (Functor_cat $A' $B') â†Ş [ $A â‰ˇ $A'; $B â‰ˇ $B' ];

symbol fapp0 : Î  [A B : Cat], Î  (F_AB : Ď„ (Functor A B)),
  Ď„ (Obj A) â†’ Ď„ (Obj B);

symbol fapp1_func : Î  [A B : Cat], Î  (F_AB : Ď„ (Functor A B)),
  Î  [X_A Y_A : Ď„ (Obj A)],
  Ď„ (Functor (Hom_cat A X_A Y_A) (Hom_cat B (fapp0 F_AB X_A) (fapp0 F_AB Y_A)));

symbol fapp1_fapp0 : Î  [A B : Cat], Î  (F_AB : Ď„ (Functor A B)),
  Î  [X_A Y_A : Ď„ (Obj A)],
  Î  (f : Ď„ (Hom A X_A Y_A)),
  Ď„ (Hom B (fapp0 F_AB X_A) (fapp0 F_AB Y_A));

rule fapp0 (fapp1_func $F_AB) $f â†Ş fapp1_fapp0 $F_AB $f;

constant symbol Grpd_grpd : Grpd;
constant symbol Cat_grpd  : Grpd;
rule Ď„ Grpd_grpd â†Ş Grpd;
rule Ď„ Cat_grpd  â†Ş Cat;

constant symbol Grpd_cat : Cat;
rule Obj Grpd_cat â†Ş Grpd_grpd;
rule Ď„ (Obj (Hom_cat Grpd_cat $X $Y)) â†Ş (Ď„ $X â†’ Ď„ $Y);

constant symbol Cat_cat : Cat;
rule Obj Cat_cat â†Ş Cat_grpd;
rule Hom_cat Cat_cat $X $Y â†Ş Functor_cat $X $Y;

assert âŠ˘ Ď„ (Obj Grpd_cat) â‰ˇ Grpd;
assert âŠ˘ Ď„ (Obj Cat_cat) â‰ˇ Cat;
assert (A B : Cat) âŠ˘ Hom_cat Cat_cat A B â‰ˇ Functor_cat A B;

symbol id_func [A: Cat] : Ď„ (Functor A A);
rule @id Cat_cat $A â†Ş @id_func $A;
rule fapp0 (@id_func $A) $xA â†Ş $xA;

symbol comp_cat_fapp0 [A B : Cat] [C : Cat]
  (F : Ď„ (Functor B C)) (G : Ď„ (Functor A B)) : Ď„ (Functor A C);

rule @comp_fapp0 Cat_cat $A $B $C $F $G â†Ş @comp_cat_fapp0 $A $B $C $F $G;
rule @fapp0 $A $C (@comp_cat_fapp0 $A $B $C $F $G) $x â†Ş @fapp0 $B $C $F (@fapp0 $A $B $G $x);

rule @comp_fapp0 $A $Y $Y $Z $g (@id $A $Y) â†Ş $g;
rule @comp_fapp0 $A $X $Z $Z (@id $A $Z) $f â†Ş $f;

injective symbol Op_func : Î  [A B : Cat],
  Ď„ (Functor A B) â†’ Ď„ (Functor (Op_cat A) (Op_cat B));

rule Op_func (@Op_func $A $B $F) â†Ş $F;
rule @fapp0 _ _ (@Op_func $A $B $F) $xA â†Ş @fapp0 $A $B $F $xA;
rule @fapp1_func _ _ (@Op_func $A $B $F) $X $Y â†Ş @fapp1_func $A $B $F $Y $X;
rule @Op_func _ _ (@id_func $A) â†Ş @id_func (Op_cat $A);
rule @Op_func _ _ (@comp_cat_fapp0 $A $B $C $F $G)
  â†Ş comp_cat_fapp0 (Op_func $F) (Op_func $G);

// Terminal category and points-as-functors are needed to derive unary homs from binary hom.
constant symbol Terminal_cat : Cat;
rule Op_cat Terminal_cat â†Ş Terminal_cat;
rule Obj Terminal_cat â†Ş Unit_grpd;
rule Hom_cat Terminal_cat _ _ â†Ş Terminal_cat;

constant symbol Terminal_obj : Ď„ (Obj Terminal_cat);
rule @id Terminal_cat _ â†Ş Terminal_obj;
rule @comp_fapp0 Terminal_cat _ _ _ _ _ â†Ş Terminal_obj;

injective symbol Terminal_func : Î  (A : Cat), Ď„ (Functor A Terminal_cat);
rule @Op_func _ _ (@Terminal_func $A) â†Ş @Terminal_func (Op_cat $A);

injective symbol Obj_func : Î  [Y : Cat], Ď„ (Obj Y) â†’ Ď„ (Functor Terminal_cat Y);
rule fapp0 (Obj_func $y) _ â†Ş $y;
rule @Op_func _ _ (@Obj_func $Y $y) â†Ş @Obj_func (Op_cat $Y) $y;

symbol fapp0_func : Î  [A B : Cat],
  Ď„ (Obj A) â†’ Ď„ (Functor (Functor_cat A B) B);
rule fapp0 (fapp0_func $x) $F â†Ş fapp0 $F $x;

// -------------------------------------------------------------------------------------------------
// 3. Uniform binary internal hom
// -------------------------------------------------------------------------------------------------

constant symbol hom2_int : Î  [I J A : Cat],
  Î  (G : Ď„ (Functor I A)),
  Î  (F : Ď„ (Functor J A)),
  Ď„ (Functor (Op_cat I) (Functor_cat J Cat_cat));

rule @fapp0 $J Cat_cat (@fapp0 (Op_cat $I) (Functor_cat $J Cat_cat) (@hom2_int $I $J $A $G $F) $i) $j
  â†Ş Hom_cat $A (@fapp0 $I $A $G $i) (@fapp0 $J $A $F $j);

symbol hom_ [A B : Cat] (F : Ď„ (Functor B A)) (W : Ď„ (Obj A))
  : Ď„ (Functor B Cat_cat);
rule @fapp0 $B Cat_cat (@hom_ $A $B $F $W) $y
  â†Ş Hom_cat $A $W (@fapp0 $B $A $F $y);

symbol hom_con [A : Cat] (W : Ď„ (Obj A)) [B : Cat] (F : Ď„ (Functor B A))
  : Ď„ (Functor (Op_cat B) Cat_cat);
rule @fapp0 (Op_cat $B) Cat_cat (@hom_con $A $W $B $F) $x
  â†Ş Hom_cat $A (@fapp0 $B $A $F $x) $W;

assert [I J A : Cat] (G : Ď„ (Functor I A)) (F : Ď„ (Functor J A))
  (i : Ď„ (Obj (Op_cat I))) (j : Ď„ (Obj J)) âŠ˘
  @fapp0 J Cat_cat (@fapp0 (Op_cat I) (Functor_cat J Cat_cat) (@hom2_int I J A G F) i) j
    â‰ˇ Hom_cat A (@fapp0 I A G i) (@fapp0 J A F j);

assert [A B : Cat] (F : Ď„ (Functor B A)) (W : Ď„ (Obj A)) (y : Ď„ (Obj B)) âŠ˘
  @fapp0 B Cat_cat (@hom_ A B F W) y â‰ˇ Hom_cat A W (@fapp0 B A F y);

assert [A B : Cat] (F : Ď„ (Functor B A)) (W : Ď„ (Obj A)) (x : Ď„ (Obj (Op_cat B))) âŠ˘
  @fapp0 (Op_cat B) Cat_cat (@hom_con A W B F) x â‰ˇ Hom_cat A (@fapp0 B A F x) W;

// -------------------------------------------------------------------------------------------------
// 4. Encoded Sigma types for object layers
// -------------------------------------------------------------------------------------------------

inductive Ď„ÎŁ_ [a : Grpd] (P : Ď„ a â†’ Grpd) : TYPE â‰”
| Struct_sigma [a P] : Î  (sigma_Fst : Ď„ a) (sigma_Snd : Ď„ (P sigma_Fst)), @Ď„ÎŁ_ a P;
notation Ď„ÎŁ_ quantifier;

constant symbol ÎŁ_ [a : Grpd] (P : Ď„ a â†’ Grpd) : Grpd;
notation ÎŁ_ quantifier;
rule Ď„ (ÎŁ_ $P) â†Ş Ď„ÎŁ_ $P;

injective symbol sigma_Fst [a P] (s : @Ď„ÎŁ_ a P) : Ď„ a;
rule sigma_Fst (Struct_sigma $1 $2) â†Ş $1;

injective symbol sigma_Snd [a P] (s : @Ď„ÎŁ_ a P) : Ď„ (P (sigma_Fst s));
rule sigma_Snd (Struct_sigma $1 $2) â†Ş $2;

// -------------------------------------------------------------------------------------------------
// 5. Displayed categories, Pi/Sigma, and displayed functors
// -------------------------------------------------------------------------------------------------

constant symbol Catd : Î  (Z : Cat), TYPE;

constant symbol Catd_grpd : Î  (Z : Cat), Grpd;
rule Ď„ (Catd_grpd $Z) â†Ş Catd $Z;

constant symbol Catd_cat : Î  (Z : Cat), Cat;
rule Obj (Catd_cat $Z) â†Ş Catd_grpd $Z;

injective symbol Fibre_cat : Î  [Z : Cat] (E : Catd Z) (z : Ď„ (Obj Z)), Cat;

symbol Fibre [Z : Cat] (E : Catd Z) (z : Ď„ (Obj Z)) : Grpd
â‰” Obj (Fibre_cat E z);

unif_rule Obj (@Fibre_cat $Z $E $z) â‰ˇ Obj (@Fibre_cat $Z' $E' $z') â†Ş [ $Z â‰ˇ $Z'; $E â‰ˇ $E'; $z â‰ˇ $z' ];
unif_rule Fibre $E $z â‰ˇ Fibre $E' $z' â†Ş [ $E â‰ˇ $E'; $z â‰ˇ $z' ];

constant symbol Terminal_catd : Î  (Z : Cat), Catd Z;
rule Fibre_cat (Terminal_catd $Z) _ â†Ş Terminal_cat;

constant symbol Fibration_cov_catd : Î  [Z : Cat], Ď„ (Functor Z Cat_cat) â†’ Catd Z;
rule Fibre_cat (Fibration_cov_catd $M) $z â†Ş fapp0 $M $z;

// Weakening / constant displayed category: a category A available in any base context Z.
injective symbol Const_catd : Î  (Z : Cat), Cat â†’ Catd Z;
rule Fibre_cat (Const_catd $Z $A) _ â†Ş $A;

symbol Lift_catd (A : Cat) : Catd Terminal_cat
â‰” Const_catd Terminal_cat A;

symbol CatCat_catd (Z : Cat) : Catd Z
â‰” Const_catd Z Cat_cat;

symbol Pullback_catd : Î  [A B : Cat], Catd B â†’ Ď„ (Functor A B) â†’ Catd A;
rule Fibre_cat (Pullback_catd $E $F) $x â†Ş Fibre_cat $E (fapp0 $F $x);

injective symbol Op_catd : Î  [Z : Cat] (E : Catd Z), Catd (Op_cat Z);
rule Op_catd (Op_catd $E) â†Ş $E;
rule Fibre_cat (Op_catd $E) $z â†Ş Op_cat (Fibre_cat $E $z);
rule @Op_catd _ (Const_catd $Z $A) â†Ş Const_catd (Op_cat $Z) (Op_cat $A);

symbol Catd_catd [Z : Cat] (E : Catd Z) : Catd Z;
rule Fibre_cat (Catd_catd $E) $z â†Ş Catd_cat (Fibre_cat $E $z);

symbol Pi_cat [Z : Cat] (E : Catd Z) : Cat;

symbol piapp0 : Î  [Z : Cat], Î  [E : Catd Z],
  Î  (s : Ď„ (Obj (Pi_cat E))),
  Î  (z : Ď„ (Obj Z)), Ď„ (Fibre E z);

symbol PiHom_catd [Z : Cat] (E : Catd Z)
  (s t : Ď„ (Obj (Pi_cat E))) : Catd Z;
rule Fibre_cat (PiHom_catd $E $s $t) $z
  â†Ş Hom_cat (Fibre_cat $E $z) (@piapp0 _ $E $s $z) (@piapp0 _ $E $t $z);

rule Hom_cat (Pi_cat $E) $s $t â†Ş Pi_cat (PiHom_catd $E $s $t);

symbol Sigma_cat [Z : Cat] (E : Catd Z) : Cat;
symbol Total_cat [Z : Cat] (E : Catd Z) : Cat â‰” Sigma_cat E;

rule Ď„ (Obj (@Sigma_cat $Z $E))
  â†Ş `Ď„ÎŁ_ z : Ď„ (Obj $Z), Obj (Fibre_cat $E z);

injective symbol Sigma_proj1_func [Z : Cat] (E : Catd Z) : Ď„ (Functor (Sigma_cat E) Z);
symbol Total_proj1_func [Z : Cat] (E : Catd Z) : Ď„ (Functor (Total_cat E) Z)
â‰” Sigma_proj1_func E;

rule fapp0 (Sigma_proj1_func $E) (Struct_sigma $z $u) â†Ş $z;

// Sections into a displayed category are the categorical Pi type.
symbol Functor_catd [Z : Cat] (E D : Catd Z) : Catd Z;
rule Fibre_cat (Functor_catd $E $D) $z
  â†Ş Functor_cat (Fibre_cat $E $z) (Fibre_cat $D $z);

symbol Functord_cat [Z : Cat] (E D : Catd Z) : Cat
â‰” Pi_cat (Functor_catd E D);

symbol Functord [Z : Cat] (E D : Catd Z) : Grpd
â‰” Obj (Functord_cat E D);

rule Hom_cat (Catd_cat $Z) $E $D â†Ş Functord_cat $E $D;

symbol id_funcd [Z : Cat] [E : Catd Z] : Ď„ (Functord E E);
rule @id (Catd_cat $Z) $E â†Ş @id_funcd $Z $E;

sequential symbol fdapp0 : Î  [Z : Cat], Î  [E D : Catd Z],
  Î  (FF : Ď„ (Functord E D)),
  Î  (z : Ď„ (Obj Z)), Ď„ (Fibre E z) â†’ Ď„ (Fibre D z)
;

rule @fdapp0 $Z $E $E (@id_funcd $Z $E) $z $u â†Ş $u;
rule @fdapp0 $Z $E $D $FF $z $u
  â†Ş @fapp0
      (Fibre_cat $E $z)
      (Fibre_cat $D $z)
      (@piapp0 $Z (@Functor_catd $Z $E $D) $FF $z)
      $u;

constant symbol Transf_cat : Î  [A B : Cat], Î  (F G : Ď„ (Functor A B)), Cat;

symbol Transf [A B : Cat] (F G : Ď„ (Functor A B)) : Grpd
â‰” Obj (@Transf_cat A B F G);

rule Hom_cat (Functor_cat _ _) $F $G â†Ş Transf_cat $F $G;

symbol Transf_catd [Z : Cat] [E D : Catd Z]
  (FF GG : Ď„ (Functord E D)) : Catd Z;
rule @Fibre_cat $Z (@Transf_catd $Z $E $D $FF $GG) $z
  â†Ş @Transf_cat
      (Fibre_cat $E $z)
      (Fibre_cat $D $z)
      (@piapp0 $Z (@Functor_catd $Z $E $D) $FF $z)
      (@piapp0 $Z (@Functor_catd $Z $E $D) $GG $z);

symbol Transfd_cat [Z : Cat] [E D : Catd Z]
  (FF GG : Ď„ (Functord E D)) : Cat
â‰” @Pi_cat Z (@Transf_catd Z E D FF GG);

symbol Transfd [Z : Cat] [E D : Catd Z]
  (FF GG : Ď„ (Functord E D)) : Grpd
â‰” Obj (@Transfd_cat Z E D FF GG);

rule @Hom_cat (@Functord_cat $Z $E $D) $FF $GG â†Ş @Transfd_cat $Z $E $D $FF $GG;

// -------------------------------------------------------------------------------------------------
// 6. Internal dependent hom over base arrows
// -------------------------------------------------------------------------------------------------

sequential symbol fib_cov_tapp0_fapp0 : Î  [Z : Cat] (M : Ď„ (Functor Z Cat_cat)),
  Î  [x y : Ď„ (Obj Z)], Î  (f : Ď„ (Hom Z x y)), Î  (u : Ď„ (Obj (fapp0 M x))),
  Ď„ (Obj (fapp0 M y));

rule fapp0 (@fapp1_fapp0 $Z Cat_cat $M $x $y $f) $u
  â†Ş @fib_cov_tapp0_fapp0 $Z $M $x $y $f $u;

rule @fib_cov_tapp0_fapp0 $Z $M $x $x (id $Z $x) $u â†Ş $u;
rule @fib_cov_tapp0_fapp0 $Z $M $y $z $g (@fib_cov_tapp0_fapp0 $Z $M $x $y $f $u)
  â†Ş @fib_cov_tapp0_fapp0 $Z $M $x $z (comp_fapp0 $g $f) $u;

// Internal edge family: for a fixed source x, the fibre at y is Hom_Z(x,y)^op.
symbol Edge_catd [Z : Cat] (x : Ď„ (Obj (Op_cat Z))) : Catd Z;
rule @Fibre_cat $Z (@Edge_catd $Z $x) $y â†Ş Op_cat (Hom_cat $Z $x $y);

// Family whose sections classify, internally, the curried dependent hom at source x.
symbol homd_curry_base_fam [Z : Cat] (E : Catd Z)
  (x : Ď„ (Obj (Op_cat Z))) : Catd Z;
rule @Fibre_cat $Z (@homd_curry_base_fam $Z $E $x) $y
  â†Ş Functor_cat
      (@Fibre_cat $Z (@Edge_catd $Z $x) $y)
      (Functor_cat (@Fibre_cat $Z $E $y) Cat_cat);

// Base functor: x |-> Pi_y Functor(Hom_Z(x,y)^op, Functor(E[y],Cat)).
symbol homd_curry_base [Z : Cat] (E : Catd Z)
  : Ď„ (Functor (Op_cat Z) Cat_cat);
rule @fapp0 (Op_cat $Z) Cat_cat (@homd_curry_base $Z $E) $x
  â†Ş @Pi_cat $Z (@homd_curry_base_fam $Z $E $x);

// Primary internal dependent hom object, suitable for iteration.
constant symbol homd_int : Î  [Z : Cat], Î  (E : Catd Z),
  Ď„ (Functord
      (@Op_catd Z E)
      (@Fibration_cov_catd (Op_cat Z) (@homd_curry_base Z E)));

// Endpoint projection/debugging head. The intended source is homd_int evaluated at x,u,y,v.
sequential symbol homd_eval_func [Z : Cat] (E : Catd Z)
  (x : Ď„ (Obj Z)) (u : Ď„ (Fibre E x))
  (y : Ď„ (Obj Z)) (v : Ď„ (Fibre E y))
  : Ď„ (Functor (Op_cat (Hom_cat Z x y)) Cat_cat);

// Compatibility alias for the first v3 iteration name. It is not the internal primitive.
symbol Homd_func [Z : Cat] (E : Catd Z)
  (x : Ď„ (Obj Z)) (u : Ď„ (Fibre E x))
  (y : Ď„ (Obj Z)) (v : Ď„ (Fibre E y))
  : Ď„ (Functor (Op_cat (Hom_cat Z x y)) Cat_cat)
â‰” @homd_eval_func Z E x u y v;

rule @fapp0 (Op_cat (Hom_cat $Z $x $y)) Cat_cat
      (@homd_eval_func $Z (@Fibration_cov_catd $Z $M) $x $u $y $v)
      $f
  â†Ş Hom_cat (fapp0 $M $y)
       (@fib_cov_tapp0_fapp0 $Z $M $x $y $f $u)
       $v;

rule Hom_cat (@Sigma_cat $Z $E) (Struct_sigma $x $u) (Struct_sigma $y $v)
  â†Ş Op_cat
      (@Sigma_cat
        (Op_cat (Hom_cat $Z $x $y))
        (@Fibration_cov_catd
          (Op_cat (Hom_cat $Z $x $y))
          (@homd_eval_func $Z $E $x $u $y $v)));

// -------------------------------------------------------------------------------------------------
// 7. Initial regression assertions for the v3 skeleton
// -------------------------------------------------------------------------------------------------

assert [Z : Cat] (A : Cat) (z : Ď„ (Obj Z)) âŠ˘
  Fibre_cat (Const_catd Z A) z â‰ˇ A;

assert [A B : Cat] (E : Catd B) (F : Ď„ (Functor A B)) (x : Ď„ (Obj A)) âŠ˘
  Fibre_cat (Pullback_catd E F) x â‰ˇ Fibre_cat E (fapp0 F x);

assert [Z : Cat] (E : Catd Z) (z : Ď„ (Obj (Op_cat Z))) âŠ˘
  Fibre_cat (Op_catd E) z â‰ˇ Op_cat (Fibre_cat E z);

assert [Z : Cat] (z : Ď„ (Obj Z)) âŠ˘
  Fibre_cat (CatCat_catd Z) z â‰ˇ Cat_cat;

assert (Z : Cat) (E : Catd Z) (z : Ď„ (Obj Z)) âŠ˘
  Fibre_cat (Catd_catd E) z â‰ˇ Catd_cat (Fibre_cat E z);

assert [Z : Cat] (x : Ď„ (Obj (Op_cat Z))) (y : Ď„ (Obj Z)) âŠ˘
  @Fibre_cat Z (@Edge_catd Z x) y â‰ˇ Op_cat (Hom_cat Z x y);

assert [Z : Cat] (E : Catd Z) (x : Ď„ (Obj (Op_cat Z))) (y : Ď„ (Obj Z)) âŠ˘
  @Fibre_cat Z (@homd_curry_base_fam Z E x) y
    â‰ˇ Functor_cat (Op_cat (Hom_cat Z x y)) (Functor_cat (Fibre_cat E y) Cat_cat);

assert [Z : Cat] (E : Catd Z) (x : Ď„ (Obj (Op_cat Z))) âŠ˘
  @fapp0 (Op_cat Z) Cat_cat (@homd_curry_base Z E) x
    â‰ˇ @Pi_cat Z (@homd_curry_base_fam Z E x);

assert [Z : Cat] (E : Catd Z) (z : Ď„ (Obj Z)) (u : Ď„ (Fibre E z)) âŠ˘
  fapp0 (Sigma_proj1_func E) (Struct_sigma z u) â‰ˇ z;

assert [Z : Cat] (E : Catd Z) (s t : Ď„ (Obj (Pi_cat E))) (z : Ď„ (Obj Z)) âŠ˘
  Fibre_cat (PiHom_catd E s t) z â‰ˇ Hom_cat (Fibre_cat E z) (piapp0 s z) (piapp0 t z);

assert [Z : Cat] (E D : Catd Z) âŠ˘
  Functord_cat E D â‰ˇ Pi_cat (Functor_catd E D);

assert [Z : Cat] (E D : Catd Z) (FF : Ď„ (Functord E D))
  (z : Ď„ (Obj Z)) (u : Ď„ (Fibre E z)) âŠ˘
  @fdapp0 Z E D FF z u
    â‰ˇ @fapp0
        (Fibre_cat E z)
        (Fibre_cat D z)
        (@piapp0 Z (Functor_catd E D) FF z)
        u;

assert [Z : Cat] (M : Ď„ (Functor Z Cat_cat))
  (x y : Ď„ (Obj Z)) (u : Ď„ (Obj (fapp0 M x))) (v : Ď„ (Obj (fapp0 M y)))
  (f : Ď„ (Hom Z x y)) âŠ˘
  fapp0 (homd_eval_func (Fibration_cov_catd M) x u y v) f
    â‰ˇ Hom_cat (fapp0 M y) (@fib_cov_tapp0_fapp0 Z M x y f u) v;

assert [Z : Cat] (M : Ď„ (Functor Z Cat_cat))
  (x y : Ď„ (Obj Z)) (u : Ď„ (Obj (fapp0 M x))) (v : Ď„ (Obj (fapp0 M y)))
  (f : Ď„ (Hom Z x y)) âŠ˘
  fapp0 (Homd_func (Fibration_cov_catd M) x u y v) f
    â‰ˇ Hom_cat (fapp0 M y) (@fib_cov_tapp0_fapp0 Z M x y f u) v;
