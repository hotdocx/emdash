    (fapp0 (@homd_ff_tgt_func K E D FF x u y) v)
    (@fdapp1_int_presheaf_arrow K E D FF x u y v)
    ≡ @fdapp1_int_hom_func K E D FF x y p u v;

// From emdash3_2.lp:8316.
assert [K : Cat] (E : τ (Catd K))
  (s : τ (Obj (Pi_cat E)))
  (x y : τ (Obj K)) ⊢
  @homd_
    K
    (@Const_catd K Terminal_cat)
    E
    s
    x
    (@piapp0 K E s x)
    y
    Terminal_obj
    ≡ @homd_
        K
        E
        E
        (@id_funcd K E)
        x
        (@piapp0 K E s x)
        y
        (@piapp0 K E s y);

// Cat-valued profunctor facade and representable hom action.
assert [A B : Cat] ⊢
  Prof_base A B ≡ Product_cat (Op_cat A) B;

assert [A B : Cat] ⊢
  Prof_cat A B ≡ Catd_cat (Product_cat (Op_cat A) B);

assert [A B : Cat] ⊢
  Prof A B ≡ Obj (Catd_cat (Product_cat (Op_cat A) B));

assert [A B X : Cat]
  (F : τ (Functor A X))
  (G : τ (Functor B X))
  (a : τ (Obj A))
  (b : τ (Obj B)) ⊢
  Fibre_cat
    (@Hom_prof_along A B X F G)
    (Struct_sigma a b)
  ≡ Hom_cat X (fapp0 F a) (fapp0 G b);

assert [A B X : Cat]
  (F : τ (Functor A X))
  (G : τ (Functor B X))
  (a a' : τ (Obj A))
  (b b' : τ (Obj B)) ⊢
  @fapp1_func
    (Product_cat (Op_cat A) B)
    Cat_cat
    (@Hom_prof_along A B X F G)
    (Struct_sigma a b)
    (Struct_sigma a' b')
  ≡ @Hom_prof_along_fapp1_func
      A B X F G
      (Struct_sigma a b)
      (Struct_sigma a' b');

assert [A B X : Cat]
  (F : τ (Functor A X))
  (G : τ (Functor B X))
  (a a' : τ (Obj A))
  (b b' : τ (Obj B))
  (p : τ (Hom A a' a))
  (q : τ (Hom B b b')) ⊢
  @fapp1_fapp0
    (Product_cat (Op_cat A) B)
    Cat_cat
    (@Hom_prof_along A B X F G)
    (Struct_sigma a b)
    (Struct_sigma a' b')
    (Struct_sigma p q)
  ≡ @comp_cat_fapp0
      (Hom_cat X (fapp0 F a) (fapp0 G b))
      (Hom_cat X (fapp0 F a') (fapp0 G b))
      (Hom_cat X (fapp0 F a') (fapp0 G b'))
      (@hom_postcomp_func
        X B G (fapp0 F a') b b' q)
      (@hom_precomp_along_func
        A X F (fapp0 G b) a' a p);

assert [A B X : Cat]
  (F : τ (Functor A X))
  (G : τ (Functor B X))
  (a a' : τ (Obj A))
  (b b' : τ (Obj B))
  (p : τ (Hom A a' a))
  (q : τ (Hom B b b'))
  (h : τ (Hom X (fapp0 F a) (fapp0 G b))) ⊢
  fapp0
    (@fapp1_fapp0
      (Product_cat (Op_cat A) B)
      Cat_cat
      (@Hom_prof_along A B X F G)
      (Struct_sigma a b)
      (Struct_sigma a' b')
      (Struct_sigma p q))
    h
  ≡ @comp_fapp0
      X
      (fapp0 F a')
      (fapp0 G b)
      (fapp0 G b')
      (fapp1_fapp0 G q)
      (@comp_fapp0
        X
        (fapp0 F a')
        (fapp0 F a)
        (fapp0 G b)
        h
        (fapp1_fapp0 F p));

assert [B X : Cat]
  (G : τ (Functor B X))
  (x : τ (Obj X))
  (b : τ (Obj B)) ⊢
  Fibre_cat (@Hom_prof B X G) (Struct_sigma x b)
  ≡ Hom_cat X x (fapp0 G b);

assert [X : Cat]
  (x y : τ (Obj X)) ⊢
  Fibre_cat (@Unit_prof X) (Struct_sigma x y)
  ≡ Hom_cat X x y;

assert [A B X : Cat]
  (F : τ (Functor A X))
  (G : τ (Functor B X))
  (a : τ (Obj A))
  (b : τ (Obj B)) ⊢
  Fibre_cat
    (@Hom_catd
      (Product_cat (Op_cat A) B)
      (@Const_catd (Product_cat (Op_cat A) B) X)
      (@comp_cat_fapp0
        (Product_cat (Op_cat A) B)
        (Op_cat A)
        (Op_cat X)
        (@Op_func A X F)
        (@Product_projL_func (Op_cat A) B))
      (@comp_cat_fapp0
        (Product_cat (Op_cat A) B)
        B
        X
        G
        (@Product_projR_func (Op_cat A) B)))
    (Struct_sigma a b)
  ≡ Fibre_cat
      (@Hom_prof_along A B X F G)
      (Struct_sigma a b);

// General two-sided product maps used by profunctor reindexing.
assert [A A' B B' : Cat]
  (F : τ (Functor A A'))
  (G : τ (Functor B B'))
  (a : τ (Obj A))
  (b : τ (Obj B)) ⊢
  @fapp0
    (Product_cat A B)
    (Product_cat A' B')
    (@Product_map_func A A' B B' F G)
    (Struct_sigma a b)
  ≡ @Product_pair A' B' (fapp0 F a) (fapp0 G b);

assert [A A' B B' : Cat]
  (F : τ (Functor A A'))
  (G : τ (Functor B B'))
  (a a' : τ (Obj A))
  (b b' : τ (Obj B))
  (p : τ (Hom A a a'))
  (q : τ (Hom B b b')) ⊢
  sigma_Fst
    (@fapp1_fapp0
      (Product_cat A B)
      (Product_cat A' B')
      (@Product_map_func A A' B B' F G)
      (Struct_sigma a b)
      (Struct_sigma a' b')
      (Struct_sigma p q))
  ≡ fapp1_fapp0 F p;

assert [A A' B B' : Cat]
  (F : τ (Functor A A'))
  (G : τ (Functor B B'))
  (a a' : τ (Obj A))
  (b b' : τ (Obj B))
  (p : τ (Hom A a a'))
  (q : τ (Hom B b b')) ⊢
  sigma_Snd
    (@fapp1_fapp0
      (Product_cat A B)
      (Product_cat A' B')
      (@Product_map_func A A' B B' F G)
      (Struct_sigma a b)
      (Struct_sigma a' b')
      (Struct_sigma p q))
  ≡ fapp1_fapp0 G q;

assert [A A' B B' : Cat]
  (F : τ (Functor A A'))
  (G : τ (Functor B B'))
  (a a' : τ (Obj A))
  (b b' : τ (Obj B)) ⊢
  sigma_Fst
    (@fapp1_func
      (Product_cat A B)
      (Product_cat A' B')
      (@Product_map_func A A' B B' F G)
      (Struct_sigma a b)
      (Struct_sigma a' b'))
  ≡ @comp_cat_fapp0
      (Product_cat (Hom_cat A a a') (Hom_cat B b b'))
      (Hom_cat A a a')
      (Hom_cat A' (fapp0 F a) (fapp0 F a'))
      (@fapp1_func A A' F a a')
      (@Product_projL_func (Hom_cat A a a') (Hom_cat B b b'));

assert [A A' B B' : Cat]
  (F : τ (Functor A A'))
  (G : τ (Functor B B'))
  (a a' : τ (Obj A))
  (b b' : τ (Obj B)) ⊢
  sigma_Snd
    (@fapp1_func
      (Product_cat A B)
      (Product_cat A' B')
      (@Product_map_func A A' B B' F G)
      (Struct_sigma a b)
      (Struct_sigma a' b'))
  ≡ @comp_cat_fapp0
      (Product_cat (Hom_cat A a a') (Hom_cat B b b'))
      (Hom_cat B b b')
      (Hom_cat B' (fapp0 G b) (fapp0 G b'))
      (@fapp1_func B B' G b b')
      (@Product_projR_func (Hom_cat A a a') (Hom_cat B b b'));

// Stable profunctor reindexing and its representable fold.
assert [A A' B B' : Cat]
  (R : τ (Catd (Product_cat (Op_cat A) B)))
  (F : τ (Functor A' A))
  (G : τ (Functor B' B))
  (a : τ (Obj A'))
  (b : τ (Obj B')) ⊢
  Fibre_cat
    (@Prof_reindex A A' B B' R F G)
    (Struct_sigma a b)
  ≡ Fibre_cat
      R
      (@Product_pair (Op_cat A) B (fapp0 F a) (fapp0 G b));

assert [A A' B B' : Cat]
  (R : τ (Catd (Product_cat (Op_cat A) B)))
  (F : τ (Functor A' A))
  (G : τ (Functor B' B))
  (a a' : τ (Obj A'))
  (b b' : τ (Obj B')) ⊢
  @fapp1_func
    (Product_cat (Op_cat A') B')
    Cat_cat
    (@Prof_reindex A A' B B' R F G)
    (Struct_sigma a b)
    (Struct_sigma a' b')
  ≡ @Prof_reindex_fapp1_func
      A A' B B' R F G
      (Struct_sigma a b)
      (Struct_sigma a' b');

assert [A A' B B' : Cat]
  (R : τ (Catd (Product_cat (Op_cat A) B)))
  (F : τ (Functor A' A))
  (G : τ (Functor B' B))
  (a a' : τ (Obj A'))
  (b b' : τ (Obj B'))
  (p : τ (Hom A' a' a))
  (q : τ (Hom B' b b')) ⊢
  @fapp1_fapp0
    (Product_cat (Op_cat A') B')
    Cat_cat
    (@Prof_reindex A A' B B' R F G)
    (Struct_sigma a b)
    (Struct_sigma a' b')
    (Struct_sigma p q)
  ≡ @fapp1_fapp0
      (Product_cat (Op_cat A) B)
      Cat_cat
      R
      (Struct_sigma (fapp0 F a) (fapp0 G b))
      (Struct_sigma (fapp0 F a') (fapp0 G b'))
      (Struct_sigma (fapp1_fapp0 F p) (fapp1_fapp0 G q));

assert [A A' B B' X : Cat]
  (F : τ (Functor A X))
  (G : τ (Functor B X))
  (F' : τ (Functor A' A))
  (G' : τ (Functor B' B)) ⊢
  @Prof_reindex
    A A' B B'
    (@Hom_prof_along A B X F G)
    F'
    G'
  ≡ @Hom_prof_along
      A' B' X
      (@comp_cat_fapp0 A' A X F F')
      (@comp_cat_fapp0 B' B X G G');

assert [A B X : Cat]
  (F : τ (Functor A X))
  (G : τ (Functor B X)) ⊢
  @Prof_reindex
    X A B B
    (@Hom_prof B X G)
    F
    (@id_func B)
  ≡ @Hom_prof_along A B X F G;

// Shaped profunctor cells and elements.
assert [A A' B B' : Cat]
  (R' : τ (Catd (Product_cat (Op_cat A') B')))
  (F : τ (Functor A' A))
  (R : τ (Catd (Product_cat (Op_cat A) B)))
  (G : τ (Functor B' B)) ⊢
  @Prof_transf_cat A A' B B' R' F R G
  ≡ @Functord_cat
      (Product_cat (Op_cat A') B')
      R'
      (@Prof_reindex A A' B B' R F G);

assert [I A B : Cat]
  (F : τ (Functor I A))
  (R : τ (Catd (Product_cat (Op_cat A) B)))
  (G : τ (Functor I B)) ⊢
  @Prof_hom_cat I A B F R G
  ≡ @Functord_cat
      (Product_cat (Op_cat I) I)
      (@Unit_prof I)
      (@Prof_reindex A I B I R F G);

assert [I A B : Cat]
  (F : τ (Functor I A))
  (R : τ (Catd (Product_cat (Op_cat A) B)))
  (G : τ (Functor I B)) ⊢
  @Prof_hom I A B F R G
  ≡ Obj
      (@Functord_cat
        (Product_cat (Op_cat I) I)
        (@Unit_prof I)
        (@Prof_reindex A I B I R F G));

assert [I C : Cat]
  (F G : τ (Functor I C)) ⊢
  @Prof_hom_cat I C C F (@Unit_prof C) G
  ≡ @Functord_cat
      (Product_cat (Op_cat I) I)
      (@Unit_prof I)
      (@Hom_prof_along I I C F G);

assert [A A' B B' X : Cat]
  (R' : τ (Catd (Product_cat (Op_cat A') B')))
  (F : τ (Functor A' A))
  (H : τ (Functor A X))
  (K : τ (Functor B X))
  (G : τ (Functor B' B)) ⊢
  @Prof_transf_cat
    A A' B B'
    R'
    F
    (@Hom_prof_along A B X H K)
    G
  ≡ @Functord_cat
      (Product_cat (Op_cat A') B')
      R'
      (@Hom_prof_along
        A' B' X
        (@comp_cat_fapp0 A' A X H F)
        (@comp_cat_fapp0 B' B X K G));

// Primitive profunctor tensor and exposed-endpoint reindexing.
assert [A B : Cat]
  (R : τ (Catd (Product_cat (Op_cat A) B))) ⊢
  @Prof_reindex A A B B R (@id_func A) (@id_func B)
  ≡ R;

assert [A A' B X X' : Cat]
  (R : τ (Catd (Product_cat (Op_cat A) B)))
  (S : τ (Catd (Product_cat (Op_cat B) X)))
  (F : τ (Functor A' A))
  (G : τ (Functor X' X)) ⊢
  @Prof_reindex
    A A' X X'
    (@Prof_tensor A B X R S)
    F
    G
  ≡ @Prof_tensor
      A' B X'
      (@Prof_reindex A A' B B R F (@id_func B))
      (@Prof_reindex B B X X' S (@id_func B) G);

assert [A A' B X : Cat]
  (R : τ (Catd (Product_cat (Op_cat A) B)))
  (S : τ (Catd (Product_cat (Op_cat B) X)))
  (F : τ (Functor A' A)) ⊢
  @Prof_reindex
    A A' X X
    (@Prof_tensor A B X R S)
    F
    (@id_func X)
  ≡ @Prof_tensor
      A' B X
      (@Prof_reindex A A' B B R F (@id_func B))
      S;

assert [A B X X' : Cat]
  (R : τ (Catd (Product_cat (Op_cat A) B)))
  (S : τ (Catd (Product_cat (Op_cat B) X)))
  (G : τ (Functor X' X)) ⊢
  @Prof_reindex
    A A X X'
    (@Prof_tensor A B X R S)
    (@id_func A)
    G
  ≡ @Prof_tensor
      A B X'
      R
      (@Prof_reindex B B X X' S (@id_func B) G);

assert [A B X : Cat]
  (R : τ (Catd (Product_cat (Op_cat A) B)))
  (S : τ (Catd (Product_cat (Op_cat B) X))) ⊢
  @Prof_reindex
    A A X X
    (@Prof_tensor A B X R S)
    (@id_func A)
    (@id_func X)
  ≡ @Prof_tensor A B X R S;

assert [A A' B X Y : Cat]
  (H : τ (Functor A Y))
  (K : τ (Functor B Y))
  (S : τ (Catd (Product_cat (Op_cat B) X)))
  (F : τ (Functor A' A)) ⊢
  @Prof_reindex
    A A' X X
    (@Prof_tensor
      A B X
      (@Hom_prof_along A B Y H K)
      S)
    F
    (@id_func X)
  ≡ @Prof_tensor
      A' B X
      (@Hom_prof_along
        A' B Y
        (@comp_cat_fapp0 A' A Y H F)
        K)
      S;

assert [A A' B B' X X' : Cat]
  [R' : τ (Catd (Product_cat (Op_cat A') B'))]
  [S' : τ (Catd (Product_cat (Op_cat B') X'))]
  [R : τ (Catd (Product_cat (Op_cat A) B))]
  [S : τ (Catd (Product_cat (Op_cat B) X))]
  [F : τ (Functor A' A)]
  [M : τ (Functor B' B)]
  [G : τ (Functor X' X)]
  (r : τ (Obj (@Prof_transf_cat A A' B B' R' F R M)))
  (s : τ (Obj (@Prof_transf_cat B B' X X' S' M S G))) ⊢
  @Prof_tensor_transf
    A A' B B' X X' R' S' R S F M G r s
  : τ (Obj
      (@Prof_transf_cat
        A A' X X'
        (@Prof_tensor A' B' X' R' S')
        F
        (@Prof_tensor A B X R S)
        G));

assert [I A B X : Cat]
  [R : τ (Catd (Product_cat (Op_cat A) B))]
  [S : τ (Catd (Product_cat (Op_cat B) X))]
  [F : τ (Functor I A)]
  [G : τ (Functor I X)]
  (M : τ (Functor I B))
  (r : τ (@Prof_hom I A B F R M))
  (s : τ (@Prof_hom I B X M S G)) ⊢
  @Prof_tensor_hom_hom I A B X R S F G M r s
  : τ (@Prof_hom I A X F (@Prof_tensor A B X R S) G);

assert [J A' A B X : Cat]
  [R' : τ (Catd (Product_cat (Op_cat A') J))]
  [R : τ (Catd (Product_cat (Op_cat A) B))]
  [S : τ (Catd (Product_cat (Op_cat B) X))]
  [F : τ (Functor A' A)]
  [G : τ (Functor J X)]
  (M : τ (Functor J B))
  (r : τ (Obj (@Prof_transf_cat A A' B J R' F R M)))
  (s : τ (@Prof_hom J B X M S G)) ⊢
  @Prof_tensor_hom_transf
    J A' A B X R' R S F G M r s
  : τ (Obj
      (@Prof_transf_cat
        A A' X J
        R'
        F
        (@Prof_tensor A B X R S)
        G));

assert [A B A' B' J : Cat]
  [P : τ (Catd (Product_cat (Op_cat A) B))]
  [P' : τ (Catd (Product_cat (Op_cat A') B'))]
  [F : τ (Functor A A')]
  [G : τ (Functor B B')]
  (pp : τ (Obj (@Prof_transf_cat A' A B' B P F P' G)))
  (N : τ (Functor J B')) ⊢
  @Prof_coyoneda_unit_tensor_cov_transf
    A B A' B' P P' F G pp J N
  : τ (Obj
      (@Prof_transf_cat
        A' A B' J
        (@Prof_tensor A B J P (@Hom_prof_along B J B' G N))
        F
        P'
        N));

assert [A B A' B' I : Cat]
  [P : τ (Catd (Product_cat (Op_cat A) B))]
  [P' : τ (Catd (Product_cat (Op_cat A') B'))]
  [F : τ (Functor A A')]
  [G : τ (Functor B B')]
  (pp : τ (Obj (@Prof_transf_cat A' A B' B P F P' G)))
  (M : τ (Functor I A')) ⊢
  @Prof_coyoneda_unit_tensor_con_transf
    A B A' B' P P' F G pp I M
  : τ (Obj
      (@Prof_transf_cat
        A' I B' B
        (@Prof_tensor I A B (@Hom_prof_along I A A' M F) P)
        M
        P'
        G));

// General equipment-cell reindexing and composition.
assert [A B C D : Cat]
  (F : τ (Functor A B))
  (G : τ (Functor B C))
  (H : τ (Functor C D)) ⊢
  @comp_cat_fapp0
    A C D H
    (@comp_cat_fapp0 A B C G F)
  ≡ @comp_cat_fapp0
      A B D
      (@comp_cat_fapp0 B C D H G)
      F;

assert [A A' A'' B B' B'' : Cat]
  (R : τ (Catd (Product_cat (Op_cat A) B)))
  (F : τ (Functor A' A))
  (G : τ (Functor B' B))
  (F' : τ (Functor A'' A'))
  (G' : τ (Functor B'' B')) ⊢
  @Prof_reindex
    A' A'' B' B''
    (@Prof_reindex A A' B B' R F G)
    F'
    G'
  ≡ @Prof_reindex
      A A'' B B''
      R
      (@comp_cat_fapp0 A'' A' A F F')
      (@comp_cat_fapp0 B'' B' B G G');

assert [A A' B B' : Cat]
  (F : τ (Functor A' A))
  (G : τ (Functor B' B))
  (R : τ (Catd (Product_cat (Op_cat A) B))) ⊢
  @fapp0
    (@Catd_cat (Product_cat (Op_cat A) B))
    (@Catd_cat (Product_cat (Op_cat A') B'))
    (@Prof_reindex_func A A' B B' F G)
    R
  ≡ @Prof_reindex A A' B B' R F G;

assert [A A' B B' : Cat]
  [R S : τ (Catd (Product_cat (Op_cat A) B))]
  (r : τ (Functord R S))
  (F : τ (Functor A' A))
  (G : τ (Functor B' B)) ⊢
  @Prof_reindex_transf A A' B B' R S r F G
  : τ (Functord
      (@Prof_reindex A A' B B' R F G)
      (@Prof_reindex A A' B B' S F G));

assert [A B : Cat]
  [R S : τ (Catd (Product_cat (Op_cat A) B))]
  (r : τ (Functord R S)) ⊢
  @Prof_reindex_transf
    A A B B
    R S r
    (@id_func A)
    (@id_func B)
  ≡ r;

assert [A0 A1 A2 B0 B1 B2 : Cat]
  [R0 : τ (Catd (Product_cat (Op_cat A0) B0))]
  [R1 : τ (Catd (Product_cat (Op_cat A1) B1))]
  [R2 : τ (Catd (Product_cat (Op_cat A2) B2))]
  [F01 : τ (Functor A0 A1)]
  [G01 : τ (Functor B0 B1)]
  [F12 : τ (Functor A1 A2)]
  [G12 : τ (Functor B1 B2)]
  (s : τ (Obj (@Prof_transf_cat A2 A1 B2 B1 R1 F12 R2 G12)))
  (r : τ (Obj (@Prof_transf_cat A1 A0 B1 B0 R0 F01 R1 G01))) ⊢
  @Prof_comp_transf
    A0 A1 A2 B0 B1 B2
    R0 R1 R2 F01 G01 F12 G12
    s r
  : τ (Obj
      (@Prof_transf_cat
        A2 A0 B2 B0
        R0
        (@comp_cat_fapp0 A0 A1 A2 F12 F01)
        R2
        (@comp_cat_fapp0 B0 B1 B2 G12 G01)));

assert [A0 A1 A2 B0 B1 B2 : Cat]
  [R0 : τ (Catd (Product_cat (Op_cat A0) B0))]
  [R1 : τ (Catd (Product_cat (Op_cat A1) B1))]
  [R2 : τ (Catd (Product_cat (Op_cat A2) B2))]
  [F01 : τ (Functor A0 A1)]
  [G01 : τ (Functor B0 B1)]
  [F12 : τ (Functor A1 A2)]
  [G12 : τ (Functor B1 B2)]
  (s : τ (Obj (@Prof_transf_cat A2 A1 B2 B1 R1 F12 R2 G12)))
  (r : τ (Obj (@Prof_transf_cat A1 A0 B1 B0 R0 F01 R1 G01))) ⊢
  @comp_catd_fapp0
    (Product_cat (Op_cat A0) B0)
    R0
    (@Prof_reindex A1 A0 B1 B0 R1 F01 G01)
    (@Prof_reindex
      A2 A0 B2 B0
      R2
      (@comp_cat_fapp0 A0 A1 A2 F12 F01)
      (@comp_cat_fapp0 B0 B1 B2 G12 G01))
    (@Prof_reindex_transf
      A1 A0 B1 B0
      R1
      (@Prof_reindex A2 A1 B2 B1 R2 F12 G12)
      s
      F01
      G01)
    r
