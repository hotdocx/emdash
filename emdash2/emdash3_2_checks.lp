// Cat-valued profunctor facade and representable hom action.
assert [A B : Cat] ⊢
  Prof_base A B ≡ Product_cat (Op_cat A) B;

assert [A B : Cat] ⊢
  Prof_cat A B ≡ Catd_cat (Product_cat (Op_cat A) B);

assert [A B : Cat] ⊢
  Prof A B ≡ Obj (Catd_cat (Product_cat (Op_cat A) B));

assert [A B : Cat] (P Q : τ (Prof A B)) ⊢
  ProfMap P Q
  ≡ Functord P Q;

assert [A B : Cat] (P : τ (Prof A B)) ⊢
  @id (Prof_cat A B) P
  : τ (ProfMap P P);

assert [A B : Cat] [P Q R : τ (Prof A B)]
  (q : τ (ProfMap Q R))
  (p : τ (ProfMap P Q)) ⊢
  @comp_fapp0 (Prof_cat A B) P Q R q p
  : τ (ProfMap P R);

assert [A B X : Cat]
  (F : τ (Functor A X))
  (G : τ (Functor B X))
  (a : τ (Obj A))
  (b : τ (Obj B)) ⊢
  Fibre_cat
    (@Hom_prof_along A B X F G)
    (Struct_sigma a b)
  ≡ Hom_cat X (fapp0 F a) (fapp0 G b);

assert [A B X : Cat]
  (F : τ (Functor A X))
  (G : τ (Functor B X))
  (a a' : τ (Obj A))
  (b b' : τ (Obj B)) ⊢
  @fapp1_func
    (Product_cat (Op_cat A) B)
    Cat_cat
    (@Hom_prof_along A B X F G)
    (Struct_sigma a b)
    (Struct_sigma a' b')
  ≡ @Hom_prof_along_fapp1_func
      A B X F G
      (Struct_sigma a b)
      (Struct_sigma a' b');

assert [A B X : Cat]
  (F : τ (Functor A X))
  (G : τ (Functor B X))
  (a a' : τ (Obj A))
  (b b' : τ (Obj B))
  (p : τ (Hom A a' a))
  (q : τ (Hom B b b')) ⊢
  @fapp1_fapp0
    (Product_cat (Op_cat A) B)
    Cat_cat
    (@Hom_prof_along A B X F G)
    (Struct_sigma a b)
    (Struct_sigma a' b')
    (Struct_sigma p q)
  ≡ @comp_cat_fapp0
      (Hom_cat X (fapp0 F a) (fapp0 G b))
      (Hom_cat X (fapp0 F a') (fapp0 G b))
      (Hom_cat X (fapp0 F a') (fapp0 G b'))
      (@hom_postcomp_func
        X B G (fapp0 F a') b b' q)
      (@hom_precomp_along_func
        A X F (fapp0 G b) a' a p);

assert [A B X : Cat]
  (F : τ (Functor A X))
  (G : τ (Functor B X))
  (a a' : τ (Obj A))
  (b b' : τ (Obj B))
  (p : τ (Hom A a' a))
  (q : τ (Hom B b b'))
  (h : τ (Hom X (fapp0 F a) (fapp0 G b))) ⊢
  fapp0
    (@fapp1_fapp0
      (Product_cat (Op_cat A) B)
      Cat_cat
      (@Hom_prof_along A B X F G)
      (Struct_sigma a b)
      (Struct_sigma a' b')
      (Struct_sigma p q))
    h
  ≡ @comp_fapp0
      X
      (fapp0 F a')
      (fapp0 G b)
      (fapp0 G b')
      (fapp1_fapp0 G q)
      (@comp_fapp0
        X
        (fapp0 F a')
        (fapp0 F a)
        (fapp0 G b)
        h
        (fapp1_fapp0 F p));

assert [B X : Cat]
  (G : τ (Functor B X))
  (x : τ (Obj X))
  (b : τ (Obj B)) ⊢
  Fibre_cat (@Hom_prof B X G) (Struct_sigma x b)
  ≡ Hom_cat X x (fapp0 G b);

assert [X : Cat]
  (x y : τ (Obj X)) ⊢
  Fibre_cat (@Unit_prof X) (Struct_sigma x y)
  ≡ Hom_cat X x y;

assert [A B X : Cat]
  (F : τ (Functor A X))
  (G : τ (Functor B X))
  (a : τ (Obj A))
  (b : τ (Obj B)) ⊢
  Fibre_cat
    (@Hom_catd
      (Product_cat (Op_cat A) B)
      (@Const_catd (Product_cat (Op_cat A) B) X)
      (@comp_cat_fapp0
        (Product_cat (Op_cat A) B)
        (Op_cat A)
        (Op_cat X)
        (@Op_func A X F)
        (@Product_projL_func (Op_cat A) B))
      (@comp_cat_fapp0
        (Product_cat (Op_cat A) B)
        B
        X
        G
        (@Product_projR_func (Op_cat A) B)))
    (Struct_sigma a b)
  ≡ Fibre_cat
      (@Hom_prof_along A B X F G)
      (Struct_sigma a b);

// General two-sided product maps used by profunctor reindexing.
assert [A A' B B' : Cat]
  (F : τ (Functor A A'))
  (G : τ (Functor B B'))
  (a : τ (Obj A))
  (b : τ (Obj B)) ⊢
  @fapp0
    (Product_cat A B)
    (Product_cat A' B')
    (@Product_map_func A A' B B' F G)
    (Struct_sigma a b)
  ≡ @Product_pair A' B' (fapp0 F a) (fapp0 G b);

assert [A A' B B' : Cat]
  (F : τ (Functor A A'))
  (G : τ (Functor B B'))
  (a a' : τ (Obj A))
  (b b' : τ (Obj B))
  (p : τ (Hom A a a'))
  (q : τ (Hom B b b')) ⊢
  sigma_Fst
    (@fapp1_fapp0
      (Product_cat A B)
      (Product_cat A' B')
      (@Product_map_func A A' B B' F G)
      (Struct_sigma a b)
      (Struct_sigma a' b')
      (Struct_sigma p q))
  ≡ fapp1_fapp0 F p;

assert [A A' B B' : Cat]
  (F : τ (Functor A A'))
  (G : τ (Functor B B'))
  (a a' : τ (Obj A))
  (b b' : τ (Obj B))
  (p : τ (Hom A a a'))
  (q : τ (Hom B b b')) ⊢
  sigma_Snd
    (@fapp1_fapp0
      (Product_cat A B)
      (Product_cat A' B')
      (@Product_map_func A A' B B' F G)
      (Struct_sigma a b)
      (Struct_sigma a' b')
      (Struct_sigma p q))
  ≡ fapp1_fapp0 G q;

assert [A A' B B' : Cat]
  (F : τ (Functor A A'))
  (G : τ (Functor B B'))
  (a a' : τ (Obj A))
  (b b' : τ (Obj B)) ⊢
  sigma_Fst
    (@fapp1_func
      (Product_cat A B)
      (Product_cat A' B')
      (@Product_map_func A A' B B' F G)
      (Struct_sigma a b)
      (Struct_sigma a' b'))
  ≡ @comp_cat_fapp0
      (Product_cat (Hom_cat A a a') (Hom_cat B b b'))
      (Hom_cat A a a')
      (Hom_cat A' (fapp0 F a) (fapp0 F a'))
      (@fapp1_func A A' F a a')
      (@Product_projL_func (Hom_cat A a a') (Hom_cat B b b'));

assert [A A' B B' : Cat]
  (F : τ (Functor A A'))
  (G : τ (Functor B B'))
  (a a' : τ (Obj A))
  (b b' : τ (Obj B)) ⊢
  sigma_Snd
    (@fapp1_func
      (Product_cat A B)
      (Product_cat A' B')
      (@Product_map_func A A' B B' F G)
      (Struct_sigma a b)
      (Struct_sigma a' b'))
  ≡ @comp_cat_fapp0
      (Product_cat (Hom_cat A a a') (Hom_cat B b b'))
      (Hom_cat B b b')
      (Hom_cat B' (fapp0 G b) (fapp0 G b'))
      (@fapp1_func B B' G b b')
      (@Product_projR_func (Hom_cat A a a') (Hom_cat B b b'));

assert [A0 A1 A2 B0 B1 B2 : Cat]
  (F01 : τ (Functor A0 A1))
  (F12 : τ (Functor A1 A2))
  (G01 : τ (Functor B0 B1))
  (G12 : τ (Functor B1 B2)) ⊢
  @comp_cat_fapp0
    (Product_cat A0 B0)
    (Product_cat A1 B1)
    (Product_cat A2 B2)
    (@Product_map_func A1 A2 B1 B2 F12 G12)
    (@Product_map_func A0 A1 B0 B1 F01 G01)
  ≡ @Product_map_func
      A0 A2 B0 B2
      (@comp_cat_fapp0 A0 A1 A2 F12 F01)
      (@comp_cat_fapp0 B0 B1 B2 G12 G01);

assert [A B : Cat] ⊢
  eq_refl
    (@Product_map_func A A B B (@id_func A) (@id_func B))
  : τ (
      @Product_map_func A A B B (@id_func A) (@id_func B)
      =
      @Struct_sigma
        (Obj (Functor_cat (Product_cat A B) A))
        (λ _ : τ (Obj (Functor_cat (Product_cat A B) A)),
          Obj (Functor_cat (Product_cat A B) B))
        (@Product_projL_func A B)
        (@Product_projR_func A B));

assert [A B : Cat] ⊢
  eq_refl
    (@Product_map_func A A B B (@id_func A) (@id_func B))
  : τ (
      @Product_map_func A A B B (@id_func A) (@id_func B)
      =
      @id_func (Product_cat A B));

assert [A A' B B' : Cat]
  (F : τ (Functor A' A))
  (G : τ (Functor B' B))
  (a : τ (Obj A'))
  (b : τ (Obj B')) ⊢
  @fapp0
    (Product_cat (Op_cat A') B')
    (Product_cat (Op_cat A) B)
    (@Prof_reindex_base_func A A' B B' F G)
    (Struct_sigma a b)
  ≡ @fapp0
      (Product_cat (Op_cat A') B')
      (Product_cat (Op_cat A) B)
      (@Product_map_func
        (Op_cat A') (Op_cat A) B' B
        (@Op_func A' A F)
        G)
      (Struct_sigma a b);

assert [A B : Cat]
  (xy : τ (Obj (Product_cat A B))) ⊢
  eq_refl (@id (Product_cat A B) xy)
  : τ (
      @id (Product_cat A B) xy
      =
      @Struct_sigma
        (Obj (Hom_cat A (sigma_Fst xy) (sigma_Fst xy)))
        (λ _ : τ (Obj (Hom_cat A (sigma_Fst xy) (sigma_Fst xy))),
          Obj (Hom_cat B (sigma_Snd xy) (sigma_Snd xy)))
        (@id A (sigma_Fst xy))
        (@id B (sigma_Snd xy)));

// Stable profunctor reindexing and its representable fold.
assert [A A' B B' : Cat]
  (R : τ (Catd (Product_cat (Op_cat A) B)))
  (F : τ (Functor A' A))
  (G : τ (Functor B' B))
  (a : τ (Obj A'))
  (b : τ (Obj B')) ⊢
  Fibre_cat
    (@Prof_reindex A A' B B' R F G)
    (Struct_sigma a b)
  ≡ Fibre_cat
      R
      (@Product_pair (Op_cat A) B (fapp0 F a) (fapp0 G b));

assert [A A' B B' : Cat]
  (R : τ (Catd (Product_cat (Op_cat A) B)))
  (F : τ (Functor A' A))
  (G : τ (Functor B' B))
  (a a' : τ (Obj A'))
  (b b' : τ (Obj B')) ⊢
  @fapp1_func
    (Product_cat (Op_cat A') B')
    Cat_cat
    (@Prof_reindex A A' B B' R F G)
    (Struct_sigma a b)
    (Struct_sigma a' b')
  ≡ @Prof_reindex_fapp1_func
      A A' B B' R F G
      (Struct_sigma a b)
      (Struct_sigma a' b');

assert [A A' B B' : Cat]
  (R : τ (Catd (Product_cat (Op_cat A) B)))
  (F : τ (Functor A' A))
  (G : τ (Functor B' B))
  (a a' : τ (Obj A'))
  (b b' : τ (Obj B'))
  (p : τ (Hom A' a' a))
  (q : τ (Hom B' b b')) ⊢
  @fapp1_fapp0
    (Product_cat (Op_cat A') B')
    Cat_cat
    (@Prof_reindex A A' B B' R F G)
    (Struct_sigma a b)
    (Struct_sigma a' b')
    (Struct_sigma p q)
  ≡ @fapp1_fapp0
      (Product_cat (Op_cat A) B)
      Cat_cat
      R
      (Struct_sigma (fapp0 F a) (fapp0 G b))
      (Struct_sigma (fapp0 F a') (fapp0 G b'))
      (Struct_sigma (fapp1_fapp0 F p) (fapp1_fapp0 G q));

assert [A A' B B' X : Cat]
  (F : τ (Functor A X))
  (G : τ (Functor B X))
  (F' : τ (Functor A' A))
  (G' : τ (Functor B' B)) ⊢
  @Prof_reindex
    A A' B B'
    (@Hom_prof_along A B X F G)
    F'
    G'
  ≡ @Hom_prof_along
      A' B' X
      (@comp_cat_fapp0 A' A X F F')
      (@comp_cat_fapp0 B' B X G G');

assert [A B X : Cat]
  (F : τ (Functor A X))
  (G : τ (Functor B X)) ⊢
  @Prof_reindex
    X A B B
    (@Hom_prof B X G)
    F
    (@id_func B)
  ≡ @Hom_prof_along A B X F G;

assert [J B : Cat]
  (G : τ (Functor J B)) ⊢
  fapp0 (@Hom_prof_func J B) G
  ≡ @Hom_prof J B G;

assert [J B : Cat]
  [G H : τ (Functor J B)] ⊢
  fapp1_func (@Hom_prof_func J B) [G] [H]
  : τ (Functor
      (@Transf_cat J B G H)
      (@Functord_cat
        (Product_cat (Op_cat B) J)
        (@Hom_prof J B G)
        (@Hom_prof J B H)));

assert [J B : Cat]
  [G H : τ (Functor J B)]
  (eta : τ (Transf G H)) ⊢
  fapp1_fapp0 (@Hom_prof_func J B) [G] [H] eta
  : τ (Functord
      (@Hom_prof J B G)
      (@Hom_prof J B H));

assert [J B : Cat]
  [G H : τ (Functor J B)]
  (eta : τ (Transf G H))
  (b : τ (Obj B))
  (j : τ (Obj J)) ⊢
  @tapp0_fapp0
    (Product_cat (Op_cat B) J)
    Cat_cat
    (@Hom_prof J B G)
    (@Hom_prof J B H)
    (Struct_sigma b j)
    (fapp1_fapp0 (@Hom_prof_func J B) eta)
  ≡ @hom_postcomp_func
      B B (@id_func B) b
      (@fapp0 J B G j)
      (@fapp0 J B H j)
      (@tapp0_fapp0 J B G H j eta);

assert [J B : Cat]
  (G : τ (Functor J B)) ⊢
  @fapp1_fapp0
    (Functor_cat J B)
    (@Catd_cat (Product_cat (Op_cat B) J))
    (@Hom_prof_func J B)
    G G
    (@id (Functor_cat J B) G)
  ≡ @id_funcd
      (Product_cat (Op_cat B) J)
      (@Hom_prof J B G);

assert [J B : Cat]
  [G H K : τ (Functor J B)]
  (eta : τ (Transf H K))
  (epsilon : τ (Transf G H)) ⊢
  @comp_catd_fapp0
    (Product_cat (Op_cat B) J)
    (@Hom_prof J B G)
    (@Hom_prof J B H)
    (@Hom_prof J B K)
    (fapp1_fapp0 (@Hom_prof_func J B) eta)
    (fapp1_fapp0 (@Hom_prof_func J B) epsilon)
  ≡ @fapp1_fapp0
      (Functor_cat J B)
      (@Catd_cat (Product_cat (Op_cat B) J))
      (@Hom_prof_func J B)
      G K
      (@comp_fapp0
        (Functor_cat J B)
        G H K eta epsilon);

assert [A B : Cat] (F : τ (Functor A B)) ⊢
  @Companion_prof A B F
  ≡ @Hom_prof_along A B B F (@id_func B);

assert [A B : Cat] (F : τ (Functor A B)) ⊢
  @Conjoint_prof A B F
  ≡ @Hom_prof A B F;

assert [B J : Cat]
  (P : τ (Prof B J))
  (L : τ (Functor J B)) ⊢
  @IsRepresentedBy_iso B J P L
  ≡ IsoEvidence
      (Prof_cat B J)
      P
      (@Conjoint_prof J B L);

assert [B J : Cat]
  (P : τ (Prof B J)) ⊢
  @Representation_iso B J P
  ≡ `Σ_ L : τ (Functor J B),
      @IsRepresentedBy_iso B J P L;

// Shaped profunctor cells and elements.
assert [A A' B B' : Cat]
  (R' : τ (Catd (Product_cat (Op_cat A') B')))
  (F : τ (Functor A' A))
  (R : τ (Catd (Product_cat (Op_cat A) B)))
  (G : τ (Functor B' B)) ⊢
  @Prof_transf_cat A A' B B' R' F R G
  ≡ @Functord_cat
      (Product_cat (Op_cat A') B')
      R'
      (@Prof_reindex A A' B B' R F G);

assert [I A B : Cat]
  (F : τ (Functor I A))
  (R : τ (Catd (Product_cat (Op_cat A) B)))
  (G : τ (Functor I B)) ⊢
  @Prof_hom_cat I A B F R G
  ≡ @Functord_cat
      (Product_cat (Op_cat I) I)
      (@Unit_prof I)
      (@Prof_reindex A I B I R F G);

assert [I A B : Cat]
  (F : τ (Functor I A))
  (R : τ (Catd (Product_cat (Op_cat A) B)))
  (G : τ (Functor I B)) ⊢
  @Prof_hom I A B F R G
  ≡ Obj
      (@Functord_cat
        (Product_cat (Op_cat I) I)
        (@Unit_prof I)
        (@Prof_reindex A I B I R F G));

assert [I C : Cat]
  (F G : τ (Functor I C)) ⊢
  @Prof_hom_cat I C C F (@Unit_prof C) G
  ≡ @Functord_cat
      (Product_cat (Op_cat I) I)
      (@Unit_prof I)
      (@Hom_prof_along I I C F G);

assert [A A' B B' X : Cat]
  (R' : τ (Catd (Product_cat (Op_cat A') B')))
  (F : τ (Functor A' A))
  (H : τ (Functor A X))
  (K : τ (Functor B X))
  (G : τ (Functor B' B)) ⊢
  @Prof_transf_cat
    A A' B B'
    R'
    F
    (@Hom_prof_along A B X H K)
    G
  ≡ @Functord_cat
      (Product_cat (Op_cat A') B')
      R'
      (@Hom_prof_along
        A' B' X
        (@comp_cat_fapp0 A' A X H F)
        (@comp_cat_fapp0 B' B X K G));

// Primitive profunctor tensor and exposed-endpoint reindexing.
assert [A B : Cat]
  (R : τ (Catd (Product_cat (Op_cat A) B))) ⊢
  @Prof_reindex A A B B R (@id_func A) (@id_func B)
  ≡ R;

assert [A A' B X X' : Cat]
  (R : τ (Catd (Product_cat (Op_cat A) B)))
  (S : τ (Catd (Product_cat (Op_cat B) X)))
  (F : τ (Functor A' A))
  (G : τ (Functor X' X)) ⊢
  @Prof_reindex
    A A' X X'
    (@Prof_tensor A B X R S)
    F
    G
  ≡ @Prof_tensor
      A' B X'
      (@Prof_reindex A A' B B R F (@id_func B))
      (@Prof_reindex B B X X' S (@id_func B) G);

assert [A A' B X : Cat]
  (R : τ (Catd (Product_cat (Op_cat A) B)))
  (S : τ (Catd (Product_cat (Op_cat B) X)))
  (F : τ (Functor A' A)) ⊢
  @Prof_reindex
    A A' X X
    (@Prof_tensor A B X R S)
    F
    (@id_func X)
  ≡ @Prof_tensor
      A' B X
      (@Prof_reindex A A' B B R F (@id_func B))
      S;

assert [A B X X' : Cat]
  (R : τ (Catd (Product_cat (Op_cat A) B)))
  (S : τ (Catd (Product_cat (Op_cat B) X)))
  (G : τ (Functor X' X)) ⊢
  @Prof_reindex
    A A X X'
    (@Prof_tensor A B X R S)
    (@id_func A)
    G
  ≡ @Prof_tensor
      A B X'
      R
      (@Prof_reindex B B X X' S (@id_func B) G);

assert [A B X : Cat]
  (R : τ (Catd (Product_cat (Op_cat A) B)))
  (S : τ (Catd (Product_cat (Op_cat B) X))) ⊢
  @Prof_reindex
    A A X X
    (@Prof_tensor A B X R S)
    (@id_func A)
    (@id_func X)
  ≡ @Prof_tensor A B X R S;

assert [A A' B X Y : Cat]
  (H : τ (Functor A Y))
  (K : τ (Functor B Y))
  (S : τ (Catd (Product_cat (Op_cat B) X)))
  (F : τ (Functor A' A)) ⊢
  @Prof_reindex
    A A' X X
    (@Prof_tensor
      A B X
      (@Hom_prof_along A B Y H K)
      S)
    F
    (@id_func X)
  ≡ @Prof_tensor
      A' B X
      (@Hom_prof_along
        A' B Y
        (@comp_cat_fapp0 A' A Y H F)
        K)
      S;

assert [A A' B B' X X' : Cat]
  [R' : τ (Catd (Product_cat (Op_cat A') B'))]
  [S' : τ (Catd (Product_cat (Op_cat B') X'))]
  [R : τ (Catd (Product_cat (Op_cat A) B))]
  [S : τ (Catd (Product_cat (Op_cat B) X))]
  [F : τ (Functor A' A)]
  [M : τ (Functor B' B)]
  [G : τ (Functor X' X)]
  (r : τ (Obj (@Prof_transf_cat A A' B B' R' F R M)))
  (s : τ (Obj (@Prof_transf_cat B B' X X' S' M S G))) ⊢
  @Prof_tensor_transf
    A A' B B' X X' R' S' R S F M G r s
  : τ (Obj
      (@Prof_transf_cat
        A A' X X'
        (@Prof_tensor A' B' X' R' S')
        F
        (@Prof_tensor A B X R S)
        G));

assert [I A B X : Cat]
  [R : τ (Catd (Product_cat (Op_cat A) B))]
  [S : τ (Catd (Product_cat (Op_cat B) X))]
  [F : τ (Functor I A)]
  [G : τ (Functor I X)]
  (M : τ (Functor I B))
  (r : τ (@Prof_hom I A B F R M))
  (s : τ (@Prof_hom I B X M S G)) ⊢
  @Prof_tensor_hom_hom I A B X R S F G M r s
  : τ (@Prof_hom I A X F (@Prof_tensor A B X R S) G);

assert [J A' A B X : Cat]
  [R' : τ (Catd (Product_cat (Op_cat A') J))]
  [R : τ (Catd (Product_cat (Op_cat A) B))]
  [S : τ (Catd (Product_cat (Op_cat B) X))]
  [F : τ (Functor A' A)]
  [G : τ (Functor J X)]
  (M : τ (Functor J B))
  (r : τ (Obj (@Prof_transf_cat A A' B J R' F R M)))
  (s : τ (@Prof_hom J B X M S G)) ⊢
  @Prof_tensor_hom_transf
    J A' A B X R' R S F G M r s
  : τ (Obj
      (@Prof_transf_cat
        A A' X J
        R'
        F
        (@Prof_tensor A B X R S)
        G));

assert [A B A' B' J : Cat]
  [P : τ (Catd (Product_cat (Op_cat A) B))]
  [P' : τ (Catd (Product_cat (Op_cat A') B'))]
  [F : τ (Functor A A')]
  [G : τ (Functor B B')]
  (pp : τ (Obj (@Prof_transf_cat A' A B' B P F P' G)))
  (N : τ (Functor J B')) ⊢
  @Prof_coyoneda_unit_tensor_cov_transf
    A B A' B' P P' F G pp J N
  : τ (Obj
      (@Prof_transf_cat
        A' A B' J
        (@Prof_tensor A B J P (@Hom_prof_along B J B' G N))
        F
        P'
        N));

assert [A B A' B' I : Cat]
  [P : τ (Catd (Product_cat (Op_cat A) B))]
  [P' : τ (Catd (Product_cat (Op_cat A') B'))]
  [F : τ (Functor A A')]
  [G : τ (Functor B B')]
  (pp : τ (Obj (@Prof_transf_cat A' A B' B P F P' G)))
  (M : τ (Functor I A')) ⊢
  @Prof_coyoneda_unit_tensor_con_transf
    A B A' B' P P' F G pp I M
  : τ (Obj
      (@Prof_transf_cat
        A' I B' B
        (@Prof_tensor I A B (@Hom_prof_along I A A' M F) P)
        M
        P'
        G));

// General equipment-cell reindexing and composition.
assert [A B C D : Cat]
  (F : τ (Functor A B))
  (G : τ (Functor B C))
  (H : τ (Functor C D)) ⊢
  @comp_cat_fapp0
    A C D H
    (@comp_cat_fapp0 A B C G F)
  ≡ @comp_cat_fapp0
      A B D
      (@comp_cat_fapp0 B C D H G)
      F;

assert [A A' A'' B B' B'' : Cat]
  (R : τ (Catd (Product_cat (Op_cat A) B)))
  (F : τ (Functor A' A))
  (G : τ (Functor B' B))
  (F' : τ (Functor A'' A'))
  (G' : τ (Functor B'' B')) ⊢
  @Prof_reindex
    A' A'' B' B''
    (@Prof_reindex A A' B B' R F G)
    F'
    G'
  ≡ @Prof_reindex
      A A'' B B''
      R
      (@comp_cat_fapp0 A'' A' A F F')
      (@comp_cat_fapp0 B'' B' B G G');

assert [A A' B B' : Cat]
  (F : τ (Functor A' A))
  (G : τ (Functor B' B))
  (R : τ (Catd (Product_cat (Op_cat A) B))) ⊢
  @fapp0
    (@Catd_cat (Product_cat (Op_cat A) B))
    (@Catd_cat (Product_cat (Op_cat A') B'))
    (@Prof_reindex_func A A' B B' F G)
    R
  ≡ @Prof_reindex A A' B B' R F G;

assert [A A' B B' : Cat]
  (F : τ (Functor A' A))
  (G : τ (Functor B' B))
  (R : τ (Catd (Product_cat (Op_cat A) B))) ⊢
  @fapp0
    (@Catd_cat (Product_cat (Op_cat A) B))
    (@Catd_cat (Product_cat (Op_cat A') B'))
    (@Pullback_catd_func
      (Product_cat (Op_cat A') B')
      (Product_cat (Op_cat A) B)
      (@Prof_reindex_base_func A A' B B' F G))
    R
  ≡ @Prof_reindex A A' B B' R F G;

assert [A A' B B' : Cat]
  (F : τ (Functor A' A))
  (G : τ (Functor B' B)) ⊢
  @Pullback_catd_func
    (Product_cat (Op_cat A') B')
    (Product_cat (Op_cat A) B)
    (@Prof_reindex_base_func A A' B B' F G)
  ≡ @Prof_reindex_func A A' B B' F G;

assert [A A' B B' : Cat]
  (F : τ (Functor A A'))
  (G : τ (Functor B B')) ⊢
  @Pullback_catd_func
    (Product_cat A B)
    (Product_cat A' B')
    (@Product_map_func A A' B B' F G)
  ≡ @Prof_reindex_func
      (Op_cat A')
      (Op_cat A)
      B'
      B
      (@Op_func A A' F)
      G;

assert [A A' B B' : Cat]
  (F : τ (Functor A A'))
  (G : τ (Functor B B'))
  (R : τ (Catd (Product_cat A' B'))) ⊢
  @Pullback_catd
    (Product_cat A B)
    (Product_cat A' B')
    R
    (@Product_map_func A A' B B' F G)
  ≡ @Prof_reindex
      (Op_cat A')
      (Op_cat A)
      B'
      B
      R
      (@Op_func A A' F)
      G;

assert [A A' B B' : Cat]
  (F : τ (Functor A A'))
  (G : τ (Functor B B'))
  (R : τ (Catd (Product_cat A' B'))) ⊢
  @fapp0
    (@Catd_cat (Product_cat A' B'))
    (@Catd_cat (Product_cat A B))
    (@Pullback_catd_func
      (Product_cat A B)
      (Product_cat A' B')
      (@Product_map_func A A' B B' F G))
    R
  ≡ @Prof_reindex
      (Op_cat A')
      (Op_cat A)
      B'
      B
      R
      (@Op_func A A' F)
      G;

assert [A A' B B' : Cat]
  (F : τ (Functor A A'))
  (G : τ (Functor B B'))
  (R : τ (Catd (Product_cat A' B'))) ⊢
  @fapp0
    (@Catd_cat (Product_cat A' B'))
    (@Catd_cat (Product_cat A B))
    (@Pullback_catd_func
      (Product_cat A B)
      (Product_cat A' B')
      (@Product_map_func A A' B B' F G))
    R
  ≡ @Pullback_catd
      (Product_cat A B)
      (Product_cat A' B')
      R
      (@Product_map_func A A' B B' F G);

assert [A A' B B' : Cat]
  (F : τ (Functor A' A))
  (G : τ (Functor B' B))
  (C : Cat) ⊢
  @Prof_reindex
    A A' B B'
    (@Const_catd (Product_cat (Op_cat A) B) C)
    F G
  ≡ @Const_catd (Product_cat (Op_cat A') B') C;

assert [A A' B B' : Cat]
  [R S : τ (Catd (Product_cat (Op_cat A) B))]
  (r : τ (Functord R S))
  (F : τ (Functor A' A))
  (G : τ (Functor B' B)) ⊢
  @Prof_reindex_transf A A' B B' R S r F G
  : τ (Functord
      (@Prof_reindex A A' B B' R F G)
      (@Prof_reindex A A' B B' S F G));

assert [A B : Cat]
  [R S : τ (Catd (Product_cat (Op_cat A) B))]
  (r : τ (Functord R S)) ⊢
  @Prof_reindex_transf
    A A B B
    R S r
    (@id_func A)
    (@id_func B)
  ≡ r;

assert [A0 A1 A2 B0 B1 B2 : Cat]
  [R0 : τ (Catd (Product_cat (Op_cat A0) B0))]
  [R1 : τ (Catd (Product_cat (Op_cat A1) B1))]
  [R2 : τ (Catd (Product_cat (Op_cat A2) B2))]
  [F01 : τ (Functor A0 A1)]
  [G01 : τ (Functor B0 B1)]
  [F12 : τ (Functor A1 A2)]
  [G12 : τ (Functor B1 B2)]
  (s : τ (Obj (@Prof_transf_cat A2 A1 B2 B1 R1 F12 R2 G12)))
  (r : τ (Obj (@Prof_transf_cat A1 A0 B1 B0 R0 F01 R1 G01))) ⊢
  @Prof_comp_transf
    A0 A1 A2 B0 B1 B2
    R0 R1 R2 F01 G01 F12 G12
    s r
  : τ (Obj
      (@Prof_transf_cat
        A2 A0 B2 B0
        R0
        (@comp_cat_fapp0 A0 A1 A2 F12 F01)
        R2
        (@comp_cat_fapp0 B0 B1 B2 G12 G01)));

assert [A A' B B' : Cat]
  [R' : τ (Catd (Product_cat (Op_cat A') B'))]
  [R : τ (Catd (Product_cat (Op_cat A) B))]
  [F : τ (Functor A' A)]
  [G : τ (Functor B' B)]
  (r : τ (Obj (@Prof_transf_cat A A' B B' R' F R G))) ⊢
  @Op_prof_transf A A' B B' R' R F G r
  : τ (Obj
      (@Prof_transf_cat
        (Op_cat B) (Op_cat B')
        (Op_cat A) (Op_cat A')
        (@Op_prof A' B' R')
        (@Op_func B' B G)
        (@Op_prof A B R)
        (@Op_func A' A F)));

assert [A B : Cat]
  (R : τ (Catd (Product_cat (Op_cat A) B))) ⊢
  @Op_prof_transf
    A A B B
    R R
    (@id_func A)
    (@id_func B)
    (@Prof_id_transf A B R)
  ≡ @Prof_id_transf
      (Op_cat B)
      (Op_cat A)
      (@Op_prof A B R);

assert [B J J' : Cat]
  [F : τ (Functor J B)]
  [W : τ (Catd (Product_cat (Op_cat J') J))]
  [L : τ (Functor J' B)]
  (isl : τ (@WeightedLimit_cov B J J' F W L)) ⊢
  @Op_weighted_colimit_con
    (Op_cat B)
    (Op_cat J)
    (Op_cat J')
    (@Op_func J B F)
    (@Op_prof J' J W)
    (@Op_func J' B L)
    (@Op_weighted_limit_cov B J J' F W L isl)
  ≡ isl;

assert [A J J' B : Cat]
  [F : τ (Functor J A)]
  [W : τ (Catd (Product_cat (Op_cat J) J'))]
  [L : τ (Functor J' A)]
  (isc : τ (@WeightedColimit_con A J J' F W L))
  (adj : τ (Adjunction A B)) ⊢
  @left_adjoint_preserves_weighted_colimit_con
    A J J' B F W L isc adj
  : τ (@WeightedColimit_con
      B J J'
      (@comp_cat_fapp0 J A B (@left_adj_func A B adj) F)
      W
      (@comp_cat_fapp0 J' A B (@left_adj_func A B adj) L));

assert [A B : Cat]
  (a : τ (Obj A))
  (b : τ (Obj B)) ⊢
  @fapp0
    (Product_cat (Op_cat A) B)
    Cat_cat
    (@Terminal_prof A B)
    (Struct_sigma a b)
  ≡ Terminal_cat;

assert [A B : Cat]
  (F : τ (Functor A B)) ⊢
  @Prof_func_transf A B F
  : τ (Obj
      (@Prof_transf_cat
        B A B A
        (@Unit_prof A)
        F
        (@Unit_prof B)
        F));

assert [A B : Cat]
  (F : τ (Functor A B)) ⊢
  @Prof_func_hom A B F
  : τ (@Prof_hom A B B F (@Unit_prof B) F);

assert [A : Cat] ⊢
  @Prof_func_transf A A (@id_func A)
  ≡ @Prof_id_transf
      A A
      (@Hom_prof_along A A A (@id_func A) (@id_func A));

assert [A B C : Cat]
  (F : τ (Functor A B))
  (G : τ (Functor B C)) ⊢
  @Prof_comp_transf
    A B C
    A B C
    (@Hom_prof_along A A A (@id_func A) (@id_func A))
    (@Hom_prof_along B B B (@id_func B) (@id_func B))
    (@Hom_prof_along C C C (@id_func C) (@id_func C))
    F F G G
    (@Prof_func_transf B C G)
    (@Prof_func_transf A B F)
  ≡ @Prof_func_transf
      A C
      (@comp_cat_fapp0 A B C G F);

assert [A B : Cat] ⊢
  @join_cross_transf A B
  : τ (Obj
      (@Prof_transf_cat
        (@Join_cat A B) A
        (@Join_cat A B) B
        (@Terminal_prof A B)
        (@join_fst_func A B)
        (@Unit_prof (@Join_cat A B))
        (@join_snd_func A B)));

assert [A B E : Cat]
  (first : τ (Functor A E))
  (second : τ (Functor B E))
  (cross : τ (Obj
      (@Prof_transf_cat
        E A E B
        (@Terminal_prof A B)
        first
        (@Unit_prof E)
        second))) ⊢
  @comp_cat_fapp0
    A
    (@Join_cat A B)
    E
    (@join_elim_func A B E first second cross)
    (@join_fst_func A B)
  ≡ first;

assert [A B E : Cat]
  (first : τ (Functor A E))
  (second : τ (Functor B E))
  (cross : τ (Obj
      (@Prof_transf_cat
        E A E B
        (@Terminal_prof A B)
        first
        (@Unit_prof E)
        second))) ⊢
  @comp_cat_fapp0
    B
    (@Join_cat A B)
    E
    (@join_elim_func A B E first second cross)
    (@join_snd_func A B)
  ≡ second;

assert [A B I : Cat]
  (a : τ (Functor I A))
  (b : τ (Functor I B)) ⊢
  @join_cross_hom A B I a b
  : τ (@Prof_hom
      I
      (@Join_cat A B)
      (@Join_cat A B)
      (@comp_cat_fapp0
        I A (@Join_cat A B)
        (@join_fst_func A B)
        a)
      (@Unit_prof (@Join_cat A B))
      (@comp_cat_fapp0
        I B (@Join_cat A B)
        (@join_snd_func A B)
        b));

assert
  [A0 A1 A2 B0 B1 B2 : Cat]
  [R0 : τ (Catd (Product_cat (Op_cat A0) B0))]
  [R1 : τ (Catd (Product_cat (Op_cat A1) B1))]
  [R2 : τ (Catd (Product_cat (Op_cat A2) B2))]
  [F01 : τ (Functor A0 A1)]
  [G01 : τ (Functor B0 B1)]
  [F12 : τ (Functor A1 A2)]
  [G12 : τ (Functor B1 B2)]
  (s : τ (Obj (@Prof_transf_cat A2 A1 B2 B1 R1 F12 R2 G12)))
  (r : τ (Obj (@Prof_transf_cat A1 A0 B1 B0 R0 F01 R1 G01))) ⊢
  @Op_prof_transf
    A2 A0 B2 B0
    R0 R2
    (@comp_cat_fapp0 A0 A1 A2 F12 F01)
    (@comp_cat_fapp0 B0 B1 B2 G12 G01)
    (@Prof_comp_transf
      A0 A1 A2 B0 B1 B2
      R0 R1 R2
      F01 G01 F12 G12
      s r)
  ≡ @Prof_comp_transf
      (Op_cat B0) (Op_cat B1) (Op_cat B2)
      (Op_cat A0) (Op_cat A1) (Op_cat A2)
      (@Op_prof A0 B0 R0)
      (@Op_prof A1 B1 R1)
      (@Op_prof A2 B2 R2)
      (@Op_func B0 B1 G01)
      (@Op_func A0 A1 F01)
      (@Op_func B1 B2 G12)
      (@Op_func A1 A2 F12)
      (@Op_prof_transf
        A2 A1 B2 B1
        R1 R2 F12 G12
        s)
      (@Op_prof_transf
        A1 A0 B1 B0
        R0 R1 F01 G01
        r);

assert [A0 A1 A2 B0 B1 B2 : Cat]
  [R0 : τ (Catd (Product_cat (Op_cat A0) B0))]
  [R1 : τ (Catd (Product_cat (Op_cat A1) B1))]
  [R2 : τ (Catd (Product_cat (Op_cat A2) B2))]
  [F01 : τ (Functor A0 A1)]
  [G01 : τ (Functor B0 B1)]
  [F12 : τ (Functor A1 A2)]
  [G12 : τ (Functor B1 B2)]
  (s : τ (Obj (@Prof_transf_cat A2 A1 B2 B1 R1 F12 R2 G12)))
  (r : τ (Obj (@Prof_transf_cat A1 A0 B1 B0 R0 F01 R1 G01))) ⊢
  @comp_catd_fapp0
    (Product_cat (Op_cat A0) B0)
    R0
    (@Prof_reindex A1 A0 B1 B0 R1 F01 G01)
    (@Prof_reindex
      A2 A0 B2 B0
      R2
      (@comp_cat_fapp0 A0 A1 A2 F12 F01)
      (@comp_cat_fapp0 B0 B1 B2 G12 G01))
    (@Prof_reindex_transf
      A1 A0 B1 B0
      R1
      (@Prof_reindex A2 A1 B2 B1 R2 F12 G12)
      s
      F01
      G01)
    r
  ≡ @Prof_comp_transf
      A0 A1 A2 B0 B1 B2
      R0 R1 R2 F01 G01 F12 G12
      s r;

assert [A B : Cat]
  (R : τ (Catd (Product_cat (Op_cat A) B))) ⊢
  @Prof_comp_transf
    A A A B B B
    R R R
    (@id_func A) (@id_func B)
    (@id_func A) (@id_func B)
    (@Prof_id_transf A B R)
    (@Prof_id_transf A B R)
  ≡ @Prof_id_transf A B R;

assert [A0 A A' B : Cat]
  [Q : τ (Catd (Product_cat (Op_cat A0) B))]
  [P : τ (Catd (Product_cat (Op_cat A) B))]
  [P' : τ (Catd (Product_cat (Op_cat A') B))]
  [H : τ (Functor A0 A)]
  [F : τ (Functor A A')]
  (qq : τ (Obj
    (@Prof_transf_cat A A0 B B Q H P (@id_func B))))
  (pp : τ (Obj
    (@Prof_transf_cat A' A B B P F P' (@id_func B)))) ⊢
  @Prof_comp_transf
    A0 A A'
    B B B
    Q
    (@Prof_tensor
      A B B P
      (@Hom_prof_along B B B (@id_func B) (@id_func B)))
    P'
    H
    (@id_func B)
    F
    (@id_func B)
    (@Prof_coyoneda_unit_tensor_cov_transf
      A B A' B
      P P'
      F
      (@id_func B)
      pp
      B
      (@id_func B))
    (@Prof_tensor_hom_transf
      B A0 A B B
      Q P
      (@Hom_prof_along B B B (@id_func B) (@id_func B))
      H
      (@id_func B)
      (@id_func B)
      qq
      (@Prof_id_transf
        B B
        (@Hom_prof_along B B B (@id_func B) (@id_func B))))
  ≡ @Prof_comp_transf
      A0 A A'
      B B B
      Q P P'
      H
      (@id_func B)
      F
      (@id_func B)
      pp qq;

assert [A A' B : Cat]
  [P : τ (Catd (Product_cat (Op_cat A) B))]
  [P' : τ (Catd (Product_cat (Op_cat A') B))]
  [H : τ (Functor B A)]
  [F : τ (Functor A A')]
  (p : τ (@Prof_hom B A B H P (@id_func B)))
  (pp : τ (Obj
    (@Prof_transf_cat A' A B B P F P' (@id_func B)))) ⊢
  @Prof_comp_transf
    B A A'
    B B B
    (@Hom_prof_along B B B (@id_func B) (@id_func B))
    (@Prof_tensor
      A B B P
      (@Hom_prof_along B B B (@id_func B) (@id_func B)))
    P'
    H
    (@id_func B)
    F
    (@id_func B)
    (@Prof_coyoneda_unit_tensor_cov_transf
      A B A' B
      P P'
      F
      (@id_func B)
      pp
      B
      (@id_func B))
    (@Prof_tensor_hom_hom
      B A B B
      P
      (@Hom_prof_along B B B (@id_func B) (@id_func B))
      H
      (@id_func B)
      (@id_func B)
      p
      (@Prof_id_transf
        B B
        (@Hom_prof_along B B B (@id_func B) (@id_func B))))
  ≡ @Prof_comp_transf
      B A A'
      B B B
      (@Hom_prof_along B B B (@id_func B) (@id_func B))
      P P'
      H
      (@id_func B)
      F
      (@id_func B)
      pp p;

assert [I X' A B X : Cat]
  [S' : τ (Catd (Product_cat (Op_cat I) X'))]
  [R : τ (Catd (Product_cat (Op_cat A) B))]
  [S : τ (Catd (Product_cat (Op_cat B) X))]
  [F : τ (Functor I A)]
  [G : τ (Functor X' X)]
  (M : τ (Functor I B))
  (r : τ (@Prof_hom I A B F R M))
  (s : τ (Obj (@Prof_transf_cat B I X X' S' M S G))) ⊢
  @Prof_tensor_transf_hom
    I X' A B X S' R S F G M r s
  : τ (Obj
      (@Prof_transf_cat
        A I X X'
        S'
        F
        (@Prof_tensor A B X R S)
        G));

assert [A B0 B B' : Cat]
  [Q : τ (Catd (Product_cat (Op_cat A) B0))]
  [P : τ (Catd (Product_cat (Op_cat A) B))]
  [P' : τ (Catd (Product_cat (Op_cat A) B'))]
  [K : τ (Functor B0 B)]
  [G : τ (Functor B B')]
  (qq : τ (Obj
    (@Prof_transf_cat A A B B0 Q (@id_func A) P K)))
  (pp : τ (Obj
    (@Prof_transf_cat A A B' B P (@id_func A) P' G))) ⊢
  @Prof_comp_transf
    A A A
    B0 B B'
    Q
    (@Prof_tensor
      A A B
      (@Hom_prof_along A A A (@id_func A) (@id_func A))
      P)
    P'
    (@id_func A)
    K
    (@id_func A)
    G
    (@Prof_coyoneda_unit_tensor_con_transf
      A B A B'
      P P'
      (@id_func A)
      G
      pp
      A
      (@id_func A))
    (@Prof_tensor_transf_hom
      A B0 A A B
      Q
      (@Hom_prof_along A A A (@id_func A) (@id_func A))
      P
      (@id_func A)
      K
      (@id_func A)
      (@Prof_id_transf
        A A
        (@Hom_prof_along A A A (@id_func A) (@id_func A)))
      qq)
  ≡ @Prof_comp_transf
      A A A
      B0 B B'
      Q P P'
      (@id_func A)
      K
      (@id_func A)
      G
      pp qq;

assert [A B B' : Cat]
  [P : τ (Catd (Product_cat (Op_cat A) B))]
  [P' : τ (Catd (Product_cat (Op_cat A) B'))]
  [K : τ (Functor A B)]
  [G : τ (Functor B B')]
  (p : τ (@Prof_hom A A B (@id_func A) P K))
  (pp : τ (Obj
    (@Prof_transf_cat A A B' B P (@id_func A) P' G))) ⊢
  @Prof_comp_transf
    A A A
    A B B'
    (@Hom_prof_along A A A (@id_func A) (@id_func A))
    (@Prof_tensor
      A A B
      (@Hom_prof_along A A A (@id_func A) (@id_func A))
      P)
    P'
    (@id_func A)
    K
    (@id_func A)
    G
    (@Prof_coyoneda_unit_tensor_con_transf
      A B A B'
      P P'
      (@id_func A)
      G
      pp
      A
      (@id_func A))
    (@Prof_tensor_hom_hom
      A A A B
      (@Hom_prof_along A A A (@id_func A) (@id_func A))
      P
      (@id_func A)
      K
      (@id_func A)
      (@Prof_id_transf
        A A
        (@Hom_prof_along A A A (@id_func A) (@id_func A)))
      p)
  ≡ @Prof_comp_transf
      A A A
      A B B'
      (@Hom_prof_along A A A (@id_func A) (@id_func A))
      P P'
      (@id_func A)
      K
      (@id_func A)
      G
      pp p;

// Covariant profunctor implication and eval/lambda calculus.
assert [A A' B B' X : Cat]
  (O : τ (Catd (Product_cat (Op_cat A) X)))
  (Q : τ (Catd (Product_cat (Op_cat B) X)))
  (F : τ (Functor A' A))
  (M : τ (Functor B' B)) ⊢
  @Prof_reindex
    A A' B B'
    (@Prof_imply_cov A B X O Q)
    F
    M
  ≡ @Prof_imply_cov
      A' B' X
      (@Prof_reindex A A' X X O F (@id_func X))
      (@Prof_reindex B B' X X Q M (@id_func X));

assert [A B X : Cat]
  (O : τ (Catd (Product_cat (Op_cat A) X)))
  (Q : τ (Catd (Product_cat (Op_cat B) X))) ⊢
  @Prof_reindex
    A A B B
    (@Prof_imply_cov A B X O Q)
    (@id_func A)
    (@id_func B)
  ≡ @Prof_imply_cov A B X O Q;

assert [A A' B B' X : Cat]
  [O : τ (Catd (Product_cat (Op_cat A) X))]
  [O' : τ (Catd (Product_cat (Op_cat A') X))]
  [Q : τ (Catd (Product_cat (Op_cat B) X))]
  [Q' : τ (Catd (Product_cat (Op_cat B') X))]
  [F : τ (Functor A A')]
  [M : τ (Functor B' B)]
  (o : τ (Obj (@Prof_transf_cat A' A X X O F O' (@id_func X))))
  (q : τ (Obj (@Prof_transf_cat B B' X X Q' M Q (@id_func X)))) ⊢
  @Prof_imply_cov_transf
    A A' B B' X
    O O' Q Q' F M
    o q
  : τ (Obj
      (@Prof_transf_cat
        A' A B' B'
        (@Prof_reindex
          A A B B'
          (@Prof_imply_cov A B X O Q)
          (@id_func A)
          M)
        F
        (@Prof_imply_cov A' B' X O' Q')
        (@id_func B')));

assert [A B X : Cat]
  (Q : τ (Prof B X))
  (O : τ (Prof A X)) ⊢
  fapp0 (@Prof_imply_cov_func A B X Q) O
  ≡ @Prof_imply_cov A B X O Q;

assert [A B X : Cat]
  (Q : τ (Prof B X))
  [O O' : τ (Prof A X)] ⊢
  fapp1_func (@Prof_imply_cov_func A B X Q) [O] [O']
  : τ (Functor
      (@Functord_cat
        (Product_cat (Op_cat A) X)
        O O')
      (@Functord_cat
        (Product_cat (Op_cat A) B)
        (@Prof_imply_cov A B X O Q)
        (@Prof_imply_cov A B X O' Q)));

assert [A B X : Cat]
  (Q : τ (Prof B X))
  [O O' : τ (Prof A X)]
  (o : τ (Functord O O')) ⊢
  fapp1_fapp0
    (@Prof_imply_cov_func A B X Q)
    [O] [O'] o
  : τ (Functord
      (@Prof_imply_cov A B X O Q)
      (@Prof_imply_cov A B X O' Q));

assert [A B X : Cat]
  (Q : τ (Prof B X))
  (O : τ (Prof A X)) ⊢
  @fapp1_fapp0
    (@Prof_cat A X)
    (@Prof_cat A B)
    (@Prof_imply_cov_func A B X Q)
    O O
    (@id (@Prof_cat A X) O)
  ≡ @id_funcd
      (Product_cat (Op_cat A) B)
      (@Prof_imply_cov A B X O Q);

assert [A B X : Cat]
  (Q : τ (Prof B X))
  [O O' O'' : τ (Prof A X)]
  (o : τ (Functord O O'))
  (o' : τ (Functord O' O'')) ⊢
  @comp_catd_fapp0
      (Product_cat (Op_cat A) B)
      (@Prof_imply_cov A B X O Q)
      (@Prof_imply_cov A B X O' Q)
      (@Prof_imply_cov A B X O'' Q)
      (fapp1_fapp0
        (@Prof_imply_cov_func A B X Q)
        [O'] [O''] o')
      (fapp1_fapp0
        (@Prof_imply_cov_func A B X Q)
        [O] [O'] o)
  ≡ fapp1_fapp0
      (@Prof_imply_cov_func A B X Q)
      [O] [O'']
      (@comp_catd_fapp0
        (Product_cat (Op_cat A) X)
        O O' O'' o' o);

assert [A B X : Cat]
  (oq : τ (Obj
    (Product_cat
      (Prof_cat A X)
      (Op_cat (Prof_cat B X))))) ⊢
  @fapp0
    (Product_cat
      (Prof_cat A X)
      (Op_cat (Prof_cat B X)))
    (Prof_cat A B)
    (@Prof_imply_cov_func2 A B X)
    oq
  ≡ @Prof_imply_cov
      A B X
      (sigma_Fst oq)
      (sigma_Snd oq);

assert [A B X : Cat]
  [oq oq' : τ (Obj
    (Product_cat
      (Prof_cat A X)
      (Op_cat (Prof_cat B X))))] ⊢
  @fapp1_func
    (Product_cat
      (Prof_cat A X)
      (Op_cat (Prof_cat B X)))
    (Prof_cat A B)
    (@Prof_imply_cov_func2 A B X)
    oq oq'
  : τ (Functor
      (Hom_cat
        (Product_cat
          (Prof_cat A X)
          (Op_cat (Prof_cat B X)))
        oq oq')
      (Hom_cat
        (Prof_cat A B)
        (fapp0 (@Prof_imply_cov_func2 A B X) oq)
        (fapp0 (@Prof_imply_cov_func2 A B X) oq')));

assert [A B X : Cat]
  [oq oq' : τ (Obj
    (Product_cat
      (Prof_cat A X)
      (Op_cat (Prof_cat B X))))]
  (r : τ (Hom
    (Product_cat
      (Prof_cat A X)
      (Op_cat (Prof_cat B X)))
    oq oq')) ⊢
  @fapp1_fapp0
    (Product_cat
      (Prof_cat A X)
      (Op_cat (Prof_cat B X)))
    (Prof_cat A B)
    (@Prof_imply_cov_func2 A B X)
    oq oq' r
  : τ (Hom
      (Prof_cat A B)
      (@Prof_imply_cov A B X (sigma_Fst oq) (sigma_Snd oq))
      (@Prof_imply_cov A B X (sigma_Fst oq') (sigma_Snd oq')));

assert [A B X : Cat]
  (oq : τ (Obj
    (Product_cat
      (Prof_cat A X)
      (Op_cat (Prof_cat B X))))) ⊢
  @fapp1_fapp0
    (Product_cat
      (Prof_cat A X)
      (Op_cat (Prof_cat B X)))
    (Prof_cat A B)
    (@Prof_imply_cov_func2 A B X)
    oq oq
    (@id
      (Product_cat
        (Prof_cat A X)
        (Op_cat (Prof_cat B X)))
      oq)
  ≡ @id_funcd
      (Product_cat (Op_cat A) B)
      (@Prof_imply_cov
        A B X
        (sigma_Fst oq)
        (sigma_Snd oq));

assert [A B X : Cat]
  [oq0 oq1 oq2 : τ (Obj
    (Product_cat
      (Prof_cat A X)
      (Op_cat (Prof_cat B X))))]
  (r01 : τ (Hom
    (Product_cat
      (Prof_cat A X)
      (Op_cat (Prof_cat B X)))
    oq0 oq1))
  (r12 : τ (Hom
    (Product_cat
      (Prof_cat A X)
      (Op_cat (Prof_cat B X)))
    oq1 oq2)) ⊢
  @comp_fapp0
      (Prof_cat A B)
      (fapp0 (@Prof_imply_cov_func2 A B X) oq0)
      (fapp0 (@Prof_imply_cov_func2 A B X) oq1)
      (fapp0 (@Prof_imply_cov_func2 A B X) oq2)
      (fapp1_fapp0 (@Prof_imply_cov_func2 A B X) r12)
      (fapp1_fapp0 (@Prof_imply_cov_func2 A B X) r01)
  ≡ fapp1_fapp0
      (@Prof_imply_cov_func2 A B X)
      (@comp_fapp0
        (Product_cat
          (Prof_cat A X)
          (Op_cat (Prof_cat B X)))
        oq0 oq1 oq2 r12 r01);

assert [A B X : Cat]
  [O O' : τ (Prof A X)]
  [Q Q' : τ (Prof B X)]
  (o : τ (Functord O O'))
  (q : τ (Functord Q' Q)) ⊢
  @Prof_imply_cov_transf
    A A B B X
    O O' Q Q'
    (@id_func A)
    (@id_func B)
    o q
  ≡ @fapp1_fapp0
      (Product_cat
        (Prof_cat A X)
        (Op_cat (Prof_cat B X)))
      (Prof_cat A B)
      (@Prof_imply_cov_func2 A B X)
      (Struct_sigma O Q)
      (Struct_sigma O' Q')
      (Struct_sigma o q);

assert [A B X : Cat]
  [P : τ (Prof A B)]
  [Q : τ (Prof B X)]
  [O : τ (Prof A X)]
  (t : τ (ProfMap P (@Prof_imply_cov A B X O Q))) ⊢
  @Prof_lambda_cov_map A B X P Q O
    (@Prof_eval_cov_map A B X P Q O t)
  ≡ t;

assert [A B X : Cat]
  [P : τ (Prof A B)]
  [Q : τ (Prof B X)]
  [O : τ (Prof A X)]
  (t : τ (ProfMap (@Prof_tensor A B X P Q) O)) ⊢
  @Prof_eval_cov_map A B X P Q O
    (@Prof_lambda_cov_map A B X P Q O t)
  ≡ t;

assert [A B X A' : Cat]
  [P : τ (Catd (Product_cat (Op_cat A) B))]
  [Q : τ (Catd (Product_cat (Op_cat B) X))]
  [O : τ (Catd (Product_cat (Op_cat A') X))]
  [F : τ (Functor A A')]
  (t : τ (Obj
    (@Prof_transf_cat
      A' A B B
      P
      F
      (@Prof_imply_cov A' B X O Q)
      (@id_func B)))) ⊢
  @Prof_lambda_cov_transf
    A B X A'
    P Q O F
    (@Prof_eval_cov_transf
      A B X A'
      P Q O F
      t)
  ≡ t;

assert [A B X A' : Cat]
  [P : τ (Catd (Product_cat (Op_cat A) B))]
  [Q : τ (Catd (Product_cat (Op_cat B) X))]
  [O : τ (Catd (Product_cat (Op_cat A') X))]
  [F : τ (Functor A A')]
  (t : τ (Obj
    (@Prof_transf_cat
      A' A X X
      (@Prof_tensor A B X P Q)
      F
      O
      (@id_func X)))) ⊢
  @Prof_eval_cov_transf
    A B X A'
    P Q O F
    (@Prof_lambda_cov_transf
      A B X A'
      P Q O F
      t)
  ≡ t;

assert [A X : Cat]
  [Q O : τ (Prof A X)]
  (t : τ (@Prof_hom
    A A A
    (@id_func A)
    (@Prof_imply_cov A A X O Q)
    (@id_func A))) ⊢
  @Prof_lambda_cov_hom_map A X Q O
    (@Prof_eval_cov_hom_map A X Q O t)
  ≡ t;

assert [A X : Cat]
  [Q O : τ (Prof A X)]
  (t : τ (ProfMap Q O)) ⊢
  @Prof_eval_cov_hom_map A X Q O
    (@Prof_lambda_cov_hom_map A X Q O t)
  ≡ t;

assert [A X A' : Cat]
  [Q : τ (Catd (Product_cat (Op_cat A) X))]
  [O : τ (Catd (Product_cat (Op_cat A') X))]
  [F : τ (Functor A A')]
  (t : τ (@Prof_hom
    A A' A
    F
    (@Prof_imply_cov A' A X O Q)
    (@id_func A))) ⊢
  @Prof_lambda_cov_transf_hom
    A X A'
    Q O F
    (@Prof_eval_cov_hom_transf
      A X A'
      Q O F
      t)
  ≡ t;

assert [A X A' : Cat]
  [Q : τ (Catd (Product_cat (Op_cat A) X))]
  [O : τ (Catd (Product_cat (Op_cat A') X))]
  [F : τ (Functor A A')]
  (t : τ (Obj
    (@Prof_transf_cat A' A X X Q F O (@id_func X)))) ⊢
  @Prof_eval_cov_hom_transf
    A X A'
    Q O F
    (@Prof_lambda_cov_transf_hom
      A X A'
      Q O F
      t)
  ≡ t;

assert [A B B' X X' : Cat]
  (P : τ (Catd (Product_cat (Op_cat A) B)))
  (O : τ (Catd (Product_cat (Op_cat A) X)))
  (M : τ (Functor B' B))
  (G : τ (Functor X' X)) ⊢
  @Prof_reindex
    B B' X X'
    (@Prof_imply_con A B X P O)
    M
    G
  ≡ @Prof_imply_con
      A B' X'
      (@Prof_reindex A A B B' P (@id_func A) M)
      (@Prof_reindex A A X X' O (@id_func A) G);

assert [A B X : Cat]
  (P : τ (Catd (Product_cat (Op_cat A) B)))
  (O : τ (Catd (Product_cat (Op_cat A) X))) ⊢
  @Prof_reindex
    B B X X
    (@Prof_imply_con A B X P O)
    (@id_func B)
    (@id_func X)
  ≡ @Prof_imply_con A B X P O;

assert [A B B' X X' : Cat]
  [P : τ (Catd (Product_cat (Op_cat A) B))]
  [P' : τ (Catd (Product_cat (Op_cat A) B'))]
  [O : τ (Catd (Product_cat (Op_cat A) X))]
  [O' : τ (Catd (Product_cat (Op_cat A) X'))]
  [M : τ (Functor B' B)]
  [G : τ (Functor X X')]
  (p : τ (Obj (@Prof_transf_cat A A B B' P' (@id_func A) P M)))
  (o : τ (Obj (@Prof_transf_cat A A X' X O (@id_func A) O' G))) ⊢
  @Prof_imply_con_transf
    A B B' X X'
    P P' O O' M G
    p o
  : τ (Obj
      (@Prof_transf_cat
        B' B' X' X
        (@Prof_reindex
          B B' X X
          (@Prof_imply_con A B X P O)
          M
          (@id_func X))
        (@id_func B')
        (@Prof_imply_con A B' X' P' O')
        G));

assert [A B X : Cat]
  [P : τ (Prof A B)]
  [Q : τ (Prof B X)]
  [O : τ (Prof A X)]
  (t : τ (ProfMap Q (@Prof_imply_con A B X P O))) ⊢
  @Prof_lambda_con_map A B X P Q O
    (@Prof_eval_con_map A B X P Q O t)
  ≡ t;

assert [A B X : Cat]
  [P : τ (Prof A B)]
  [Q : τ (Prof B X)]
  [O : τ (Prof A X)]
  (t : τ (ProfMap (@Prof_tensor A B X P Q) O)) ⊢
  @Prof_eval_con_map A B X P Q O
    (@Prof_lambda_con_map A B X P Q O t)
  ≡ t;

assert [A B X X' : Cat]
  [P : τ (Catd (Product_cat (Op_cat A) B))]
  [Q : τ (Catd (Product_cat (Op_cat B) X))]
  [O : τ (Catd (Product_cat (Op_cat A) X'))]
  [G : τ (Functor X X')]
  (t : τ (Obj
    (@Prof_transf_cat
      B B X' X
      Q
      (@id_func B)
      (@Prof_imply_con A B X' P O)
      G))) ⊢
  @Prof_lambda_con_transf
    A B X X'
    P Q O G
    (@Prof_eval_con_transf
      A B X X'
      P Q O G
      t)
  ≡ t;

assert [A B X X' : Cat]
  [P : τ (Catd (Product_cat (Op_cat A) B))]
  [Q : τ (Catd (Product_cat (Op_cat B) X))]
  [O : τ (Catd (Product_cat (Op_cat A) X'))]
  [G : τ (Functor X X')]
  (t : τ (Obj
    (@Prof_transf_cat
      A A X' X
      (@Prof_tensor A B X P Q)
      (@id_func A)
      O
      G))) ⊢
  @Prof_eval_con_transf
    A B X X'
    P Q O G
    (@Prof_lambda_con_transf
      A B X X'
      P Q O G
      t)
  ≡ t;

assert [A B : Cat]
  [P O : τ (Prof A B)]
  (t : τ (@Prof_hom
    B B B
    (@id_func B)
    (@Prof_imply_con A B B P O)
    (@id_func B))) ⊢
  @Prof_lambda_con_hom_map A B P O
    (@Prof_eval_con_hom_map A B P O t)
  ≡ t;

assert [A B : Cat]
  [P O : τ (Prof A B)]
  (t : τ (ProfMap P O)) ⊢
  @Prof_eval_con_hom_map A B P O
    (@Prof_lambda_con_hom_map A B P O t)
  ≡ t;

assert [A B X : Cat]
  [P : τ (Catd (Product_cat (Op_cat A) B))]
  [O : τ (Catd (Product_cat (Op_cat A) X))]
  [G : τ (Functor B X)]
  (t : τ (@Prof_hom
    B B X
    (@id_func B)
    (@Prof_imply_con A B X P O)
    G)) ⊢
  @Prof_lambda_con_transf_hom
    A B X
    P O G
    (@Prof_eval_con_hom_transf
      A B X
      P O G
      t)
  ≡ t;

assert [A B X : Cat]
  [P : τ (Catd (Product_cat (Op_cat A) B))]
  [O : τ (Catd (Product_cat (Op_cat A) X))]
  [G : τ (Functor B X)]
  (t : τ (Obj
    (@Prof_transf_cat A A X B P (@id_func A) O G))) ⊢
  @Prof_eval_con_hom_transf
    A B X
    P O G
    (@Prof_lambda_con_transf_hom
      A B X
      P O G
      t)
  ≡ t;

assert [B J J' : Cat]
  (F : τ (Functor J B))
  (W : τ (Prof J' J)) ⊢
  @WeightedCone_prof B J J' F W
  ≡ @Prof_imply_cov
      B J' J
      (@Hom_prof J B F)
      W;

assert [B J J' : Cat]
  (F : τ (Functor J B))
  (W : τ (Prof J' J))
  (L : τ (Functor J' B)) ⊢
  @IsWeightedLimit_cov_iso B J J' F W L
  ≡ @IsoEvidence
      (@Prof_cat B J')
      (@Prof_imply_cov
        B J' J
        (@Hom_prof J B F)
        W)
      (@Conjoint_prof J' B L);

assert [B J J' : Cat]
  (W : τ (Prof J' J))
  [O O' : τ (Prof B J)]
  (i : τ (@IsoEvidence (@Prof_cat B J) O O')) ⊢
  @iso_evidence_fmap
    (@Prof_cat B J)
    (@Prof_cat B J')
    (@Prof_imply_cov_func B J' J W)
    O O' i
  : τ (@IsoEvidence
      (@Prof_cat B J')
      (@Prof_imply_cov B J' J O W)
      (@Prof_imply_cov B J' J O' W));

// Computational profunctor comparisons and weighted representability.
assert [A B : Cat]
  [P Q : τ (Prof A B)]
  (i : τ (@ProfComparison A B P Q)) ⊢
  @prof_comparison_evidence A B P Q i
  : τ (@IsoEvidence (@Prof_cat A B) P Q);

assert [A B : Cat]
  [P Q : τ (Prof A B)]
  (i : τ (@ProfComparison A B P Q)) ⊢
  @prof_comparison_to_evidence A B P Q i
  ≡ eq_refl (@prof_comparison_to A B P Q i);

assert [A B : Cat]
  [P Q : τ (Prof A B)]
  (i : τ (@ProfComparison A B P Q)) ⊢
  @prof_comparison_from_evidence A B P Q i
  ≡ eq_refl (@prof_comparison_from A B P Q i);

assert [A B : Cat]
  [P Q : τ (Prof A B)]
  (i : τ (@ProfComparison A B P Q)) ⊢
  @comp_catd_fapp0
    (Product_cat (Op_cat A) B)
    P Q P
    (@prof_comparison_from A B P Q i)
    (@prof_comparison_to A B P Q i)
  ≡ @id_funcd
      (Product_cat (Op_cat A) B)
      P;

assert [A B : Cat]
  [P Q R : τ (Prof A B)]
  (i : τ (@ProfComparison A B P Q))
  (r : τ (@ProfMap A B R P)) ⊢
  @prof_comparison_push_semantics A B P Q i R r
  : τ (
      @prof_comparison_push A B P Q i R r
      =
      @comp_catd_fapp0
        (Product_cat (Op_cat A) B)
        R P Q
        (@iso_evidence_to
          (Prof_cat A B) P Q
        (@prof_comparison_evidence A B P Q i))
        r);

assert [A B : Cat]
  [P Q R S : τ (Prof A B)]
  (i : τ (@ProfComparison A B P Q))
  (r : τ (@ProfMap A B R P))
  (h : τ (@ProfMap A B S R)) ⊢
  @comp_catd_fapp0
    (Product_cat (Op_cat A) B)
    S R Q
    (@prof_comparison_push A B P Q i R r)
    h
  ≡ @prof_comparison_push A B P Q i S
      (@comp_catd_fapp0
        (Product_cat (Op_cat A) B)
        S R P r h);

assert [A B : Cat]
  [P Q R : τ (Prof A B)]
  (i : τ (@ProfComparison A B P Q))
  (r : τ (@ProfMap A B R P)) ⊢
  @fapp0
    (Hom_cat (Prof_cat A B) R P)
    (Hom_cat (Prof_cat A B) R Q)
    (@prof_comparison_push_func A B P Q i R)
    r
  ≡ @prof_comparison_push A B P Q i R r;

assert [A B : Cat]
  [P Q R : τ (Prof A B)]
  (i : τ (@ProfComparison A B P Q))
  (r : τ (@ProfMap A B R P)) ⊢
  @prof_comparison_pull A B P Q i R
    (@prof_comparison_push A B P Q i R r)
  ≡ r;

assert [A B : Cat]
  [P Q R : τ (Prof A B)]
  (i : τ (@ProfComparison A B P Q))
  (s : τ (@ProfMap A B R Q)) ⊢
  @prof_comparison_push A B P Q i R
    (@prof_comparison_pull A B P Q i R s)
  ≡ s;

assert [A B : Cat]
  [P R : τ (Prof A B)]
  (r : τ (@ProfMap A B R P)) ⊢
  @prof_comparison_push
    A B P P
    (@prof_comparison_refl A B P)
    R r
  ≡ r;

assert [A B : Cat]
  [P Q S R : τ (Prof A B)]
  (i : τ (@ProfComparison A B P Q))
  (j : τ (@ProfComparison A B Q S))
  (r : τ (@ProfMap A B R P)) ⊢
  @prof_comparison_push
    A B P S
    (@prof_comparison_comp A B P Q S j i)
    R r
  ≡ @prof_comparison_push A B Q S j R
      (@prof_comparison_push A B P Q i R r);

assert [B J J' : Cat]
  [F : τ (Functor J B)]
  [W : τ (Prof J' J)]
  [L : τ (Functor J' B)]
  (isl : τ (@IsWeightedLimit_cov_comp B J J' F W L)) ⊢
  @prof_comparison_evidence
    B J'
    (@WeightedCone_prof B J J' F W)
    (@Hom_prof J' B L)
    isl
  : τ (@IsWeightedLimit_cov_iso B J J' F W L);

assert [B J J' I : Cat]
  [F : τ (Functor J B)]
  [W : τ (Prof J' J)]
  [L : τ (Functor J' B)]
  (isl : τ (@IsWeightedLimit_cov_comp B J J' F W L))
  (M : τ (Functor I B))
  [R : τ (Prof I J')]
  (r : τ (ProfMap
      R
      (@Prof_imply_cov
        I J' J
        (@Hom_prof_along I J B M F)
        W))) ⊢
  @weighted_limit_cov_pull B J J' F W L isl I M R
    (@weighted_limit_cov_push B J J' F W L isl I M R r)
  ≡ r;

assert [B J J' I : Cat]
  [F : τ (Functor J B)]
  [W : τ (Prof J' J)]
  [L : τ (Functor J' B)]
  (isl : τ (@IsWeightedLimit_cov_comp B J J' F W L))
  (M : τ (Functor I B))
  [R : τ (Prof I J')]
  (s : τ (ProfMap R (@Hom_prof_along I J' B M L))) ⊢
  @weighted_limit_cov_push B J J' F W L isl I M R
    (@weighted_limit_cov_pull B J J' F W L isl I M R s)
  ≡ s;

assert [A B : Cat]
  (adj : τ (Adjunction A B)) ⊢
  @prof_comparison_evidence
    A B
    _
    _
    (@Adjunction_hom_prof_comparison A B adj)
  ≡ @Adjunction_hom_prof_iso_evidence A B adj;

assert [B J J' A : Cat]
  [W : τ (Prof J' J)]
  [F : τ (Functor J B)]
  [L : τ (Functor J' B)]
  (isl : τ (@IsWeightedLimit_cov_comp B J J' F W L))
  (adj : τ (Adjunction A B)) ⊢
  @prof_comparison_evidence
    A J'
    _ _
    (@right_adjoint_preserves_weighted_limit_cov_comp
      B J J' A W F L isl adj)
  ≡ @right_adjoint_preserves_weighted_limit_cov_iso
      B J J' A W F L
      (@prof_comparison_evidence
        B J'
        _
        _
        isl)
      adj;

assert [B J J' A : Cat]
  [W : τ (Prof J' J)]
  [F : τ (Functor J B)]
  [L : τ (Functor J' B)]
  (isl : τ (@IsWeightedLimit_cov_comp B J J' F W L))
  (adj : τ (Adjunction A B)) ⊢
  @right_adjoint_preserves_weighted_limit_cov_comp
    B J J' A W F L isl adj
  : τ (@IsWeightedLimit_cov_comp
      A J J'
      (@comp_cat_fapp0
        J B A
        (@right_adj_func A B adj)
        F)
      W
      (@comp_cat_fapp0
        J' B A
        (@right_adj_func A B adj)
        L));

assert [B J J' I : Cat]
  [F : τ (Functor J B)]
  [W : τ (Catd (Product_cat (Op_cat J') J))]
  [L : τ (Functor J' B)]
  (isl : τ (@WeightedLimit_cov B J J' F W L))
  (M : τ (Functor I B)) ⊢
  @weighted_limit_cov_univ_transf
    B J J'
    F W L
    isl
    I M
  : τ (Obj
      (@Prof_transf_cat
        I I J' J'
        (@Prof_imply_cov
          I J' J
          (@Hom_prof_along I J B M F)
          W)
        (@id_func I)
        (@Hom_prof_along I J' B M L)
        (@id_func J')));

assert [B J J' I : Cat]
  [F : τ (Functor J B)]
  [W : τ (Catd (Product_cat (Op_cat J') J))]
  [L : τ (Functor J' B)]
  (isl : τ (@WeightedLimit_cov B J J' F W L))
  (M : τ (Functor I B)) ⊢
  @weighted_limit_cov_cone_transf
    B J J'
    F W L
